// An AI was asked to "add a Triangle variant". It added it to the TYPE
// but forgot to handle it in `area` — the canonical modification mistake.
type Shape = Circle(Int) | Rect(Int, Int) | Triangle(Int, Int)

fn area(s: Shape) -> Int = match s {
  Circle(r)  => 3 * r * r,
  Rect(w, h) => w * h,
}

fn main() -> Unit = {
  println(int.to_string(area(Triangle(4, 6))))
}
