// msr.almd — MSR (Modification Survival Rate) measurement tool
//
// Usage:
//   almide run msr/msr.almd                                    # default: haiku, all exercises
//   almide run msr/msr.almd -- --model sonnet                  # use sonnet
//   almide run msr/msr.almd -- --exercise bob                  # single exercise

import args
import fs
import process

fn run_exercise(name: String, prompt_path: String, output_dir: String, model: String, system_prompt: String) -> Bool = {
  let output_path = output_dir + "/" + name + ".almd"
  let prompt_content = result.unwrap_or(fs.read_text(prompt_path), "")
  let full_prompt = prompt_content + "\n\nImplement the functions above. Output ONLY the complete .almd file."

  // Call claude CLI
  let solution = process.exec("claude", ["--model", model, "--print", "-s", system_prompt, full_prompt])

  if result.is_err(solution) then false
  else {
    let code = result.unwrap_or(solution, "")

    // Strip code fences
    let cleaned = code
      |> string.split("\n")
      |> list.filter((line) => not string.starts_with(string.trim(line), "```"))
      |> string.join("\n")

    let _ = fs.write(output_path, cleaned)

    // Verify: type check
    let check = process.exec("almide", ["check", output_path])
    if result.is_err(check) then false
    else {
      // Verify: run tests
      let test_r = process.exec("almide", ["test", output_path])
      result.is_ok(test_r)
    }
  }
}

effect fn main() -> Result[Unit, String] = do {
  let model = args.option_or("model", "haiku")
  let exercise_filter = args.option("exercise")
  let prompt_dir = "msr/prompts"
  let output_dir = "msr/outputs/" + model

  fs.mkdir_p(output_dir)

  let cheatsheet = fs.read_text("docs/CHEATSHEET.md")

  let system_prompt = "You are writing Almide code (.almd files). Here is the language reference:\n\n" + cheatsheet + "\n\nIMPORTANT RULES:\n- Write ONLY the Almide code. No markdown, no explanation, no code fences.\n- Replace `todo` with working implementations.\n- Keep all test blocks exactly as they are.\n- Keep all type declarations exactly as they are.\n- Lambda syntax: (x) => expr, NOT fn(x) => expr\n- if requires then: if cond then a else b\n- String concat uses +\n- effect fn returns Result, auto-unwraps with ?"

  let all_prompts = fs.glob(prompt_dir + "/*.almd.prompt")
  let prompts = match exercise_filter {
    some(name) => list.filter(all_prompts, (p) => string.contains(p, "/" + name + ".almd.prompt"))
    none => all_prompts
  }

  println("")
  println("MSR Measurement — " + model)
  println("================================")
  println("")

  var pass = 0
  var fail = 0
  var total = 0

  for prompt_path in prompts {
    let parts = string.split(prompt_path, "/")
    let filename = list.get_or(parts, list.len(parts) - 1, "unknown.almd.prompt")
    let name = string.replace(filename, ".almd", "")

    if name == "wasm-smoke" then {
      println("SKIP " + name)
    } else {
      total = total + 1
      println("RUN  " + name)

      let passed = run_exercise(name, prompt_path, output_dir, model, system_prompt)

      if passed then {
        println("  OK " + name)
        pass = pass + 1
      } else {
        println("  NG " + name)
        fail = fail + 1
      }
    }
  }

  println("")
  println("================================")
  println("Model:  " + model)
  println("Passed: " + int.to_string(pass) + " / " + int.to_string(total))

  if total > 0 then {
    let msr = pass * 100 / total
    println("MSR:    " + int.to_string(msr) + "%")
  } else {
    println("No exercises found.")
  }

  let results_dir = "msr/results"
  fs.mkdir_p(results_dir)
  let report = "model: " + model + "\npassed: " + int.to_string(pass) + "\ntotal: " + int.to_string(total)
  fs.write(results_dir + "/" + model + ".txt", report)

  println("")
  println("Results: " + results_dir + "/" + model + ".txt")
  println("Outputs: " + output_dir + "/")

  ok(())
}
