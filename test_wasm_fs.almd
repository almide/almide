import fs

effect fn main() -> Result[Unit, String] = {
  fs.write("_wasm_test_tmp.txt", "hello from wasm")

  let exists = fs.exists("_wasm_test_tmp.txt")
  assert(exists)

  let content = fs.read_text("_wasm_test_tmp.txt")
  assert_eq(content, "hello from wasm")

  println("WASM fs test passed!")
  ok(())
}
