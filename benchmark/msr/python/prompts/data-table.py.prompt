from dataclasses import dataclass


@dataclass
class Row:
    id: int
    name: str
    value: int


TABLE = [Row(1, "alpha", 10), Row(2, "beta", 20), Row(3, "gamma", 30)]


def pluck_ids(rows: list[Row]) -> list[int]:
