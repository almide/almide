// msr.almd — MSR (Modification Survival Rate) measurement tool
//
// Usage:
//   almide run benchmark/msr/msr.almd                          # default: haiku
//   almide run benchmark/msr/msr.almd -- --model sonnet         # use sonnet
//   almide run benchmark/msr/msr.almd -- --exercise bob         # single exercise

import fs
import env
import process

fn find_arg(raw_args: List[String], name: String, fallback: String) -> String = {
  let flag = "--" + name
  match list.index_of(raw_args, flag) {
    some(i) => list.get_or(raw_args, i + 1, fallback)
    none => fallback
  }
}

effect fn main() -> Result[Unit, String] = {
  let raw_args = env.args()
  let model = find_arg(raw_args, "model", "haiku")
  let exercise_raw = find_arg(raw_args, "exercise", "")
  let prompt_dir = "benchmark/msr/prompts"
  let output_dir = "benchmark/msr/outputs/" + model

  fs.mkdir_p(output_dir)

  let cheatsheet = fs.read_text("docs/CHEATSHEET.md")

  let system_prompt = "You are writing Almide code (.almd files). Here is the language reference:\n\n" + cheatsheet + "\n\nIMPORTANT RULES:\n- Write ONLY the Almide code. No markdown, no explanation, no code fences.\n- Replace `todo` with working implementations.\n- Keep all test blocks exactly as they are.\n- Keep all type declarations exactly as they are.\n- Lambda syntax: (x) => expr, NOT fn(x) => expr\n- if requires then: if cond then a else b\n- String concat uses +\n- effect fn returns Result, auto-unwraps with ?"

  let all_files = fs.list_dir(prompt_dir)
  let all_prompts = list.filter(all_files, (f) => string.ends_with(f, ".almd.prompt"))
    |> list.map((f) => prompt_dir + "/" + f)
  let prompts = if string.len(exercise_raw) > 0
    then list.filter(all_prompts, (p) => string.contains(p, "/" + exercise_raw + ".almd.prompt"))
    else all_prompts

  println("")
  println("MSR Measurement — " + model)
  println("================================")
  println("")

  var pass = 0
  var fail = 0
  var total = 0

  for prompt_path in prompts {
    let parts = string.split(prompt_path, "/")
    let filename = list.get_or(parts, list.len(parts) - 1, "unknown")
    let name = string.replace(filename, ".almd.prompt", "")

    if name == "wasm-smoke" then {
      println("SKIP " + name)
    } else {
      total = total + 1
      let output_path = output_dir + "/" + name + ".almd"

      let prompt_content = fs.read_text(prompt_path)
      let full_prompt = prompt_content + "\n\nImplement the functions above. Output ONLY the complete .almd file."

      println("RUN  " + name)

      // Call claude CLI — match on Result for error handling
      match process.exec("claude", ["--model", model, "--print", "--system-prompt", system_prompt, full_prompt]) {
        ok(solution) => {
          // Strip markdown code fences if present
          let cleaned = solution
            |> string.split("\n")
            |> list.filter((line) => not string.starts_with(string.trim(line), "```"))
            |> string.join("\n")

          let _ = fs.write(output_path, cleaned)

          // Verify: type check
          match process.exec("almide", ["check", output_path]) {
            ok(_) => {
              // Verify: run tests
              match process.exec("almide", ["test", output_path]) {
                ok(_) => {
                  println("  OK " + name)
                  pass = pass + 1
                }
                err(_) => {
                  println("  NG " + name + " (test)")
                  fail = fail + 1
                }
              }
            }
            err(_) => {
              println("  NG " + name + " (check)")
              fail = fail + 1
            }
          }
        }
        err(e) => {
          println("  NG " + name + " (cli: " + e + ")")
          fail = fail + 1
        }
      }
    }
  }

  println("")
  println("================================")
  println("Model:  " + model)
  println("Passed: " + int.to_string(pass) + " / " + int.to_string(total))

  if total > 0 then {
    let msr = pass * 100 / total
    println("MSR:    " + int.to_string(msr) + "%")
  } else {
    println("No exercises found.")
  }

  let results_dir = "benchmark/msr/results"
  fs.mkdir_p(results_dir)
  let report = "model: " + model + "\npassed: " + int.to_string(pass) + "\ntotal: " + int.to_string(total)
  fs.write(results_dir + "/" + model + ".txt", report)

  println("")
  println("Results: " + results_dir + "/" + model + ".txt")
  println("Outputs: " + output_dir + "/")

  ok(())
}
