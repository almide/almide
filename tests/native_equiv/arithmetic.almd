fn add(a: Int, b: Int) -> Int = a + b

fn fib(n: Int) -> Int =
  if n < 2 then n
  else fib(n - 1) + fib(n - 2)

fn classify(n: Int) -> String =
  match n {
    0 => "zero",
    1 => "one",
    _ => "many",
  }

fn main() -> Unit = {
  println(int.to_string(add(3, 4)))
  println(int.to_string(fib(10)))
  println(classify(7))
}
