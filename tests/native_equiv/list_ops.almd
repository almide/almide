fn double(x: Int) -> Int = x * 2

fn main() -> Unit = {
  let xs = [1, 2, 3, 4, 5]
  let doubled = xs |> list.map((x) => double(x))
  let evens = doubled |> list.filter((x) => x % 2 == 0)
  let total = list.fold(evens, 0, (acc, x) => acc + x)
  println(int.to_string(total))
  println(int.to_string(list.sum([10, 20, 30])))
  println(string.to_upper("hello"))
}
