type Shape = | Circle(Float) | Rect(Float, Float) | Point

fn area(s: Shape) -> Float =
  match s {
    Circle(r) => 3.14159 * r * r,
    Rect(w, h) => w * h,
    Point => 0.0,
  }

fn main() -> Unit = {
  println(float.to_string(area(Circle(5.0))))
  println(float.to_string(area(Rect(3.0, 4.0))))
  println(float.to_string(area(Point)))
}
