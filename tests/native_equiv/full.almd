type Vec2 = { x: Float, y: Float }

fn dot(a: Vec2, b: Vec2) -> Float = a.x * b.x + a.y * b.y

fn magnitude(v: Vec2) -> Float = math.sqrt(dot(v, v))

fn fib(n: Int) -> Int =
  match n {
    0 => 0,
    1 => 1,
    _ => fib(n - 1) + fib(n - 2),
  }

fn main() -> Unit = {
  let v = Vec2 { x: 3.0, y: 4.0 }
  println(float.to_string(magnitude(v)))
  let items = [10, 20, 30]
  println(int.to_string(list.len(items)))
  println(int.to_string(fib(10)))
  let m: Map[String, Int] = ["a": 1, "b": 2]
  println(int.to_string(map.len(m)))
  let result = if fib(5) > 3 then "big" else "small"
  println(result)
}
