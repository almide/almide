fn option.filter[A](o: Option[A], f: fn(A) -> Bool) -> Option[A]
fn option.flat_map[A, B](o: Option[A], f: fn(A) -> Option[B]) -> Option[B]
fn option.flatten[A](o: Option[Option[A]]) -> Option[A]
fn option.is_none[A](o: Option[A]) -> Bool
fn option.is_some[A](o: Option[A]) -> Bool
fn option.map[A, B](o: Option[A], f: fn(A) -> B) -> Option[B]
fn option.or_else[A](o: Option[A], f: fn(Unit) -> Option[A]) -> Option[A]
fn option.to_list[A](o: Option[A]) -> List[A]
fn option.to_result[A](o: Option[A], err: String) -> Result[A, String]
fn option.unwrap_or[A](o: Option[A], default: A) -> A
fn option.unwrap_or_else[A](o: Option[A], f: fn(Unit) -> A) -> A
fn option.zip[A, B](a: Option[A], b: Option[B]) -> Option[(A, B)]
