// operator_test — Operators beyond basic arithmetic

// ── Pipe operator ──

fn double(x: Int) -> Int = x * 2
fn add_one(x: Int) -> Int = x + 1

test "pipe basic" {
  let result = 5 |> double
  assert_eq(result, 10)
}

test "pipe chain" {
  let result = 3 |> double |> add_one |> double
  assert_eq(result, 14)
}

test "pipe into function call with args" {
  let xs = [3, 1, 2]
  let result = xs |> list.map(fn(x) => x * 10)
  assert_eq(result, [30, 10, 20])
}

test "pipe chain list operations" {
  let result = [1, 2, 3, 4, 5]
    |> list.filter(fn(x) => x % 2 == 0)
    |> list.map(fn(x) => x * 10)
  assert_eq(result, [20, 40])
}

// ── String concatenation (++) ──

test "string concat operator" {
  assert_eq("foo" ++ "bar", "foobar")
  assert_eq("" ++ "", "")
  assert_eq("a" ++ "b" ++ "c", "abc")
}

// ── List concatenation (++) ──

test "list concat operator" {
  assert_eq([1, 2] ++ [3], [1, 2, 3])
  assert_eq([1] ++ [2] ++ [3], [1, 2, 3])
}

// ── Deep equality (==, !=) ──

test "deep equality on lists" {
  assert_eq([1, 2, 3] == [1, 2, 3], true)
  assert_eq([1, 2] == [1, 3], false)
  assert_eq([1, 2] != [1, 3], true)
}

test "deep equality on records" {
  let a = { x: 1, y: "hello" }
  let b = { x: 1, y: "hello" }
  let c = { x: 2, y: "hello" }
  assert_eq(a == b, true)
  assert_eq(a != c, true)
}

test "deep equality on nested structures" {
  let a = { items: [1, 2], name: "test" }
  let b = { items: [1, 2], name: "test" }
  assert_eq(a == b, true)
}

test "equality on Option" {
  assert_eq(some(1) == some(1), true)
  assert_eq(some(1) != some(2), true)
  let x: Option[Int] = none
  assert_eq(x == none, true)
}

// ── Power / XOR (^) ──

test "float power" {
  assert_eq(2.0 ^ 3.0, 8.0)
  assert_eq(3.0 ^ 2.0, 9.0)
  assert_eq(4.0 ^ 0.5, 2.0)
}

test "int xor" {
  assert_eq(5 ^ 3, 6)
  assert_eq(0 ^ 0, 0)
  assert_eq(255 ^ 255, 0)
}

// ── Bitwise operations (stdlib) ──

test "bitwise and or xor" {
  assert_eq(int.band(0xFF, 0x0F), 15)
  assert_eq(int.bor(0xF0, 0x0F), 255)
  assert_eq(int.bxor(0xFF, 0x0F), 240)
}

test "bitwise shift" {
  assert_eq(int.bshl(1, 8), 256)
  assert_eq(int.bshr(256, 8), 1)
}

test "bitwise not" {
  assert_eq(int.band(int.bnot(0), 0xFF), 255)
}

// ── String interpolation ──

test "string interpolation basic" {
  let name = "world"
  assert_eq("hello ${name}", "hello world")
}

test "string interpolation with expression" {
  let x = 10
  assert_eq("value: ${int.to_string(x + 5)}", "value: 15")
}

test "string interpolation multiple" {
  let a = "foo"
  let b = "bar"
  assert_eq("${a}-${b}", "foo-bar")
}

// ── Comparison operators ──

test "string comparison" {
  assert_eq("a" < "b", true)
  assert_eq("b" > "a", true)
  assert_eq("abc" <= "abc", true)
  assert_eq("abc" >= "abc", true)
}

test "float comparison" {
  assert_eq(1.0 < 2.0, true)
  assert_eq(2.0 > 1.0, true)
  assert_eq(1.5 <= 1.5, true)
  assert_eq(1.5 >= 1.5, true)
}
