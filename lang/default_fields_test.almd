type Shape =
  | Circle { radius: Float }
  | Rect { width: Float, height: Float, color: String = "", filled: Bool = false }
  | Group { label: String, items: List[Shape] = [] }

fn describe(s: Shape) -> String = match s {
  Circle { radius } => "circle r=" ++ float.to_string(radius)
  Rect { width, height, color, filled } => {
    let base = "rect " ++ float.to_string(width) ++ "x" ++ float.to_string(height)
    let base = if color != "" then base ++ " color=" ++ color else base
    if filled then base ++ " filled" else base
  }
  Group { label, items } => {
    let count = list.len(items)
    label ++ " (" ++ int.to_string(count) ++ " items)"
  }
}

test "default fields - omit all defaults" {
  let r = Rect { width: 10.0, height: 20.0 }
  assert_eq(describe(r), "rect 10.0x20.0")
}

test "default fields - override one default" {
  let r = Rect { width: 5.0, height: 3.0, color: "red" }
  assert_eq(describe(r), "rect 5.0x3.0 color=red")
}

test "default fields - override all defaults" {
  let r = Rect { width: 1.0, height: 1.0, color: "blue", filled: true }
  assert_eq(describe(r), "rect 1.0x1.0 color=blue filled")
}

test "default fields - empty list default" {
  let g = Group { label: "empty" }
  assert_eq(describe(g), "empty (0 items)")
}

test "default fields - list with items" {
  let g = Group { label: "shapes", items: [Circle { radius: 1.0 }, Circle { radius: 2.0 }] }
  assert_eq(describe(g), "shapes (2 items)")
}

test "default fields - nested with defaults" {
  let g = Group { label: "nested", items: [Rect { width: 10.0, height: 20.0 }] }
  assert_eq(describe(g), "nested (1 items)")
}
