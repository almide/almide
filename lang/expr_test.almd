// expr_test — Basic expressions

// ── Integer arithmetic ──

test "addition" {
  assert_eq(1 + 2, 3)
  assert_eq(0 + 0, 0)
  assert_eq(-1 + 1, 0)
}

test "subtraction" {
  assert_eq(5 - 3, 2)
  assert_eq(0 - 1, -1)
  assert_eq(10 - 10, 0)
}

test "multiplication" {
  assert_eq(3 * 4, 12)
  assert_eq(0 * 100, 0)
  assert_eq(-2 * 3, -6)
}

test "division" {
  assert_eq(10 / 2, 5)
  assert_eq(7 / 3, 2)
  assert_eq(-6 / 2, -3)
}

test "modulo" {
  assert_eq(10 % 3, 1)
  assert_eq(9 % 3, 0)
  assert_eq(7 % 2, 1)
}

test "operator precedence" {
  assert_eq(2 + 3 * 4, 14)
  assert_eq((2 + 3) * 4, 20)
  assert_eq(10 - 2 * 3, 4)
  assert_eq(10 / 2 + 1, 6)
}

test "unary minus" {
  let x = 5
  assert_eq(-x, -5)
  assert_eq(-(-x), 5)
}

// ── Float arithmetic ──

test "float addition" {
  assert_eq(1.0 + 2.5, 3.5)
  assert_eq(0.1 + 0.2 > 0.29, true)
}

test "float multiplication" {
  assert_eq(2.0 * 3.0, 6.0)
  assert_eq(0.5 * 4.0, 2.0)
}

// ── Comparison operators ──

test "int comparison" {
  assert_eq(1 < 2, true)
  assert_eq(2 > 1, true)
  assert_eq(1 <= 1, true)
  assert_eq(1 >= 1, true)
  assert_eq(2 <= 1, false)
  assert_eq(0 >= 1, false)
}

test "equality on Int" {
  assert_eq(42 == 42, true)
  assert_eq(42 != 43, true)
  assert_eq(1 == 2, false)
  assert_eq(1 != 1, false)
}

test "equality on String" {
  assert_eq("hello" == "hello", true)
  assert_eq("hello" != "world", true)
  assert_eq("" == "", true)
}

test "equality on Bool" {
  assert_eq(true == true, true)
  assert_eq(false == false, true)
  assert_eq(true != false, true)
}

// ── Logical operators ──

test "and" {
  assert_eq(true and true, true)
  assert_eq(true and false, false)
  assert_eq(false and true, false)
  assert_eq(false and false, false)
}

test "or" {
  assert_eq(true or false, true)
  assert_eq(false or true, true)
  assert_eq(false or false, false)
  assert_eq(true or true, true)
}

test "not" {
  assert_eq(not true, false)
  assert_eq(not false, true)
  assert_eq(not (1 == 2), true)
}

test "short-circuit and" {
  // If first is false, second should not matter
  let result = false and true
  assert_eq(result, false)
}

test "short-circuit or" {
  // If first is true, second should not matter
  let result = true or false
  assert_eq(result, true)
}

// ── String concatenation ──

test "string concat" {
  assert_eq("hello" ++ " " ++ "world", "hello world")
  assert_eq("" ++ "a", "a")
  assert_eq("a" ++ "", "a")
}

// ── List concatenation ──

test "list concat" {
  assert_eq([1, 2] ++ [3, 4], [1, 2, 3, 4])
  let empty: List[Int] = []
  assert_eq(empty ++ [1], [1])
  assert_eq([1] ++ empty, [1])
}

// ── Parenthesized grouping ──

test "parenthesized expressions" {
  assert_eq((1 + 2) * 3, 9)
  assert_eq(2 * (3 + 4), 14)
  assert_eq((10 - 5) * (2 + 1), 15)
}

// ── Equality on collections ──

test "list equality" {
  assert_eq([1, 2, 3] == [1, 2, 3], true)
  assert_eq([1, 2] == [1, 3], false)
  let empty1: List[Int] = []
  let empty2: List[Int] = []
  assert_eq(empty1 == empty2, true)
}

test "record equality" {
  assert_eq({ x: 1, y: 2 } == { x: 1, y: 2 }, true)
  assert_eq({ x: 1, y: 2 } != { x: 1, y: 3 }, true)
}
