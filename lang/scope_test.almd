// scope_test — Scoping rules

// ── Block scope ──

test "block scope isolates variables" {
  let x = 1
  let y = {
    let x = 99
    x + 1
  }
  assert_eq(x, 1)
  assert_eq(y, 100)
}

test "nested block scope" {
  let a = 10
  let b = {
    let c = {
      a + 5
    }
    c * 2
  }
  assert_eq(b, 30)
}

// ── Let shadowing ──

test "let shadowing same scope" {
  let x = 1
  let x = x + 10
  let x = x * 2
  assert_eq(x, 22)
}

test "let shadowing different type" {
  let x = 42
  let x = "now a string"
  assert_eq(x, "now a string")
}

// ── For loop variable scope ──

test "for loop variable does not leak" {
  var total = 0
  for x in [1, 2, 3] {
    total = total + x
  }
  // x is not accessible here
  assert_eq(total, 6)
}

test "for loop variable shadows outer" {
  let x = 999
  var sum = 0
  for x in [10, 20, 30] {
    sum = sum + x
  }
  assert_eq(x, 999)
  assert_eq(sum, 60)
}

// ── Match arm binding scope ──

test "match binding scoped to arm" {
  let val = some(42)
  let result = match val {
    some(n) => n + 1,
    none => 0,
  }
  assert_eq(result, 43)
}

test "match binding does not leak" {
  let x = "outer"
  let _ = match some(10) {
    some(x) => x * 2,
    none => 0,
  }
  assert_eq(x, "outer")
}

// ── Closure captures ──

fn make_counter(start: Int) -> fn(Int) -> Int = {
  fn(step) => start + step
}

test "closure captures value at definition" {
  let counter = make_counter(100)
  assert_eq(counter(1), 101)
  assert_eq(counter(5), 105)
}

test "closure captures multiple values" {
  let a = 10
  let b = 20
  let f = fn(x: Int) => a + b + x
  assert_eq(f(3), 33)
}

test "nested closure" {
  let base = 5
  let outer = fn(x: Int) => {
    let inner = fn(y: Int) => base + x + y
    inner(1)
  }
  assert_eq(outer(10), 16)
}
