// control_flow_test — Control flow constructs

// ── if/then/else ──

test "if then else returns value" {
  let x = if true then 1 else 2
  assert_eq(x, 1)
  let y = if false then 1 else 2
  assert_eq(y, 2)
}

test "if with comparison" {
  let x = 10
  let result = if x > 5 then "big" else "small"
  assert_eq(result, "big")
}

test "nested if" {
  let x = 5
  let result = if x > 10 then "large"
    else if x > 3 then "medium"
    else "small"
  assert_eq(result, "medium")
}

test "if with block body" {
  let result = if true then {
    let a = 1
    let b = 2
    a + b
  } else {
    0
  }
  assert_eq(result, 3)
}

// ── match ──

test "match int literal" {
  let x = 2
  let result = match x {
    1 => "one",
    2 => "two",
    3 => "three",
    _ => "other",
  }
  assert_eq(result, "two")
}

test "match string literal" {
  let cmd = "run"
  let result = match cmd {
    "run" => 1,
    "build" => 2,
    _ => 0,
  }
  assert_eq(result, 1)
}

test "match bool" {
  let flag = true
  let result = match flag {
    true => "yes",
    false => "no",
  }
  assert_eq(result, "yes")
}

test "match Option some" {
  let x = some(42)
  let result = match x {
    some(v) => v,
    none => 0,
  }
  assert_eq(result, 42)
}

test "match Option none" {
  let x: Option[Int] = none
  let result = match x {
    some(v) => v,
    none => -1,
  }
  assert_eq(result, -1)
}

test "match Result" {
  let x: Result[Int, String] = ok(10)
  let r1 = match x {
    ok(v) => v,
    err(_e) => 0,
  }
  assert_eq(r1, 10)

  let y: Result[Int, String] = err("fail")
  let r2 = match y {
    ok(v) => v,
    err(_e) => -1,
  }
  assert_eq(r2, -1)
}

test "match wildcard" {
  let x = 99
  let result = match x {
    1 => "one",
    _ => "other",
  }
  assert_eq(result, "other")
}

test "match with guard" {
  let x = 15
  let result = match x {
    n if n > 10 => "big",
    n if n > 5 => "medium",
    _ => "small",
  }
  assert_eq(result, "big")
}

// ── for...in ──

test "for in list" {
  var sum = 0
  for x in [1, 2, 3, 4, 5] {
    sum = sum + x
  }
  assert_eq(sum, 15)
}

test "for in range" {
  var sum = 0
  for i in 0..5 {
    sum = sum + i
  }
  assert_eq(sum, 10)
}

test "for in inclusive range" {
  var sum = 0
  for i in 1..=5 {
    sum = sum + i
  }
  assert_eq(sum, 15)
}

test "for with var accumulation" {
  var result = ""
  for x in ["a", "b", "c"] {
    result = result ++ x
  }
  assert_eq(result, "abc")
}

test "for with enumerate" {
  var sum = 0
  for (i, _v) in list.enumerate([10, 20, 30]) {
    sum = sum + i
  }
  assert_eq(sum, 3)
}

test "for with zip" {
  var result: List[String] = []
  for (a, b) in list.zip(["x", "y"], [1, 2]) {
    result = result ++ ["${a}${int.to_string(b)}"]
  }
  assert_eq(result, ["x1", "y2"])
}

test "nested for" {
  var sum = 0
  for i in 0..3 {
    for j in 0..3 {
      sum = sum + 1
    }
  }
  assert_eq(sum, 9)
}

// ── do block with guard ──

test "do guard loop" {
  var count = 0
  do {
    guard count < 5 else ok(())
    count = count + 1
  }
  assert_eq(count, 5)
}

test "do guard with accumulation" {
  var xs = [1, 2, 3, 4, 5]
  var sum = 0
  var i = 0
  do {
    guard i < list.len(xs) else ok(())
    let v = match list.get(xs, i) {
      some(x) => x,
      none => 0,
    }
    sum = sum + v
    i = i + 1
  }
  assert_eq(sum, 15)
}

// ── do block with guard else break/continue ──

test "do guard else break" {
  var count = 0
  do {
    guard count < 5 else break
    count = count + 1
  }
  assert_eq(count, 5)
}

test "do guard else break with accumulation" {
  var i = 0
  var sum = 0
  do {
    guard i < 10 else break
    sum = sum + i
    i = i + 1
  }
  assert_eq(sum, 45)
}

test "for guard else continue" {
  var result = ""
  for ch in ["a", " ", "b", " ", "c"] {
    guard ch != " " else continue
    result = result ++ ch
  }
  assert_eq(result, "abc")
}

test "for guard else break" {
  var result = ""
  for ch in ["a", "b", "!", "c", "d"] {
    guard ch != "!" else break
    result = result ++ ch
  }
  assert_eq(result, "ab")
}
