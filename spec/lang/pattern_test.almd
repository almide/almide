
// pattern_test — Pattern matching
// ── Literal patterns ──
test "match int literal" {
  let x = 2;
  let result = match x {
    1 => "one",
    2 => "two",
    3 => "three",
    _ => "other",
  };
  assert_eq(result, "two")
}

test "match string literal" {
  let s = "hello";
  let result = match s {
    "hello" => 1,
    "world" => 2,
    _ => 0,
  };
  assert_eq(result, 1)
}

test "match bool literal" {
  let b = false;
  let result = match b {
    true => "yes",
    false => "no",
  };
  assert_eq(result, "no")
}

// ── Identifier pattern (binding) ──
test "match identifier binding" {
  let x = 42;
  let result = match x {
    n => n + 1
  };
  assert_eq(result, 43)
}

// ── Wildcard ──
test "match wildcard" {
  let x = 99;
  let result = match x {
    1 => "one",
    _ => "other",
  };
  assert_eq(result, "other")
}

// ── Option patterns ──
test "match some" {
  let x = some(10);
  let result = match x {
    some(v) => v * 2,
    none => 0,
  };
  assert_eq(result, 20)
}

test "match none" {
  let x: Option[Int] = none;
  let result = match x {
    some(v) => v,
    none => -1,
  };
  assert_eq(result, -1)
}

// ── Result patterns ──
test "match ok" {
  let x: Result[Int, String] = ok(42);
  let result = match x {
    ok(v) => v,
    err(_e) => 0,
  };
  assert_eq(result, 42)
}

test "match err" {
  let x: Result[Int, String] = err("bad");
  let result = match x {
    ok(_v) => "",
    err(e) => e,
  };
  assert_eq(result, "bad")
}

// ── Constructor patterns (user-defined variants) ──
type Shape = | Circle(Float) | Rect(Float, Float) | Point

fn describe(s: Shape) -> String = match s {
  Circle(r) => "circle r=${float.to_string(r)}",
  Rect(w, h) => "rect ${float.to_string(w)}x${float.to_string(h)}",
  Point => "point",
}

test "match constructor with payload" {
  assert_eq(describe(Circle(1.0)), "circle r=1.0");
  assert_eq(describe(Rect(3.0, 4.0)), "rect 3.0x4.0")
}

test "match constructor zero-arg" {
  assert_eq(describe(Point), "point")
}

// ── Tuple patterns ──
test "match tuple" {
  let p = (1, 2);
  let result = match p {
    (a, b) => a + b
  };
  assert_eq(result, 3)
}

test "match tuple three elements" {
  let t = ("x", 10, true);
  let result = match t {
    (s, n, _b) => "${s}=${int.to_string(n)}"
  };
  assert_eq(result, "x=10")
}

// ── Nested patterns ──
test "nested some tuple" {
  let x = some((1, 2));
  let result = match x {
    some((a, b)) => a + b,
    none => 0,
  };
  assert_eq(result, 3)
}

test "nested constructor in option" {
  let x = some(Circle(5.0));
  let result = match x {
    some(Circle(r)) => r,
    some(_) => 0.0,
    none => 0.0,
  };
  assert_eq(result, 5.0)
}

// ── Guard conditions ──
test "match with guard" {
  let x = 15;
  let result = match x {
    n if n > 100 => "huge",
    n if n > 10 => "big",
    n if n > 0 => "small",
    _ => "zero or negative",
  };
  assert_eq(result, "big")
}

test "match guard with binding" {
  let x = some(5);
  let result = match x {
    some(n) if n > 10 => "big",
    some(n) if n > 0 => "small ${int.to_string(n)}",
    some(_) => "zero or negative",
    none => "nothing",
  };
  assert_eq(result, "small 5")
}

// ── Record patterns ──
test "match record pattern" {
  let user = { name: "alice", age: 30 };
  let { name, age } = user;
  assert_eq(name, "alice");
  assert_eq(age, 30)
}

// ── Additional pattern tests ──
test "nested option pattern" {
  let x = some(some(99));
  let result = match x {
    some(some(v)) => v,
    some(none) => -1,
    none => -2,
  };
  assert_eq(result, 99)
}

test "nested result in option" {
  let x: Option[Result[Int, String]] = some(ok(42));
  let result = match x {
    some(ok(v)) => v,
    some(err(_)) => -1,
    none => -2,
  };
  assert_eq(result, 42)
}

test "pattern on variant with multiple constructors" {
  let shapes = [Circle(1.0), Rect(2.0, 3.0), Point, Circle(5.0)];
  var circles = 0;
  for s in shapes {
    let is_circle = match s {
      Circle(_) => true,
      _ => false,
    };
    if is_circle then {
      circles = circles + 1;
    } else { () };
  };
  assert_eq(circles, 2)
}

test "wildcard in various positions" {
  let t = (1, "hello", true);
  let result = match t {
    (_, s, _) => s
  };
  assert_eq(result, "hello")
}

test "match with guard on variant" {
  let s = Circle(10.0);
  let result = match s {
    Circle(r) if r > 5.0 => "big circle",
    Circle(_) => "small circle",
    _ => "not circle",
  };
  assert_eq(result, "big circle")
}

test "match guard falls through" {
  let s = Circle(2.0);
  let result = match s {
    Circle(r) if r > 5.0 => "big",
    Circle(r) if r > 0.0 => "small",
    Circle(_) => "zero",
    _ => "other",
  };
  assert_eq(result, "small")
}

test "match returns option" {
  let x = 5;
  let result: Option[String] = match x {
    1 => some("one"),
    5 => some("five"),
    _ => none,
  };
  assert_eq(result, some("five"))
}

test "pattern on result ok variant" {
  let r: Result[String, String] = ok("success");
  let msg = match r {
    ok(s) => "got: " + s,
    err(e) => "err: " + e,
  };
  assert_eq(msg, "got: success")
}

test "match with binding and computation" {
  let x = some(10);
  let result = match x {
    some(n) => {
      let squared = n * n;
      let doubled = squared * 2;
      doubled
    },
    none => 0,
  };
  assert_eq(result, 200)
}

test "tuple pattern four elements" {
  let t = (1, 2, 3, 4);
  let result = match t {
    (a, b, c, d) => a + b + c + d
  };
  assert_eq(result, 10)
}

test "match int negative" {
  let x = -1;
  let result = match x {
    0 => "zero",
    _ => "nonzero",
  };
  assert_eq(result, "nonzero")
}

test "match on computed value" {
  let xs = [1, 2, 3];
  let result = match list.len(xs) {
    0 => "empty",
    1 => "one",
    _ => "many",
  };
  assert_eq(result, "many")
}

test "nested tuple in option" {
  let x = some((10, 20, 30));
  let result = match x {
    some((a, b, c)) => a + b + c,
    none => 0,
  };
  assert_eq(result, 60)
}

test "match guard with string operation" {
  let s = "hello world";
  let result = match s {
    x if string.len(x) > 10 => "long",
    x if string.len(x) > 5 => "medium",
    _ => "short",
  };
  assert_eq(result, "long")
}

test "pattern with record spread destructure" {
  let config = { host: "localhost", port: 8080, debug: true };
  let { host, port, debug } = config;
  assert_eq(host, "localhost");
  assert_eq(port, 8080);
  assert_eq(debug, true)
}
