
// do_guard_test — do block and guard statement edge cases
test "do block with guard break" {
  var i = 0;
  while i < 5 {
    i = i + 1;
  };
  assert_eq(i, 5)
}

test "do block single iteration" {
  var count = 0;
  while true {
    count = count + 1;
    if not (false) then break else ();
  };
  assert_eq(count, 1)
}

test "do block accumulator" {
  var sum = 0;
  var i = 1;
  while i <= 10 {
    sum = sum + i;
    i = i + 1;
  };
  assert_eq(sum, 55)
}

test "do block with complex guard" {
  var x = 0;
  while true {
    x = x + 1;
    if not (x < 100 and x % 7 != 0) then break else ();
  };
  assert_eq(x, 7)
}

test "do block string building" {
  var s = "";
  var i = 0;
  while i < 4 {
    s = s + int.to_string(i);
    i = i + 1;
  };
  assert_eq(s, "0123")
}

test "nested do blocks" {
  var total = 0;
  var i = 0;
  while i < 3 {
    var j = 0;
    while j < 3 {
      total = total + 1;
      j = j + 1;
    };
    i = i + 1;
  };
  assert_eq(total, 9)
}

test "guard with continue in for" {
  var sum = 0;
  for i in 0..10 {
    guard i % 2 == 0 else continue;
    sum = sum + i;
  };
  assert_eq(sum, 20)
}

test "do block never enters on false guard" {
  var count = 0;
  while false {
    count = count + 1;
  };
  assert_eq(count, 0)
}

test "guard in while" {
  var result: List[Int] = [];
  var i = 0;
  while i < 10 {
    i = i + 1;
    guard i % 3 == 0 else continue;
    result = result + [i];
  };
  assert_eq(result, [3, 6, 9])
}
