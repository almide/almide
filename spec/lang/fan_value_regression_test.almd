// Value-asserting regression tests for the fan.* cross-target bugs.
// The original fan specs only checked lengths / race winners, so corrupt
// settled payloads, dropped/invalid fan.any results, and mis-typed
// fan.timeout Results all slipped through. These lock in the actual values.

effect fn succeed(x: Int) -> Result[Int, String] = ok(x)
effect fn fail_with(msg: String) -> Result[Int, String] = err(msg)
effect fn pick(s: String) -> Result[String, String] = ok(s)

// ── fan.settle — every settled payload must survive (was zeroed/corrupt) ──
test "fan.settle preserves ok and err payloads" {
  let rs = fan.settle([
    () => succeed(11),
    () => fail_with("boom"),
    () => succeed(33)
  ]);
  assert_eq(list.len(rs), 3)
  assert_eq(rs[0], ok(11))
  assert_eq(rs[1], err("boom"))
  assert_eq(rs[2], ok(33))
}

// ── fan.any returning Int — must produce a valid module + correct value ──
test "fan.any returns the Int winner" {
  let w = fan.any([() => succeed(5)]);
  assert_eq(w, 5)
}

// ── fan.any returning String — must not silently drop the winner ──
test "fan.any returns the String winner" {
  let w = fan.any([() => pick("alpha"), () => pick("beta")]);
  assert_eq(w, "alpha")
}

// ── fan.timeout Result bound to a Result let — ?? and == must type-check ──
test "fan.timeout result supports ?? and ==" {
  let r: Result[Int, String] = fan.timeout(5000, () => succeed(42));
  assert_eq(r ?? -1, 42)
  assert(r == ok(42))
}
