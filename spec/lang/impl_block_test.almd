
// impl_block_test — impl Protocol for Type { ... } block syntax
// ── Basic impl block ──
protocol Showable {
  fn show(a: Self) -> String
}

type Dog = { name: String }

impl Showable for Dog {
  fn show(d: Dog) -> String = "Dog: " + d.name
}

test "basic impl block" {
  let d = Dog { name: "Rex" };
  assert_eq(d.show(), "Dog: Rex")
}

// ── impl block with multiple methods ──
protocol Describable {
  fn label(a: Self) -> String
  fn detail(a: Self) -> String
}

type Book = { title: String, author: String }

impl Describable for Book {
  fn label(b: Book) -> String = b.title
  fn detail(b: Book) -> String = b.title + " by " + b.author
}

test "impl block with multiple methods" {
  let b = Book { title: "1984", author: "Orwell" };
  assert_eq(b.label(), "1984");
  assert_eq(b.detail(), "1984 by Orwell")
}

// ── impl block used in generic function ──
fn display[T: Showable](item: T) -> String = item.show()

type Cat = { name: String }

impl Showable for Cat {
  fn show(c: Cat) -> String = "Cat: " + c.name
}

test "impl block with generic bounds" {
  assert_eq(display(Dog { name: "Max" }), "Dog: Max");
  assert_eq(display(Cat { name: "Mimi" }), "Cat: Mimi")
}

// ── impl block with Self in return type ──
protocol Combinable {
  fn combine(a: Self, b: Self) -> Self
}

type Score = { points: Int }

impl Combinable for Score {
  fn combine(a: Score, b: Score) -> Score = Score { points: a.points + b.points }
}

test "impl block with Self in multiple positions" {
  let a = Score { points: 10 };
  let b = Score { points: 20 };
  let c = Score.combine(a, b);
  assert_eq(c.points, 30)
}

// ── impl block on variant type ──
protocol Printable {
  fn to_str(a: Self) -> String
}

type Status = | Active | Inactive | Pending(String)

impl Printable for Status {
  fn to_str(s: Status) -> String = match s {
    Active => "active",
    Inactive => "inactive",
    Pending(reason) => "pending: " + reason,
  }
}

test "impl block on variant type" {
  assert_eq(Active.to_str(), "active");
  assert_eq(Pending("review").to_str(), "pending: review")
}

// ── impl block coexisting with built-in conventions ──
protocol Labelable {
  fn label_text(a: Self) -> String
}

type Tag: Eq = { key: String, value: String }

impl Labelable for Tag {
  fn label_text(t: Tag) -> String = t.key + "=" + t.value
}

test "impl block with built-in derive" {
  let a = Tag { key: "env", value: "prod" };
  let b = Tag { key: "env", value: "prod" };
  assert_eq(a == b, true);
  assert_eq(a.label_text(), "env=prod")
}

// ── Multiple impl blocks for same type ──
protocol HasName {
  fn get_name(a: Self) -> String
}

protocol HasAge {
  fn get_age(a: Self) -> Int
}

type Employee = { emp_name: String, emp_age: Int }

impl HasName for Employee {
  fn get_name(e: Employee) -> String = e.emp_name
}

impl HasAge for Employee {
  fn get_age(e: Employee) -> Int = e.emp_age
}

test "multiple impl blocks for one type" {
  let e = Employee { emp_name: "Bob", emp_age: 25 };
  assert_eq(e.get_name(), "Bob");
  assert_eq(e.get_age(), 25)
}

// ── impl block method called as Type.method ──
test "impl method via Type.method syntax" {
  let d = Dog { name: "Buddy" };
  assert_eq(Dog.show(d), "Dog: Buddy")
}

// ── impl block with non-Self params ──
protocol Searchable {
  fn contains_text(a: Self, query: String) -> Bool
}

type Document = { title: String, body: String }

impl Searchable for Document {
  fn contains_text(d: Document, query: String) -> Bool = string.contains(d.body, query)
}

test "impl block with mixed Self and non-Self params" {
  let doc = Document { title: "readme", body: "hello world" };
  assert_eq(doc.contains_text("world"), true);
  assert_eq(doc.contains_text("missing"), false)
}
