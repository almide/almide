// string_interp_test — String interpolation edge cases

// ── Basic interpolation ──

test "interp simple variable" {
  let name = "world"
  assert_eq("hello ${name}", "hello world")
}

test "interp int auto-conversion" {
  let n = 42
  assert_eq("answer: ${n}", "answer: 42")
}

// ── Interpolation with math expressions ──

test "interp with addition" {
  let a = 3
  let b = 4
  assert_eq("sum: ${a + b}", "sum: 7")
}

test "interp with multiplication" {
  let x = 5
  assert_eq("doubled: ${x * 2}", "doubled: 10")
}

// ── Field access in interpolation ──

test "interp field access" {
  let p = { x: 10, y: 20 }
  assert_eq("x=${p.x}, y=${p.y}", "x=10, y=20")
}

test "interp nested field" {
  let data = { inner: { value: 99 } }
  assert_eq("v=${data.inner.value}", "v=99")
}

// ── Function call in interpolation ──

test "interp function call" {
  assert_eq("len=${string.len("hello")}", "len=5")
}

test "interp stdlib call" {
  let xs = [1, 2, 3]
  assert_eq("count=${list.len(xs)}", "count=3")
}

// ── Conditional in interpolation ──

test "interp if-then-else" {
  let x = 10
  let s = "sign: ${if x > 0 then "positive" else "negative"}"
  assert_eq(s, "sign: positive")
}

test "interp if-then-else false branch" {
  let x = -5
  let s = "sign: ${if x > 0 then "positive" else "negative"}"
  assert_eq(s, "sign: negative")
}

// ── Multiple interpolations ──

test "interp multiple in one string" {
  let a = 1
  let b = 2
  let c = 3
  assert_eq("${a}-${b}-${c}", "1-2-3")
}

test "interp adjacent" {
  let x = "ab"
  let y = "cd"
  assert_eq("${x}${y}", "abcd")
}

// ── Empty and trivial interpolation ──

test "interp empty string" {
  let s = ""
  assert_eq("before${s}after", "beforeafter")
}

test "interp string-only" {
  let s = "hello"
  assert_eq("${s}", "hello")
}

// ── Interpolation with complex expressions ──

test "interp with block expression" {
  let s = "result: ${int.to_string({ let x = 10; x * 3 })}"
  assert_eq(s, "result: 30")
}
