
module syntax_test

fn main() -> Unit = {
  let x = 42;
  let path = "C:\\Users\\test\\file.txt";
  let regex = "^\\d{3}-\\d{4}$";
  println(path);
  println(regex)
}

test "raw strings" {
  let s = "hello\\nworld";
  assert_eq(s, "hello\\nworld")
}

test "block comments" {
  let x = 1 + 3;
  assert_eq(x, 4)
}
