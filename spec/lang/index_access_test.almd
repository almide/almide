import bytes

test "list index read" {
  let xs = [10, 20, 30]
  assert_eq(xs[0], 10)
  assert_eq(xs[1], 20)
  assert_eq(xs[2], 30)
}

test "list index write" {
  var xs = [10, 20, 30]
  xs[1] = 99
  assert_eq(xs[1], 99)
  assert_eq(xs[0], 10)
  assert_eq(xs[2], 30)
}

test "bytes index read" {
  var buf: Bytes = bytes.from_list([0xAA, 0xBB, 0xCC])
  assert_eq(buf[0], 0xAA)
  assert_eq(buf[1], 0xBB)
  assert_eq(buf[2], 0xCC)
}

test "bytes index write" {
  var buf: Bytes = bytes.new(4)
  buf[0] = 0xFF
  buf[2] = 0x42
  assert_eq(buf[0], 0xFF)
  assert_eq(buf[1], 0)
  assert_eq(buf[2], 0x42)
  assert_eq(buf[3], 0)
}

test "bytes read-write same buffer" {
  var buf: Bytes = bytes.from_list([10, 20, 30, 40])
  buf[0] = buf[2]
  assert_eq(buf[0], 30)
}

test "bytes index in expression" {
  var buf: Bytes = bytes.from_list([3, 7])
  let sum = buf[0] + buf[1]
  assert_eq(sum, 10)
}

test "bytes range slice" {
  var buf: Bytes = bytes.from_list([10, 20, 30, 40, 50])
  let sub = buf[1..3]
  assert_eq(bytes.len(sub), 2)
  assert_eq(sub[0], 20)
  assert_eq(sub[1], 30)
}

test "bytes range inclusive" {
  var buf: Bytes = bytes.from_list([10, 20, 30, 40, 50])
  let sub = buf[1..=3]
  assert_eq(bytes.len(sub), 3)
  assert_eq(sub[0], 20)
  assert_eq(sub[2], 40)
}

test "list range slice" {
  let xs = [10, 20, 30, 40, 50]
  let sub = xs[1..4]
  assert_eq(list.len(sub), 3)
  assert_eq(sub[0], 20)
  assert_eq(sub[2], 40)
}

test "list range inclusive" {
  let xs = [10, 20, 30, 40, 50]
  let sub = xs[0..=2]
  assert_eq(list.len(sub), 3)
  assert_eq(sub[0], 10)
  assert_eq(sub[2], 30)
}

test "list index write loop" {
  var xs = [0, 0, 0, 0, 0]
  var i = 0
  while i < 5 {
    xs[i] = i * i
    i = i + 1
  }
  assert_eq(xs[0], 0)
  assert_eq(xs[1], 1)
  assert_eq(xs[2], 4)
  assert_eq(xs[3], 9)
  assert_eq(xs[4], 16)
}
