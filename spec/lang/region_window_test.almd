// Region-specialized allocation (region_alloc.rs, issue #838): the
// `consume(produce(scalars))` window becomes a bump region on the wasm leg.
// These tests pin the OBSERVABLE behavior (values identical whether or not
// the rewrite fires) across the shapes the analysis must distinguish.

type Tree = Leaf | Node(Tree, Tree)

fn make(depth: Int) -> Tree =
  if depth == 0 then Leaf
  else Node(make(depth - 1), make(depth - 1))

fn check(tree: Tree) -> Int = match tree {
  Leaf => 1,
  Node(left, right) => check(left) + check(right) + 1,
}

// The window shape: produce → consume → drop, repeated in a loop (the region
// resets between iterations; every tree must count the same).
fn sum_checks(n: Int, depth: Int) -> Int = {
  var total = 0
  for _ in 0..n {
    total = total + check(make(depth))
  }
  total
}

// The NON-window shape: the produced tree is held in a binding that outlives
// the consumer — the rewrite must not fire, and the value must still be
// readable afterwards.
fn held_tree(depth: Int) -> Int = {
  let t = make(depth)
  let first = check(t)
  let second = check(t)
  first + second
}

test "region window: repeated produce/consume counts every node" {
  assert_eq(sum_checks(4, 5), 4 * 63)
  assert_eq(sum_checks(1, 0), 1)
}

test "region window: consumer result feeds arithmetic between call and drop" {
  var acc = 100
  acc = acc + check(make(3))
  assert_eq(acc, 115)
}

test "held tree (no window): the value survives multiple consumers" {
  assert_eq(held_tree(4), 62)
}

test "windows interleave with unrelated heap use" {
  var xs: List[Int] = []
  var total = 0
  for i in 0..3 {
    total = total + check(make(2))
    list.push(xs, i * 10)
  }
  assert_eq(total, 21)
  assert_eq(list.len(xs), 3)
  assert_eq(xs[2], 20)
}

// --- Compact layout (region_compact.rs, #838 stage 2) ---------------------

// A SCALAR field between the tag and the handle fields: the compact layout
// packs it as a raw 8-byte slot ahead of the 4-byte child pointers, so this
// exercises RegionStoreS/RegionLoadS and the mixed-offset computation.
type Weighted = Tip | Nd(Int, Weighted, Weighted)

fn make_w(depth: Int) -> Weighted =
  if depth == 0 then Tip
  else Nd(depth, make_w(depth - 1), make_w(depth - 1))

fn sum_w(t: Weighted) -> Int = match t {
  Tip => 0,
  Nd(x, l, r) => x + sum_w(l) + sum_w(r),
}

test "region compact: scalar field packs next to handle fields" {
  var total = 0
  for _ in 0..3 {
    total = total + sum_w(make_w(3))
  }
  assert_eq(total, 3 * 11)
}

// TWO nullary constructors: two per-region singletons, so the tag read
// becomes a chained RegionTagSel — each singleton must keep its own tag.
type Tri = Aa | Bb | Nn(Tri, Tri)

fn make_t(d: Int) -> Tri =
  if d == 0 then Aa
  else if d == 1 then Bb
  else Nn(make_t(d - 1), make_t(d - 2))

fn count_t(t: Tri) -> Int = match t {
  Aa => 1,
  Bb => 2,
  Nn(l, r) => count_t(l) + count_t(r),
}

test "region compact: two singletons chain the tag select" {
  var total = 0
  for _ in 0..3 {
    total = total + count_t(make_t(6))
  }
  assert_eq(total, 3 * 21)
}

// A FLOAT payload rides the compact scalar slot as raw bits (poisoned to the
// i64-uniform repr, stored/loaded via RegionStoreS/RegionLoadS) — the sums
// below are dyadic rationals, so equality is exact on both targets.
type FTree = FLeaf | FNode(Float, FTree, FTree)

fn make_f(depth: Int, x: Float) -> FTree =
  if depth == 0 then FLeaf
  else FNode(x, make_f(depth - 1, x + 0.25), make_f(depth - 1, x + 0.25))

fn sum_f(t: FTree) -> Float = match t {
  FLeaf => 0.0,
  FNode(x, l, r) => x + sum_f(l) + sum_f(r),
}

test "region compact: float payload is bit-exact through the packed slot" {
  var total = 0.0
  for _ in 0..2 {
    total = total + sum_f(make_f(3, 1.5))
  }
  // S(d,x) = x + 2*S(d-1, x+0.25); S(3, 1.5) = 13.0
  assert_eq(total, 26.0)
}

// The region must SURVIVE a memory.grow at the frontier: one window big
// enough that the (inlined) bump+grow tail actually grows linear memory
// mid-region, then keeps allocating past the old boundary.
test "region window: frontier grow inside one region" {
  assert_eq(check(make(19)), 1048575)
}

// Free-list integrity across windows: the churn list dies each iteration
// (its block enters the free-list), the next window EMPTIES the free-list on
// entry and RESTORES it on exit — the churn list must keep reusing its block
// and every tree must still count the same.
test "region windows interleave with free-list churn" {
  var total = 0
  for i in 0..50 {
    var xs: List[Int] = []
    for j in 0..20 {
      list.push(xs, i + j)
    }
    total = total + check(make(6)) + xs[19]
  }
  assert_eq(total, 50 * 127 + 2175)
}
