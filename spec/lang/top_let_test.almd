
let PI = 3.141592653589793

let SOLAR_MASS = 4.0 * PI * PI

let DAYS_PER_YEAR = 365.24

let MAX_COUNT = 100

let IS_DEBUG = false

fn main() -> Unit = {
  println("PI = ${PI}");
  println("SOLAR_MASS = ${SOLAR_MASS}");
  println("DAYS_PER_YEAR = ${DAYS_PER_YEAR}");
  println("MAX_COUNT = ${MAX_COUNT}");
  println("IS_DEBUG = ${IS_DEBUG}")
}

test "top-level let numeric" {
  assert_eq(MAX_COUNT, 100);
  assert_eq(DAYS_PER_YEAR, 365.24)
}

test "top-level let cross-reference" {
  let expected = 4.0 * 3.141592653589793 * 3.141592653589793;
  assert_eq(SOLAR_MASS, expected)
}

test "top-level let bool" {
  assert_eq(IS_DEBUG, false)
}

test "top-level let usage in expressions" {
  let half_mass = SOLAR_MASS / 2.0;
  let x = MAX_COUNT + 1;
  assert_eq(x, 101)
}

// ── Additional top-level let tests ──

let DOUBLE_MAX = MAX_COUNT * 2

let HALF_COUNT = MAX_COUNT / 2

test "top-level let computed from other top-level" {
  assert_eq(DOUBLE_MAX, 200)
}

test "top-level let integer division" {
  assert_eq(HALF_COUNT, 50)
}

fn uses_top_level() -> Int = MAX_COUNT + 10

test "top-level let used in function" {
  assert_eq(uses_top_level(), 110)
}

let ZERO = 0

test "top-level zero" {
  assert_eq(ZERO, 0)
  assert_eq(ZERO + 1, 1)
}

test "top-level let in arithmetic" {
  let result = MAX_COUNT * 2 + 50
  assert_eq(result, 250)
}

test "top-level let in conditional" {
  let label = if IS_DEBUG then "debug" else "release"
  assert_eq(label, "release")
}

test "top-level let in match" {
  let result = match MAX_COUNT {
    100 => "century",
    _ => "other",
  }
  assert_eq(result, "century")
}

test "top-level let in comparison" {
  assert_eq(MAX_COUNT > 50, true)
  assert_eq(MAX_COUNT < 200, true)
  assert_eq(ZERO == 0, true)
}
