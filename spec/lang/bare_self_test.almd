// bare_self_test — `self` as a bare, untyped first parameter (#828)
// ── Plain convention method, no protocol involved ──
type User = { name: String }

fn User.greet(self) -> String = "hi " + self.name

test "bare self on a plain convention method" {
  let u = User { name: "alice" };
  assert_eq(u.greet(), "hi alice")
}

// ── Protocol method satisfied with bare self ──
protocol Showable {
  fn show(self) -> String
}

type Point: Showable = { x: Int, y: Int }

fn Point.show(self) -> String = "(" + int.to_string(self.x) + ", " + int.to_string(self.y) + ")"

fn display[T: Showable](item: T) -> String = item.show()

test "bare self on a protocol-satisfying method" {
  let p = Point { x: 1, y: 2 };
  assert_eq(display(p), "(1, 2)")
}

// ── Multiple methods with bare self, chained via UFCS ──
type Counter = { n: Int }

fn Counter.inc(self) -> Counter = Counter { n: self.n + 1 }
fn Counter.value(self) -> Int = self.n

test "bare self chained across multiple methods" {
  let c = Counter { n: 0 };
  assert_eq(c.inc().inc().inc().value(), 3)
}

// ── Bare self alongside non-self params ──
type Document = { title: String, body: String }

fn Document.contains_text(self, query: String) -> Bool = string.contains(self.body, query)

test "bare self with additional non-self params" {
  let doc = Document { title: "readme", body: "hello world" };
  assert_eq(doc.contains_text("world"), true);
  assert_eq(doc.contains_text("missing"), false)
}
