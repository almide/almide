// Heap index whose CONTAINER is itself a heap field of a materialized aggregate
// (`node.children[item.idx]` — the ceangal layout class): the element borrow must
// chain through the field borrow, and per-element record reads must see the
// element's slots inside a real for-in loop.

type Color = { r: Float, a: Float }
type Item = { idx: Int, basis: Float }
type Child = { grow: Float, shrink: Float }
type Node = { children: List[Child], gap: Float }
type Line = { items: List[Item], used: Float }

fn pass1(node: Node, line: Line) -> Float = {
  var tg = 0.0
  var tss = 0.0
  for item in line.items {
    let child = node.children[item.idx]
    tg = tg + child.grow
    tss = tss + child.shrink * item.basis
  }
  tg + tss
}

test "member-container index borrow in for-in" {
  let n = { children: [{ grow: 1.0, shrink: 0.5 }, { grow: 2.0, shrink: 1.0 }], gap: 4.0 }
  let ln = { items: [{ idx: 0, basis: 2.0 }, { idx: 1, basis: 3.0 }], used: 0.0 }
  assert(pass1(n, ln) == 7.0)
}

test "member-container index borrow direct" {
  let n = { children: [{ grow: 5.0, shrink: 0.0 }], gap: 0.0 }
  assert(n.children[0].grow == 5.0)
}

fn pass2(node: Node, line: Line, n: Int) -> Float = {
  var t = 0.0
  for ii in 0..n {
    let child = node.children[line.items[ii].idx]
    t = t + child.grow * line.items[ii].basis
  }
  t
}

test "chained index-member scalar reads" {
  let nd = { children: [{ grow: 2.0, shrink: 0.0 }, { grow: 5.0, shrink: 0.0 }], gap: 0.0 }
  let ln = { items: [{ idx: 1, basis: 3.0 }, { idx: 0, basis: 4.0 }], used: 0.0 }
  assert(pass2(nd, ln, 2) == 23.0)
}

fn sum_items(line: Line, n: Int) -> Float = {
  var t = 0.0
  for ii in 0..n {
    t = t + line.items[ii].basis
  }
  t
}

test "scalar index through a member-field list" {
  let ln = { items: [{ idx: 0, basis: 1.5 }, { idx: 1, basis: 2.5 }], used: 0.0 }
  assert(sum_items(ln, 2) == 4.0)
}

fn rebind_read(n: Int) -> Float = {
  var a: List[Float] = []
  for i in 0..n { a = a + [int.to_float(i) + 1.0] }
  var b: List[Float] = []
  for i in 0..n { b = b + [a[i] * 3.0] }
  a = b
  var t = 0.0
  for i in 0..n { t = t + a[i] }
  t
}

test "rebound heap local keeps its list registrations" {
  assert(rebind_read(3) == 18.0)
}

fn take_color(c: Color) -> Float = c.r + c.a

test "cross-module-style record global passing" {
  let col = { r: 0.5, a: 1.0 }
  assert(take_color(col) == 1.5)
}
