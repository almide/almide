// range_test — Range expressions and iteration

test "basic range in for" {
  var sum = 0
  for i in 0..5 {
    sum = sum + i
  }
  assert_eq(sum, 10)
}

test "range starts at non-zero" {
  var sum = 0
  for i in 3..6 {
    sum = sum + i
  }
  assert_eq(sum, 12)
}

test "inclusive range" {
  var count = 0
  for _ in 0..=5 {
    count = count + 1
  }
  assert_eq(count, 6)
}

test "range zero iterations" {
  var count = 0
  for _ in 5..5 {
    count = count + 1
  }
  assert_eq(count, 0)
}

test "range single iteration" {
  var count = 0
  for _ in 0..1 {
    count = count + 1
  }
  assert_eq(count, 1)
}

test "range with variable bounds" {
  let start = 2
  let end = 7
  var sum = 0
  for i in start..end {
    sum = sum + i
  }
  assert_eq(sum, 20)
}

test "range collecting to list" {
  var result: List[Int] = []
  for i in 0..4 {
    result = result + [i]
  }
  assert_eq(result, [0, 1, 2, 3])
}

test "range in nested loop" {
  var count = 0
  for _ in 0..3 {
    for _ in 0..4 {
      count = count + 1
    }
  }
  assert_eq(count, 12)
}

test "inclusive range boundary" {
  var last = -1
  for i in 0..=0 {
    last = i
  }
  assert_eq(last, 0)
}

test "range with large step accumulator" {
  var sum = 0
  for i in 0..100 {
    sum = sum + i
  }
  assert_eq(sum, 4950)
}
