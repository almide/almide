
// ── expr! on Result ──

effect fn parse_must(s: String) -> Result[Int, String] = {
  let n = int.parse(s)!
  ok(n)
}

test "bang result ok" {
  assert_eq(parse_must("42"), ok(42))
}

test "bang result err propagates" {
  let r = parse_must("bad")
  assert(result.is_err(r))
}

effect fn chain_bang() -> Result[Int, String] = {
  let a = int.parse("10")!
  let b = int.parse("20")!
  ok(a + b)
}

test "bang result chain" {
  assert_eq(chain_bang(), ok(30))
}

// ── expr! on Option ──

effect fn get_first(xs: List[Int]) -> Result[Int, String] = {
  let v = list.first(xs)!
  ok(v)
}

test "bang option some" {
  assert_eq(get_first([1, 2, 3]), ok(1))
}

test "bang option none propagates err" {
  let r = get_first([])
  assert(result.is_err(r))
}

// ── expr ?? on Result ──

test "qq result ok" {
  let v = int.parse("42") ?? 0
  assert_eq(v, 42)
}

test "qq result err uses fallback" {
  let v = int.parse("bad") ?? 99
  assert_eq(v, 99)
}

// ── expr ?? on Option ──

test "qq option some" {
  let xs = [10, 20]
  let v = list.first(xs) ?? 0
  assert_eq(v, 10)
}

test "qq option none uses fallback" {
  let xs: List[Int] = []
  let v = list.first(xs) ?? 42
  assert_eq(v, 42)
}

// ── expr? on Result → Option ──

fn try_parse(s: String) -> Option[Int] =
  int.parse(s)?

test "question result ok becomes some" {
  assert_eq(try_parse("42"), some(42))
}

test "question result err becomes none" {
  assert_eq(try_parse("bad"), none)
}

// ── expr? on Option → Option (identity) ──

fn try_first(xs: List[Int]) -> Option[Int] =
  list.first(xs)?

test "question option some passthrough" {
  assert_eq(try_first([1, 2]), some(1))
}

test "question option none passthrough" {
  assert_eq(try_first([]), none)
}

// ── Combined operators ──

test "qq chain result and option" {
  let port = int.parse(map.get(["port": "8080"], "port") ?? "3000") ?? 80
  assert_eq(port, 8080)
}

test "qq chain fallback key missing" {
  let port = int.parse(map.get(["host": "localhost"], "port") ?? "3000") ?? 80
  assert_eq(port, 3000)
}
