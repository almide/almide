// Regression tests for the DRAIN-SMALLS cross-target/codegen fixes.
// Each `test` block validates a fixed bug on BOTH targets (run via
// `almide test spec/lang/drain_smalls_test.almd` for native and the WASM
// test path for wasm).

// ── Item 3: sized-integer fields in record / variant construction ──
type Inner = { x: Int8, y: Int32 }
type Outer = { a: UInt8, inner: Inner, b: Int16 }
type Event = Click(Int32, Int) | Scroll { dy: Int8 }

test "sized-int record fields read back exact, no neighbor corruption" {
  let o = Outer { a: 200, inner: Inner { x: 7, y: 100000 }, b: 30000 };
  assert_eq("${o.a}", "200");
  assert_eq("${o.inner.x}", "7");
  assert_eq("${o.inner.y}", "100000");
  assert_eq("${o.b}", "30000")
}

test "tuple-variant payload Int32 does not corrupt the next Int field" {
  let c = Click(42, 9);
  assert_eq("${c}", "Click(42, 9)");
  let s = Scroll { dy: 5 };
  assert_eq("${s}", "Scroll { dy: 5 }")
}

test "negative sized-int literals round-trip" {
  let n = Inner { x: -8, y: -50000 };
  assert_eq("${n.x} ${n.y}", "-8 -50000")
}

// ── Item 5: user `Box` type coexists with a recursive enum ──
type Box = { width: Int, height: Int }
type Tree = Leaf(Int) | Node(Tree, Tree)

fn tree_sum(t: Tree) -> Int = match t {
  Leaf(n) => n,
  Node(l, r) => tree_sum(l) + tree_sum(r),
}

test "user Box type and recursive enum compile and run together" {
  let b = Box { width: 3, height: 4 };
  assert_eq(b.width + b.height, 7);
  let t = Node(Leaf(1), Node(Leaf(2), Leaf(3)));
  assert_eq(tree_sum(t), 6);
  assert_eq("${t}", "Node(Leaf(1), Node(Leaf(2), Leaf(3)))")
}

// ── Item 6: List[String] param used by both string.join and list.len ──
fn summary(xs: List[String]) -> String = {
  let n = list.len(xs);
  string.join(xs, ",") + "/" + int.to_string(n)
}

test "List[String] param consumed by join and len at once" {
  assert_eq(summary(["a", "b", "c"]), "a,b,c/3");
  assert_eq(summary([]), "/0");
  assert_eq(summary(["solo"]), "solo/1")
}
