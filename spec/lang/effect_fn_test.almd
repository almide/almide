// effect_fn_test — Effect function patterns

// ── Basic effect fn returning ok/err ──

effect fn safe_div(a: Int, b: Int) -> Result[Int, String] = {
  guard b != 0 else err("division by zero")
  ok(a / b)
}

test "effect fn ok path" {
  assert_eq(safe_div(10, 2), ok(5))
}

test "effect fn err path" {
  assert_eq(safe_div(10, 0), err("division by zero"))
}

// ── Auto-? propagation ──

effect fn parse_num(s: String) -> Result[Int, String] = {
  let n = int.parse(s)
  ok(n)
}

effect fn add_strings(a: String, b: String) -> Result[Int, String] = {
  let x = parse_num(a)
  let y = parse_num(b)
  ok(x + y)
}

test "effect fn auto unwrap chain ok" {
  assert_eq(add_strings("10", "20"), ok(30))
}

test "effect fn auto unwrap chain err propagates" {
  match add_strings("10", "abc") {
    ok(_) => assert(false, "should be err"),
    err(e) => assert(string.len(e) > 0),
  }
}

// ── Guard else err ──

effect fn require_positive(n: Int) -> Result[Int, String] = {
  guard n > 0 else err("not positive")
  ok(n)
}

test "guard else err passes" {
  assert_eq(require_positive(5), ok(5))
}

test "guard else err fails" {
  assert_eq(require_positive(-3), err("not positive"))
}

// ── Multiple guards ──

effect fn validate_age(age: Int) -> Result[Int, String] = {
  guard age >= 0 else err("negative age")
  guard age <= 150 else err("unrealistic age")
  ok(age)
}

test "multiple guards first fails" {
  assert_eq(validate_age(-1), err("negative age"))
}

test "multiple guards second fails" {
  assert_eq(validate_age(200), err("unrealistic age"))
}

test "multiple guards all pass" {
  assert_eq(validate_age(25), ok(25))
}

// ── Effect fn calling effect fn (auto unwrap) ──

effect fn double_parsed(s: String) -> Result[Int, String] = {
  let n = parse_num(s)
  let valid = require_positive(n)
  ok(valid * 2)
}

test "effect fn chain three deep ok" {
  assert_eq(double_parsed("5"), ok(10))
}

test "effect fn chain parse error" {
  match double_parsed("abc") {
    ok(_) => assert(false, "should err"),
    err(_) => assert(true),
  }
}

test "effect fn chain validation error" {
  assert_eq(double_parsed("-3"), err("not positive"))
}

// ── Effect fn with loop ──

effect fn sum_strs(strs: List[String]) -> Result[Int, String] = {
  var total = 0
  for s in strs {
    let n = parse_num(s)
    total = total + n
  }
  ok(total)
}

test "effect fn with for loop ok" {
  assert_eq(sum_strs(["1", "2", "3"]), ok(6))
}

// ── Effect fn with conditional logic ──

effect fn classify_str(s: String) -> Result[String, String] = {
  let n = parse_num(s)
  let pos = require_positive(n)
  let label = if pos > 100 then "big"
    else if pos > 10 then "medium"
    else "small"
  ok(label)
}

test "effect fn conditional small" {
  assert_eq(classify_str("5"), ok("small"))
}

test "effect fn conditional big" {
  assert_eq(classify_str("200"), ok("big"))
}
