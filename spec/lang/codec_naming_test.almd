import value
import jsontype

module naming_test

test "naming strategy via composition" {
  let r = ApiResponse { user_name: "Alice", created_at: "2024-01-15" };
  let v = r.encode();
  let camel = value.to_camel_case(v);
  let text = json.stringify(camel);
  println(text);
  assert(string.contains(text, "userName"));
  assert(string.contains(text, "createdAt"))
}
