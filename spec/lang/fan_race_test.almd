// fan.race — first to complete wins

effect fn fast() -> Result[String, String] = ok("fast")
effect fn slow() -> Result[String, String] = ok("slow")

test "fan.race basic" {
  let winner = fan.race([
    () => fast(),
    () => slow(),
  ])
  assert(winner == "fast" or winner == "slow")
}

test "fan.race single thunk" {
  let result = fan.race([
    () => fast(),
  ])
  assert_eq(result, "fast")
}
