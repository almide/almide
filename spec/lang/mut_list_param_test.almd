// Runs on BOTH targets since 0.28.6 (#705): a bare `mut List` param lowers
// through tuple return + place writeback, so a reallocating push persists to
// the caller's slot on wasm as well as native (C-131/C-132). The record-field
// case is mut_record_field_test.almd.

fn push9(mut v: List[Int], x: Int) -> Int = {
  list.push(v, x)
  list.len(v) - 1
}

test "mut List param pushes in place (native; #705 on wasm)" {
  var v: List[Int] = [10]
  let i = push9(v, 20)
  let j = push9(v, 30)
  assert(i == 1 and j == 2)
  assert(list.len(v) == 3)
  assert(v[2] == 30)
}
