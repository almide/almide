// Perceus monkey test: adversarial patterns designed to break RC.
// If any test panics, leaks, or double-frees, the proof has a gap.

fn build_str(n: Int) -> String =
  if n <= 0 then ""
  else build_str(n - 1) + "x"

fn fib_str(n: Int) -> String =
  if n <= 1 then int.to_string(n)
  else {
    let a = fib_str(n - 1)
    let b = fib_str(n - 2)
    a + "+" + b
  }

test "heap alloc + immediate discard" {
  let _ = "hello"
  let _ = "world"
  assert_eq(1, 1)
}

test "chain of reassignments" {
  var s = "a"
  s = "b"
  s = "c"
  s = "d"
  s = "e"
  assert_eq(s, "e")
}

test "branch: both sides allocate" {
  let x = if true then "left" else "right"
  assert_eq(x, "left")
}

test "branch: nested if/else heap" {
  let x = if true then
    if false then "deep-left" else "deep-right"
  else
    "shallow"
  assert_eq(x, "deep-right")
}

test "unused heap in both branches" {
  let _ = if true then {
    let _ = "discard-then"
    "keep-then"
  } else {
    let _ = "discard-else"
    "keep-else"
  }
  assert_eq(1, 1)
}

test "match with heap in every arm" {
  let x = 3
  let s = match x {
    1 => "one",
    2 => "two",
    3 => "three",
    _ => "other",
  }
  assert_eq(s, "three")
}

test "heap string concat chain" {
  let a = "hello"
  let b = a + " " + "world"
  let c = b + "!"
  assert_eq(c, "hello world!")
}

test "list alloc and discard" {
  let _ = [1, 2, 3]
  let _ = [4, 5, 6]
  let xs = [7, 8, 9]
  assert_eq(list.len(xs), 3)
}

test "list map creates new list" {
  let xs = [1, 2, 3]
  let ys = xs |> list.map((x) => x * 2)
  assert_eq(ys, [2, 4, 6])
}

test "list filter discards elements" {
  let xs = [1, 2, 3, 4, 5, 6]
  let evens = xs |> list.filter((x) => x % 2 == 0)
  assert_eq(evens, [2, 4, 6])
}

test "nested list operations" {
  let result = [1, 2, 3, 4, 5]
    |> list.map((x) => x * 10)
    |> list.filter((x) => x > 20)
    |> list.map((x) => int.to_string(x))
  assert_eq(result, ["30", "40", "50"])
}

test "string in loop" {
  var acc = ""
  for i in list.range(0, 5) {
    acc = acc + int.to_string(i)
  }
  assert_eq(acc, "01234")
}

test "heap alloc inside while" {
  var i = 0
  var last = ""
  while i < 10 {
    last = "iter-" + int.to_string(i)
    i = i + 1
  }
  assert_eq(last, "iter-9")
}

test "many temps in one expression" {
  let s = "a" + "b" + "c" + "d" + "e" + "f" + "g" + "h"
  assert_eq(s, "abcdefgh")
}

test "recursive fn with heap alloc" {
  assert_eq(build_str(5), "xxxxx")
}

test "closure captures heap value" {
  let prefix = "hello-"
  let greet = (name: String) => prefix + name
  assert_eq(greet("world"), "hello-world")
}

test "closure in list.map" {
  let tag = "item-"
  let result = [1, 2, 3] |> list.map((x) => tag + int.to_string(x))
  assert_eq(result, ["item-1", "item-2", "item-3"])
}

test "multiple closures capture same value" {
  let base = "test"
  let f1 = () => base + "-1"
  let f2 = () => base + "-2"
  let f3 = () => base + "-3"
  assert_eq(f1(), "test-1")
  assert_eq(f2(), "test-2")
  assert_eq(f3(), "test-3")
}

test "deeply nested blocks" {
  let result = {
    let a = "level1"
    let b = {
      let c = "level2"
      let d = {
        let e = "level3"
        a + "-" + c + "-" + e
      }
      d
    }
    b
  }
  assert_eq(result, "level1-level2-level3")
}

test "var reassign in branch" {
  var s = "initial"
  if true then {
    s = "changed"
  } else {
    s = "other"
  }
  assert_eq(s, "changed")
}

test "list of strings" {
  let xs = ["alpha", "beta", "gamma"]
  let joined = xs |> list.join(", ")
  assert_eq(joined, "alpha, beta, gamma")
}

test "string repeat pattern 100x" {
  var result = ""
  for _ in list.range(0, 100) {
    result = result + "."
  }
  assert_eq(string.len(result), 100)
}

test "discard intermediate list results" {
  let _ = list.range(0, 50) |> list.map((x) => x * 2)
  let _ = list.range(0, 50) |> list.filter((x) => x > 25)
  let final = list.range(0, 10) |> list.map((x) => int.to_string(x))
  assert_eq(list.len(final), 10)
}

test "recursive fibonacci with string trace" {
  let trace = fib_str(4)
  assert_eq(string.len(trace) > 0, true)
}

test "option with heap value" {
  let x: Option[String] = some("hello")
  let y: Option[String] = none
  let r1 = x ?? "default"
  let r2 = y ?? "default"
  assert_eq(r1, "hello")
  assert_eq(r2, "default")
}

test "100 sequential heap allocs" {
  var count = 0
  for i in list.range(0, 100) {
    let _ = "alloc-" + int.to_string(i)
    count = count + 1
  }
  assert_eq(count, 100)
}

test "nested for with heap" {
  var total = 0
  for i in list.range(0, 10) {
    for j in list.range(0, 10) {
      let _ = int.to_string(i) + "-" + int.to_string(j)
      total = total + 1
    }
  }
  assert_eq(total, 100)
}

test "string comparison after many ops" {
  var s = "start"
  for i in list.range(0, 20) {
    s = s + "-" + int.to_string(i)
  }
  assert_eq(string.starts_with(s, "start-0-1-2"), true)
}
