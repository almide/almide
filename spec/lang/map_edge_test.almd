
// map_edge_test — Map literal and operation edge cases
test "empty map" {
  let m: Map[String, Int] = [:];
  assert_eq(m.len(), 0)
}

test "map creation and get" {
  let m = ["a": 1, "b": 2, "c": 3];
  assert_eq(m.get("a"), some(1));
  assert_eq(m.get("c"), some(3))
}

test "map get returns Option" {
  let m = ["x": 10];
  assert_eq(m.get("x"), some(10));
  assert_eq(m.get("y"), none)
}

test "map contains" {
  let m = ["key": "value"];
  assert_eq(m.contains("key"), true);
  assert_eq(m.contains("other"), false)
}

test "map len" {
  let m = [
    "a": 1,
    "b": 2,
    "c": 3,
    "d": 4
  ];
  assert_eq(m.len(), 4)
}

test "map keys and values" {
  let m = ["x": 1, "y": 2];
  let ks = m.keys().sort();
  assert_eq(ks, ["x", "y"])
}

test "map iteration" {
  let m = ["a": 10, "b": 20];
  var sum = 0;
  for (_, v) in m {
    sum = sum + v;
  };
  assert_eq(sum, 30)
}

test "map with integer values" {
  let scores = ["alice": 95, "bob": 87, "charlie": 92];
  assert_eq(scores.len(), 3);
  assert_eq(scores.get("alice"), some(95))
}

test "map is_empty" {
  let empty: Map[String, Int] = [:];
  let nonempty = ["a": 1];
  assert_eq(empty.is_empty(), true);
  assert_eq(nonempty.is_empty(), false)
}

test "single entry map" {
  let m = ["only": 42];
  assert_eq(m.len(), 1);
  assert_eq(m.get("only"), some(42))
}
