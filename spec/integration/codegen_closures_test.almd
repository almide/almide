// codegen_closures_test — Closure capture edge cases for codegen

// ── Closure capturing multiple variables of different types ──

test "closure captures mixed types" {
  let name = "item"
  let count = 3
  let separator = "-"
  let builder = (i) => "${name}${separator}${int.to_string(i)}"
  var results: List[String] = []
  for i in 0..count {
    results = results ++ [builder(i)]
  }
  assert_eq(results, ["item-0", "item-1", "item-2"])
}

// ── Closure returned from function capturing its argument ──

fn make_prefixer(prefix: String) -> (String) -> String =
  (s) => prefix ++ s

fn make_suffixer(suffix: String) -> (String) -> String =
  (s) => s ++ suffix

test "composed closures from functions" {
  let add_hash = make_prefixer("#")
  let add_bang = make_suffixer("!")
  let result = add_bang(add_hash("hello"))
  assert_eq(result, "#hello!")
}

// ── Closure as value in list ──

test "list of closures" {
  let fns: List[(Int) -> Int] = [
    (x) => x + 1,
    (x) => x * 2,
    (x) => x * x,
  ]
  var results: List[Int] = []
  for f in fns {
    results = results ++ [f(5)]
  }
  assert_eq(results, [6, 10, 25])
}

// ── Closure capturing a record ──

test "closure captures record" {
  let config = { multiplier: 10, offset: 5 }
  let transform = (x) => x * config.multiplier + config.offset
  assert_eq(transform(3), 35)
  assert_eq(transform(0), 5)
}

// ── Closure capturing a list ──

test "closure captures list and uses it" {
  let allowed = [1, 3, 5, 7, 9]
  let is_allowed = (x) => list.contains(allowed, x)
  assert_eq(is_allowed(3), true)
  assert_eq(is_allowed(4), false)
  assert_eq(is_allowed(9), true)
}

// ── Nested closures with layered capture ──

test "nested closure captures from multiple layers" {
  let a = 100
  let outer = (x: Int) => {
    let b = 200
    let inner = (y: Int) => a + b + x + y
    inner(4)
  }
  assert_eq(outer(3), 307)
}

// ── Closure used as callback in fold with capture ──

test "closure with capture in fold" {
  let weights = [2, 3, 5]
  let values = [10, 20, 30]
  let pairs = list.zip(weights, values)
  let weighted_sum = list.fold(pairs, 0, (acc, pair) => {
    let (w, v) = pair
    acc + w * v
  })
  assert_eq(weighted_sum, 230)
}

// ── Closure capturing an option ──

test "closure captures option" {
  let default_val = some(42)
  let get_or_default = (opt: Option[Int]) => match opt {
    some(v) => v,
    none => match default_val {
      some(d) => d,
      none => 0,
    },
  }
  assert_eq(get_or_default(some(10)), 10)
  assert_eq(get_or_default(none), 42)
}

// ── Closure used after the captured variable is shadowed ──

test "closure captures original value before shadowing" {
  let x = 10
  let f = (n: Int) => n + x
  let x = 999
  assert_eq(f(5), 15)
  assert_eq(x, 999)
}

// ── Higher-order function returning closure that captures argument ──

fn make_range_checker(lo: Int, hi: Int) -> (Int) -> Bool =
  (x) => x >= lo and x <= hi

test "closure captures multiple function args" {
  let in_range = make_range_checker(10, 20)
  assert_eq(in_range(5), false)
  assert_eq(in_range(15), true)
  assert_eq(in_range(25), false)
}
