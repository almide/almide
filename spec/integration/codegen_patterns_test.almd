// codegen_patterns_test — Pattern matching and destructuring edge cases

// ── Match with nested variant and record patterns ──

type Msg =
  | Text(String)
  | Number(Int)
  | Pair(Int, Int)

fn msg_to_string(m: Msg) -> String = match m {
  Text(s) => "text:" + s,
  Number(n) => "num:" + int.to_string(n),
  Pair(a, b) => "pair:" + int.to_string(a) + "," + int.to_string(b),
}

test "variant match with all arms" {
  assert_eq(msg_to_string(Text("hi")), "text:hi")
  assert_eq(msg_to_string(Number(42)), "num:42")
  assert_eq(msg_to_string(Pair(1, 2)), "pair:1,2")
}

// ── Match on option of variant ──

test "match option of variant" {
  let x: Option[Msg] = some(Number(99))
  let result = match x {
    some(Number(n)) => n,
    some(_) => -1,
    none => -2,
  }
  assert_eq(result, 99)
}

test "match option of variant none case" {
  let x: Option[Msg] = none
  let result = match x {
    some(Number(n)) => n,
    some(_) => -1,
    none => -2,
  }
  assert_eq(result, -2)
}

// ── Tuple destructuring in let ──

test "tuple destructure three elements" {
  let (a, b, c) = (10, "hello", true)
  assert_eq(a, 10)
  assert_eq(b, "hello")
  assert_eq(c, true)
}

test "tuple destructure from function return" {
  let (min, max) = list.partition([5, 1, 8, 3, 9], (x) => x < 5)
  assert_eq(min, [1, 3])
  assert_eq(max, [5, 8, 9])
}

// ── For loop with tuple destructuring ──

test "for loop with tuple destructure from zip" {
  let names = ["alice", "bob", "carol"]
  let scores = [90, 85, 95]
  var results: List[String] = []
  for (name, score) in list.zip(names, scores) {
    results = results + ["${name}:${int.to_string(score)}"]
  }
  assert_eq(results, ["alice:90", "bob:85", "carol:95"])
}

test "for loop with enumerate tuple destructure" {
  let items = ["a", "b", "c"]
  var indexed: List[String] = []
  for (i, item) in list.enumerate(items) {
    indexed = indexed + ["${int.to_string(i)}=${item}"]
  }
  assert_eq(indexed, ["0=a", "1=b", "2=c"])
}

// ── For loop with tuple destructure from map entries ──

test "for (k, v) in map entries" {
  let m = map.set(map.set(map.new(), "x", 10), "y", 20)
  var sum = 0
  for (k, v) in map.entries(m) {
    sum = sum + v
  }
  assert_eq(sum, 30)
}

// ── Match with guard and complex condition ──

test "match guard with function call in condition" {
  let xs = [1, 2, 3, 4, 5]
  let result = match xs {
    ys if list.len(ys) > 3 => "long list",
    ys if list.len(ys) > 0 => "short list",
    _ => "empty",
  }
  assert_eq(result, "long list")
}

// ── Record destructuring ──

test "record destructure with many fields" {
  let config = { host: "localhost", port: 8080, debug: true, timeout: 30 }
  let { host, port, debug, timeout } = config
  assert_eq(host, "localhost")
  assert_eq(port, 8080)
  assert_eq(debug, true)
  assert_eq(timeout, 30)
}

// ── Match returning different types of expressions ──

test "match arms returning records" {
  let x = 1
  let result = match x {
    1 => { name: "one", value: 1 },
    2 => { name: "two", value: 2 },
    _ => { name: "other", value: 0 },
  }
  assert_eq(result.name, "one")
  assert_eq(result.value, 1)
}

test "match arms returning tuples" {
  let x = "hello"
  let (label, len) = match x {
    s if string.len(s) > 3 => ("long", string.len(s)),
    s => ("short", string.len(s)),
  }
  assert_eq(label, "long")
  assert_eq(len, 5)
}

// ── Match arms returning lists ──

test "match arms returning lists" {
  let n = 3
  let result = match n {
    1 => [1],
    2 => [1, 2],
    3 => [1, 2, 3],
    _ => [],
  }
  assert_eq(result, [1, 2, 3])
}

// ── Nested match with block bodies ──

test "nested match with blocks" {
  let x: Option[Result[Int, String]] = some(ok(42))
  let result = match x {
    some(inner) => {
      let msg = match inner {
        ok(v) => {
          let doubled = v * 2
          "ok:${int.to_string(doubled)}"
        },
        err(e) => "err:${e}",
      }
      msg
    },
    none => "none",
  }
  assert_eq(result, "ok:84")
}

// ── Match with wildcard and binding together ──

test "match wildcard in variant payload" {
  let msgs = [Pair(1, 2), Text("hi"), Number(5), Pair(3, 4)]
  var pair_sums: List[Int] = []
  for m in msgs {
    let maybe_sum = match m {
      Pair(a, b) => some(a + b),
      _ => none,
    }
    match maybe_sum {
      some(s) => { pair_sums = pair_sums + [s] },
      none => { () },
    }
  }
  assert_eq(pair_sums, [3, 7])
}
