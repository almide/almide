// codegen_collections_test — List/Map operations chained, empty collections, type inference

// ── Empty collections with type inference ──

test "empty list in typed context" {
  let xs: List[Int] = []
  let ys = xs ++ [1, 2, 3]
  assert_eq(ys, [1, 2, 3])
  assert_eq(list.len(xs), 0)
}

test "empty map operations" {
  let m: Map[String, Int] = [:]
  assert_eq(m.len(), 0)
  assert_eq(m.is_empty?(), true)
  let m2 = m.set("x", 42)
  assert_eq(m2.len(), 1)
  assert_eq(m2["x"], some(42))
}

// ── List of lists ──

test "list of lists with map and flatten" {
  let matrix = [[1, 2], [3, 4], [5, 6]]
  let flat = list.flatten(matrix)
  assert_eq(flat, [1, 2, 3, 4, 5, 6])
  let doubled_rows = list.map(matrix, fn(row) => list.map(row, fn(x) => x * 2))
  assert_eq(doubled_rows, [[2, 4], [6, 8], [10, 12]])
}

// ── Chained list operations ──

test "chain: filter, map, sort, reverse, take" {
  let data = [15, 3, 8, 22, 1, 19, 7, 11, 25, 4]
  let result = data
    |> list.filter(fn(x) => x > 5)
    |> list.map(fn(x) => x * 2)
    |> list.sort()
    |> list.reverse()
    |> list.take(3)
  assert_eq(result, [50, 44, 38])
}

// ── Map built from list operations ──

test "map from computed entries" {
  let names = ["alice", "bob", "carol"]
  let entries = list.map(
    list.enumerate(names),
    fn(pair) => {
      let (i, name) = pair
      (name, i)
    }
  )
  let m = map.from_entries(entries)
  assert_eq(map.get(m, "alice"), some(0))
  assert_eq(map.get(m, "bob"), some(1))
  assert_eq(map.get(m, "carol"), some(2))
}

// ── List chunk and windows ──

test "list chunk then map to sums" {
  let result = list.chunk([1, 2, 3, 4, 5, 6, 7, 8, 9], 3)
    |> list.map(fn(chunk) => list.sum(chunk))
  assert_eq(result, [6, 15, 24])
}

test "list windows overlapping" {
  let result = list.windows([1, 2, 3, 4, 5], 2)
  assert_eq(result, [[1, 2], [2, 3], [3, 4], [4, 5]])
}

// ── List zip and unzip pattern ──

test "zip then process pairs" {
  let keys = ["a", "b", "c"]
  let values = [1, 2, 3]
  let entries = list.zip(keys, values)
  let descriptions = list.map(entries, fn(pair) => {
    let (k, v) = pair
    "${k}=${int.to_string(v)}"
  })
  assert_eq(descriptions, ["a=1", "b=2", "c=3"])
}

// ── Map iteration and transformation ──

test "map entries iterated with for loop" {
  let m = ["x": 10, "y": 20, "z": 30]
  var total = 0
  var keys: List[String] = []
  for (k, v) in m {
    total = total + v
    keys = keys ++ [k]
  }
  assert_eq(total, 60)
  assert_eq(list.len(keys), 3)
}

// ── Mutable map with index assignment ──

test "mutable map build via index assignment" {
  var m: Map[String, Int] = [:]
  for i in 0..5 {
    m["key${int.to_string(i)}"] = i * 10
  }
  assert_eq(m.len(), 5)
  assert_eq(m["key0"], some(0))
  assert_eq(m["key4"], some(40))
}

// ── List group_by pattern using map ──

test "group list elements by predicate using map" {
  let words = ["cat", "car", "dog", "cup", "dart"]
  var groups: Map[String, List[String]] = [:]
  for w in words {
    let first = match string.char_at(w, 0) {
      some(c) => c,
      none => "?",
    }
    let existing = match groups[first] {
      some(xs) => xs,
      none => [],
    }
    groups[first] = existing ++ [w]
  }
  assert_eq(groups["c"], some(["cat", "car", "cup"]))
  assert_eq(groups["d"], some(["dog", "dart"]))
}

// ── List of tuples ──

test "list of tuples with operations" {
  let pairs = [(1, "one"), (2, "two"), (3, "three")]
  let nums = list.map(pairs, fn(p) => p.0)
  let strs = list.map(pairs, fn(p) => p.1)
  assert_eq(nums, [1, 2, 3])
  assert_eq(strs, ["one", "two", "three"])
}

// ── List reduce ──

test "list reduce to find max" {
  let result = list.reduce([3, 7, 2, 9, 1], fn(a, b) => if a > b then a else b)
  assert_eq(result, some(9))
}

// ── Empty collection edge cases ──

test "operations on empty list return sensible defaults" {
  let empty: List[Int] = []
  assert_eq(list.sum(empty), 0)
  assert_eq(list.product(empty), 1)
  assert_eq(list.first(empty), none)
  assert_eq(list.last(empty), none)
  assert_eq(list.min(empty), none)
  assert_eq(list.max(empty), none)
  assert_eq(list.reverse(empty), [])
  assert_eq(list.sort(empty), [])
}
