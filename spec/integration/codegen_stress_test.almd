type Point = { x: Int, y: Int }

type Shape =
  | Circle(Float)
  | Rect(Float, Float)

test "variable used 3 times" {
  let s = "hello"
  let a = string.len(s)
  let b = string.to_upper(s)
  let c = s + " world"
  assert_eq(a, 5)
  assert_eq(b, "HELLO")
  assert_eq(c, "hello world")
}

test "list used in multiple operations" {
  let xs = [1, 2, 3]
  let a = list.len(xs)
  let b = list.map(xs, (x) => x * 2)
  let c = list.filter(xs, (x) => x > 1)
  assert_eq(a, 3)
  assert_eq(b, [2, 4, 6])
  assert_eq(c, [2, 3])
}

test "param used in closure and after" {
  let xs = [1, 2, 3]
  let doubled = list.map(xs, (x) => x * 2)
  let sum = list.fold(xs, 0, (acc, x) => acc + x)
  assert_eq(doubled, [2, 4, 6])
  assert_eq(sum, 6)
}

test "string in interpolation then function" {
  let name = "Alice"
  let greeting = "Hello, ${name}!"
  let upper = string.to_upper(name)
  assert_eq(greeting, "Hello, Alice!")
  assert_eq(upper, "ALICE")
}

test "variable in for loop then used after" {
  let xs = [1, 2, 3]
  var total = 0
  for x in xs { total = total + x }
  let len = list.len(xs)
  assert_eq(total, 6)
  assert_eq(len, 3)
}

test "nested function calls with same var" {
  let s = "hello world"
  let words = string.split(s, " ")
  let has = string.contains(s, "hello")
  assert_eq(list.len(words), 2)
  assert_eq(has, true)
}

test "map used multiple ways" {
  let m = map.set(map.set(map.new(), "a", 1), "b", 2)
  let has_a = map.contains(m, "a")
  let size = map.len(m)
  assert_eq(size, 2)
  assert_eq(has_a, true)
}

test "record field access" {
  let p = Point { x: 3, y: 4 }
  assert_eq(p.x + p.y, 7)
  assert_eq(p.x, 3)
}

test "list passed to two functions" {
  let data = [5, 3, 1, 4, 2]
  let sorted = list.sort(data)
  let reversed = list.reverse(data)
  assert_eq(sorted, [1, 2, 3, 4, 5])
  assert_eq(reversed, [2, 4, 1, 3, 5])
}

test "string concat then interpolation" {
  let first = "Hello"
  let second = "World"
  let combined = first + " " + second
  let msg = "${first} says ${second}"
  assert_eq(combined, "Hello World")
  assert_eq(msg, "Hello says World")
}

test "triple nested for" {
  let as_ = [1, 2]
  let bs = [10, 20]
  let cs = [100, 200]
  var total = 0
  for a in as_ {
    for b in bs {
      for c in cs {
        total = total + a + b + c
      }
    }
  }
  assert_eq(total, 1332)
}

fn area(s: Shape) -> Float =
  match s { Circle(r) => 3.14 * r * r, Rect(w, h) => w * h }

test "match variant" { assert_eq(area(Rect(3.0, 4.0)), 12.0) }

test "match string" {
  let r = match "hello" { "hello" => "world", _ => "?" }
  assert_eq(r, "world")
}

test "option" {
  let v = match list.get([10, 20], 1) { some(v) => v, none => 0 }
  assert_eq(v, 20)
}

test "while" {
  var i = 0
  var s = 0
  while i < 5 { s = s + i; i = i + 1 }
  assert_eq(s, 10)
}

test "pipe chain" {
  let r = [1, 2, 3, 4, 5]
    |> list.filter((x) => x > 2)
    |> list.map((x) => x * 10)
    |> list.fold(0, (a, x) => a + x)
  assert_eq(r, 120)
}

fn factorial(n: Int) -> Int = if n <= 1 then 1 else n * factorial(n - 1)

test "recursion" { assert_eq(factorial(5), 120) }

fn greet(name: String, prefix: String = "Hello") -> String = "${prefix}, ${name}!"

test "default args" {
  assert_eq(greet("Alice"), "Hello, Alice!")
  assert_eq(greet("Bob", "Hi"), "Hi, Bob!")
}
