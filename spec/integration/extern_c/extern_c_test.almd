// @extern(c) test: call C library functions from Almide

@extern(c, "m", "sqrt")
fn c_sqrt(x: Float) -> Float

@extern(c, "m", "floor")
fn c_floor(x: Float) -> Float

@extern(c, "m", "ceil")
fn c_ceil(x: Float) -> Float

fn main() -> Unit = {
  // sqrt(25.0) = 5.0
  assert_eq(c_sqrt(25.0), 5.0, "@extern(c) sqrt")
  assert_eq(c_sqrt(9.0), 3.0, "@extern(c) sqrt(9)")

  // floor(3.7) = 3.0
  assert_eq(c_floor(3.7), 3.0, "@extern(c) floor")

  // ceil(3.2) = 4.0
  assert_eq(c_ceil(3.2), 4.0, "@extern(c) ceil")

  println("All @extern(c) tests passed!")
}
