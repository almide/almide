// Submodule call tests (Go-style: each module imported individually)
// Verify that submodules must be explicitly imported to use.

import dmod_d
import dmod_d.utils as utils
import dmod_d.nested.deep as deep
import dmod_b

// ── Direct package function ──

test "submodule: top-level function" {
  assert_eq(dmod_d.shared(), "from D")
}

test "submodule: top-level value" {
  assert_eq(dmod_d.value(), 42)
}

// ── Submodule via explicit import ──

test "submodule: utils call via import" {
  assert_eq(utils.format_level(0), "DEBUG")
  assert_eq(utils.format_level(1), "INFO")
  assert_eq(utils.format_level(2), "WARN")
  assert_eq(utils.format_level(99), "ERROR")
}

// ── Deep submodule via explicit import ──

test "submodule: deep nested via import" {
  assert_eq(deep.greet("x"), "hello from deep: x")
  assert_eq(deep.greet(""), "hello from deep: ")
}

// ── Mix top-level and submodule in same expression ──

test "submodule: top-level and submodule in one expression" {
  let level = dmod_d.value() - 42
  let label = utils.format_level(level)
  assert_eq(label, "DEBUG")
}

test "submodule: type from top-level used with submodule" {
  let logger = dmod_d.make_logger("sub-test", 2)
  let name = dmod_d.log_name(logger)
  let level_str = utils.format_level(2)
  assert_eq(name, "sub-test")
  assert_eq(level_str, "WARN")
}

// ── Submodule through diamond dependency ──

test "submodule: B uses D, then access D submodule directly" {
  let from_b = dmod_b.from_b()
  let level = utils.format_level(1)
  assert_eq(from_b, "B says: from D")
  assert_eq(level, "INFO")
}
