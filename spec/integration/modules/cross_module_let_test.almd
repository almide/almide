import letlib

test "cross-module let value access" {
  assert_eq(letlib.GREETING, "hello")
}

test "cross-module let composes with stdlib pipes" {
  assert_eq(letlib.NUMBERS |> list.len, 3)
}

test "cross-module let alongside cross-module fn" {
  assert_eq(letlib.welcome(), "hello world")
}

test "cross-module let Float value" {
  assert(letlib.UNDEFINED == -1.0)
  assert(letlib.PI > 3.14)
  assert(letlib.PI < 3.15)
}

test "cross-module let Int value" {
  assert(letlib.MAX_ITEMS == 42)
}

test "cross-module let repeated access" {
  assert(letlib.UNDEFINED < 0.0)
  assert(letlib.UNDEFINED == -1.0)
}

test "cross-module let in expressions" {
  let half_pi = letlib.PI / 2.0
  assert(half_pi > 1.57)
  assert(half_pi < 1.58)
}

test "unannotated negative constant in an anon record field via pipe" {
  // #784: { left: letlib.MARGIN_AUTO } previously carried left: Unknown.
  let v = 10.0 |> letlib.box_left({ top: 0.0, left: letlib.MARGIN_AUTO })
  assert_eq(v, 8.0)
}

test "unannotated negative constant through a bare let bind" {
  let k = letlib.MARGIN_AUTO
  let v = 10.0 |> letlib.box_left({ top: 0.0, left: k })
  assert_eq(v, 8.0)
}
