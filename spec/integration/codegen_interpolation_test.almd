// codegen_interpolation_test — String interpolation edge cases for codegen

// ── Interpolation with method calls ──

test "interpolation with stdlib call" {
  let xs = [1, 2, 3]
  let n = list.len(xs)
  let msg = "count: ${int.to_string(n)}"
  assert_eq(msg, "count: 3")
}

// ── Interpolation with nested function calls ──

test "interpolation with nested calls" {
  let msg = "upper: ${string.to_upper(string.trim("  hello  "))}"
  assert_eq(msg, "upper: HELLO")
}

// ── Interpolation with arithmetic ──

test "interpolation with arithmetic expression" {
  let a = 10
  let b = 20
  let msg = "sum=${int.to_string(a + b)}, product=${int.to_string(a * b)}"
  assert_eq(msg, "sum=30, product=200")
}

// ── Interpolation with match expression ──

test "interpolation with match" {
  let x = some(42)
  let label = match x {
    some(v) => "value: ${int.to_string(v)}",
    none => "nothing",
  }
  assert_eq(label, "value: 42")
}

// ── Interpolation with if expression ──

test "interpolation with conditional" {
  let n = 7
  let msg = "n is ${if n > 5 then "big" else "small"}"
  assert_eq(msg, "n is big")
}

// ── Multiple interpolations in sequence ──

test "many interpolations in one string" {
  let a = 1
  let b = 2
  let c = 3
  let d = 4
  let result = "${int.to_string(a)}-${int.to_string(b)}-${int.to_string(c)}-${int.to_string(d)}"
  assert_eq(result, "1-2-3-4")
}

// ── Interpolation inside loop building strings ──

test "interpolation inside for loop" {
  var lines: List[String] = []
  for i in 1..=3 {
    lines = lines ++ ["line ${int.to_string(i)}"]
  }
  assert_eq(lines, ["line 1", "line 2", "line 3"])
}

// ── Interpolation with record field access ──

test "interpolation with record field" {
  let user = { name: "alice", age: 30 }
  let msg = "user: ${user.name}, age: ${int.to_string(user.age)}"
  assert_eq(msg, "user: alice, age: 30")
}

// ── Interpolation with string concatenation inside ──

test "interpolation with concat inside" {
  let first = "hello"
  let last = "world"
  let msg = "greeting: ${first ++ " " ++ last}"
  assert_eq(msg, "greeting: hello world")
}

// ── Interpolation with tuple field access ──

test "interpolation with tuple index" {
  let t = (10, 20)
  let msg = "pair: (${int.to_string(t.0)}, ${int.to_string(t.1)})"
  assert_eq(msg, "pair: (10, 20)")
}

// ── Heredoc with complex interpolation ──

test "heredoc with record field interpolation" {
  let config = { host: "localhost", port: 8080 }
  let text = """
    server: ${config.host}
    port: ${int.to_string(config.port)}
  """
  assert_eq(text, "server: localhost\nport: 8080")
}

// ── Interpolation with empty string variable ──

test "interpolation with empty var" {
  let empty = ""
  let msg = "before${empty}after"
  assert_eq(msg, "beforeafter")
}
