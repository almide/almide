// @contract: C-101
// list.min / list.max over a List[String] — by CONTENT (lexicographic), not the i64 handle the generic
// list_min/list_max compared (→ wrong element, a silent bug). Returns Some(a deep copy) like list.get.
effect fn main() -> Unit = {
  println(list.min(["c", "a", "b"]) ?? "?")
  println(list.max(["c", "a", "b"]) ?? "?")
  println(list.min(["solo"]) ?? "?")
  println(list.max(["Z", "a", "B", "1"]) ?? "?")
  println(list.min([]) ?? "EMPTY")
}
