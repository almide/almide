
test "list.take_end" {
  assert_eq(list.take_end([1, 2, 3, 4], 2), [3, 4]);
  assert_eq(list.take_end([1], 5), [1])
}

test "list.drop_end" {
  assert_eq(list.drop_end([1, 2, 3, 4], 2), [1, 2]);
  assert_eq(list.drop_end([1], 5), [])
}

test "list.unique_by" {
  let xs = [
    1,
    2,
    3,
    4,
    5,
    6
  ];
  let result = list.unique_by(xs, (x) => x % 3);
  assert_eq(result, [1, 2, 3])
}

test "list.shuffle preserves length" {
  let xs = [1, 2, 3, 4, 5];
  let shuffled = list.shuffle(xs);
  assert_eq(list.len(shuffled), 5)
}

test "list.window" {
  assert_eq(list.window([1, 2, 3, 4], 2), [
    [1, 2],
    [2, 3],
    [3, 4]
  ]);
  assert_eq(list.window([1, 2, 3], 3), [
    [1, 2, 3]
  ])
}
