// RMSNorm and SwiGLU primitives for Llama-style transformer FFN.

fn approx_eq(a: Float, b: Float, tol: Float) -> Bool = {
  let d = if a > b then a - b else b - a
  d < tol
}

test "rms_norm_rows: identity gamma on uniform row" {
  // For row [1,1,1,1], mean(x²) = 1, so y[j] = 1 / sqrt(1+ε) * γ[j] ≈ γ[j].
  let x = matrix.from_lists([[1.0, 1.0, 1.0, 1.0]])
  let gamma = [1.0, 2.0, 3.0, 4.0]
  let y = matrix.rms_norm_rows(x, gamma, 0.000001)
  assert(approx_eq(matrix.get(y, 0, 0), 1.0, 0.0001))
  assert(approx_eq(matrix.get(y, 0, 1), 2.0, 0.0001))
  assert(approx_eq(matrix.get(y, 0, 2), 3.0, 0.0001))
  assert(approx_eq(matrix.get(y, 0, 3), 4.0, 0.0001))
}

test "rms_norm_rows: scale-invariant (per row)" {
  // Scaling a row by k should not change its RMS-normalized form (with γ=1).
  let x1 = matrix.from_lists([[1.0, 2.0, 3.0, 4.0]])
  let x2 = matrix.from_lists([[10.0, 20.0, 30.0, 40.0]])
  let gamma = [1.0, 1.0, 1.0, 1.0]
  let y1 = matrix.rms_norm_rows(x1, gamma, 0.000001)
  let y2 = matrix.rms_norm_rows(x2, gamma, 0.000001)
  assert(approx_eq(matrix.get(y1, 0, 0), matrix.get(y2, 0, 0), 0.0001))
  assert(approx_eq(matrix.get(y1, 0, 3), matrix.get(y2, 0, 3), 0.0001))
}

test "swiglu_gate matches manual silu(x@W_gate) * (x@W_up)" {
  let x = matrix.from_lists([[1.0, 2.0]])
  let w_gate = matrix.from_lists([[0.5, 0.5], [1.0, -0.5]])
  let w_up = matrix.from_lists([[1.0, 0.0], [0.0, 1.0]])

  // Gate: x @ W_gate^T
  //   z[0] = 1*0.5 + 2*0.5 = 1.5
  //   z[1] = 1*1.0 + 2*(-0.5) = 0.0
  // Up: x @ W_up^T
  //   u[0] = 1*1 + 2*0 = 1.0
  //   u[1] = 1*0 + 2*1 = 2.0
  // silu(z) = z / (1+exp(-z))
  //   silu(1.5) ≈ 1.227, silu(0) = 0
  // out = silu(z) * u
  //   out[0] = 1.227 * 1 ≈ 1.227
  //   out[1] = 0 * 2 = 0
  let y = matrix.swiglu_gate(x, w_gate, w_up)
  assert(approx_eq(matrix.get(y, 0, 0), 1.227, 0.001))
  assert(approx_eq(matrix.get(y, 0, 1), 0.0, 0.0001))
}

test "swiglu_gate ones inputs" {
  // x = ones(2, 3), W_gate = ones(4, 3), W_up = ones(4, 3)
  // Each gate / up element = 3 (sum of 3 ones).
  // silu(3) = 3 / (1 + exp(-3)) ≈ 2.857
  // out = silu(3) * 3 ≈ 8.572
  let x = matrix.ones(2, 3)
  let w_gate = matrix.ones(4, 3)
  let w_up = matrix.ones(4, 3)
  let y = matrix.swiglu_gate(x, w_gate, w_up)
  let (r, c) = matrix.shape(y)
  assert_eq(r, 2)
  assert_eq(c, 4)
  assert(approx_eq(matrix.get(y, 0, 0), 8.572, 0.01))
  assert(approx_eq(matrix.get(y, 1, 3), 8.572, 0.01))
}
