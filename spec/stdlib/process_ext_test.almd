// wasm:skip — process.env/spawn/kill are native-only
import process

test "process.env reads HOME or USERPROFILE" {
  let home = process.env("HOME") ?? process.env("USERPROFILE") ?? ""
  assert(string.len(home) > 0)
}

test "process.env returns None for missing var" {
  let val = process.env("ALMIDE_NONEXISTENT_VAR_12345")
  assert_eq(val, none)
}

test "process.spawn and kill" {
  let is_win = (process.env("OS") ?? "") == "Windows_NT"
  let cmd = if is_win then "ping" else "sleep"
  let args = if is_win then ["-n", "100", "127.0.0.1"] else ["100"]
  let pid = process.spawn(cmd, args)!
  assert(pid > 0)
  let alive = process.is_alive(pid)
  assert(alive)
  process.kill(pid, 9)!
}

test "process.is_alive returns false for nonexistent PID" {
  assert_eq(process.is_alive(99999999), false)
}

test "process.spawn failure for bad command" {
  let result = process.spawn("nonexistent_command_xyz", [])
  match result {
    Ok(_) => assert(false),
    Err(msg) => assert(string.len(msg) > 0),
  }
}
