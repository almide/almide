// Test: newlines suppressed inside parentheses and brackets
// Test: newlines suppressed before leading binary operators

import math

// --- Multi-line function parameters ---

fn add3(
  a: Int,
  b: Int,
  c: Int
) -> Int = a + b + c

test "multi-line function parameters" {
  assert_eq(add3(1, 2, 3), 6)
}

// --- Multi-line function call ---

test "multi-line function call" {
  let result = add3(
    10,
    20,
    30
  )
  assert_eq(result, 60)
}

// --- Multi-line list literal ---

test "multi-line list literal" {
  let xs = [
    1,
    2,
    3,
    4,
    5
  ]
  assert_eq(list.len(xs), 5)
  assert_eq(list.fold(xs, 0, fn(acc, x) => acc + x), 15)
}

// --- Nested multi-line ---

fn add5(
  a: Int,
  b: Int,
  c: Int,
  d: Int,
  e: Int
) -> Int = a + b + c + d + e

test "nested multi-line parens and brackets" {
  let xs = [
    add3(
      1,
      2,
      3
    ),
    add3(
      4,
      5,
      6
    )
  ]
  assert_eq(list.fold(xs, 0, fn(acc, x) => acc + x), 21)
}

// --- Leading binary operator continuation ---

test "leading plus continuation" {
  let x = 10
    + 20
    + 30
  assert_eq(x, 60)
}

test "leading minus continuation" {
  let x = 100
    - 30
    - 20
  assert_eq(x, 50)
}

test "leading multiply continuation" {
  let x = 2
    * 3
    * 4
  assert_eq(x, 24)
}

test "mixed operators continuation" {
  let x = 1.0
    + 2.0
    * 3.0
  // 1.0 + (2.0 * 3.0) = 7.0 due to precedence
  assert_eq(float.to_string(x), "7.0")
}

// --- Multi-line with comparison operators ---

test "leading comparison continuation" {
  let a = 10
  let b = 20
  let result = a
    == b
  assert_eq(result, false)
}

test "leading != continuation" {
  let a = 10
  let b = 20
  let result = a
    != b
  assert_eq(result, true)
}

// --- Complex multi-line expression ---

test "multi-line float expression" {
  let energy = 0.5 * 10.0 * (3.0 * 3.0 + 4.0 * 4.0)
    + 0.5 * 20.0 * (1.0 * 1.0 + 2.0 * 2.0)
    - 10.0 * 20.0 / math.sqrt(2.0 * 2.0 + 3.0 * 3.0)
  // 0.5*10*25 + 0.5*20*5 - 200/sqrt(13)
  // 125 + 50 - 55.47... = 119.52...
  let rounded = float.round(energy)
  assert_eq(float.to_string(rounded), "120.0")
}

// --- Multi-line type annotation in function ---

fn transform(
  input: String,
  times: Int
) -> String = string.repeat(input, times)

test "multi-line param with type annotations" {
  assert_eq(transform("ab", 3), "ababab")
}
