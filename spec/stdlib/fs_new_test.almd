test "fs.temp_dir" {
  let tmp = fs.temp_dir()
  assert(string.len(tmp) > 0)
}

test "fs.file_size" {
  let path = fs.temp_dir() ++ "/almide_fs_size_test.txt"
  fs.write(path, "hello")
  let size = fs.file_size(path)
  assert_eq(size, 5)
  fs.remove(path)
}

test "fs.remove_all" {
  let dir = fs.temp_dir() ++ "/almide_rm_all_test"
  fs.mkdir_p(dir ++ "/sub")
  fs.write(dir ++ "/sub/f.txt", "x")
  fs.remove_all(dir)
  assert_eq(fs.exists(dir), false)
}
