// bytes cursor family — immutable position-threaded reads.
// Each read returns (next_pos, Option[T]); EOF returns (pos, none).

test "skip clamps to len" {
  let b = bytes.new(8)
  assert_eq(bytes.skip(b, 0, 4), 4)
  assert_eq(bytes.skip(b, 6, 5), 8)
  assert_eq(bytes.skip(b, 8, 1), 8)
}

test "eof detection" {
  let b = bytes.new(4)
  assert_eq(bytes.eof(b, 0), false)
  assert_eq(bytes.eof(b, 4), true)
  assert_eq(bytes.eof(b, 5), true)
}

test "read_u8_at advances and returns Some when in-range" {
  var b = bytes.new(0)
  bytes.append_u8(b, 0xAA)
  bytes.append_u8(b, 0xBB)
  let (p1, v1) = bytes.read_u8_at(b, 0)
  assert_eq(p1, 1)
  assert_eq(v1 |> option.unwrap_or(0), 0xAA)
  let (p2, v2) = bytes.read_u8_at(b, p1)
  assert_eq(p2, 2)
  assert_eq(v2 |> option.unwrap_or(0), 0xBB)
}

test "read_u8_at returns none at EOF without advancing" {
  let b = bytes.new(1)
  let (p, v) = bytes.read_u8_at(b, 1)
  assert_eq(p, 1)
  assert(option.is_none(v), "expected none at eof")
}

test "chained u32 reads via cursor pattern" {
  var b = bytes.new(0)
  bytes.append_u32_le(b, 100)
  bytes.append_u32_le(b, 200)
  bytes.append_u32_le(b, 300)
  let (p1, a) = bytes.read_u32_le_at(b, 0)
  let (p2, c) = bytes.read_u32_le_at(b, p1)
  let (p3, _e) = bytes.read_u32_le_at(b, p2)
  assert_eq(p1, 4)
  assert_eq(p2, 8)
  assert_eq(p3, 12)
  assert_eq(a |> option.unwrap_or(0), 100)
  assert_eq(c |> option.unwrap_or(0), 200)
}

test "read_f64_le_at round-trip" {
  var b = bytes.new(0)
  bytes.append_f64_le(b, 1.5)
  bytes.append_f64_le(b, -2.25)
  let (p1, x) = bytes.read_f64_le_at(b, 0)
  let (p2, y) = bytes.read_f64_le_at(b, p1)
  assert_eq(p1, 8)
  assert_eq(p2, 16)
  assert_eq(x |> option.unwrap_or(0.0), 1.5)
  assert_eq(y |> option.unwrap_or(0.0), -2.25)
}

test "read_u32_be_at" {
  var b = bytes.new(0)
  bytes.append_u32_be(b, 0x01020304)
  let (p, v) = bytes.read_u32_be_at(b, 0)
  assert_eq(p, 4)
  assert_eq(v |> option.unwrap_or(0), 0x01020304)
}

test "take_at copies n bytes" {
  var b = bytes.new(0)
  bytes.append_u8(b, 1)
  bytes.append_u8(b, 2)
  bytes.append_u8(b, 3)
  bytes.append_u8(b, 4)
  let (p, slice) = bytes.take_at(b, 1, 2)
  assert_eq(p, 3)
  let s = slice |> option.unwrap_or(bytes.new(0))
  assert_eq(bytes.len(s), 2)
  assert_eq(bytes.read_u8(s, 0), 2)
  assert_eq(bytes.read_u8(s, 1), 3)
}

test "take_at returns none when not enough bytes" {
  let b = bytes.new(2)
  let (p, slice) = bytes.take_at(b, 1, 5)
  assert_eq(p, 1)
  assert(option.is_none(slice), "expected none")
}

// ── New _at scalars (u16_be, i16_le, i16_be) — completes le/be symmetry ──

test "read_u16_be_at advances and is big-endian" {
  var b = bytes.new(0)
  bytes.append_u16_be(b, 0x1234)
  let (p, v) = bytes.read_u16_be_at(b, 0)
  assert_eq(p, 2)
  assert_eq(v |> option.unwrap_or(0), 0x1234)
}

test "read_u16_be_at none at EOF without advancing" {
  let b = bytes.new(1)
  let (p, v) = bytes.read_u16_be_at(b, 0)
  assert_eq(p, 0)
  assert(option.is_none(v), "expected none at partial eof")
}

test "read_i16_le_at sign-extends negatives" {
  var b = bytes.new(0)
  bytes.append_i16_le(b, -1)
  let (p, v) = bytes.read_i16_le_at(b, 0)
  assert_eq(p, 2)
  assert_eq(v |> option.unwrap_or(0), -1)
}

test "read_i16_be_at sign-extends negatives" {
  var b = bytes.new(0)
  bytes.append_i16_be(b, -42)
  let (p, v) = bytes.read_i16_be_at(b, 0)
  assert_eq(p, 2)
  assert_eq(v |> option.unwrap_or(0), -42)
}

// ── read_bool_at / read_f16_le_at / read_string_be_at ──

test "read_bool_at advances and returns Some" {
  var b = bytes.new(0)
  bytes.append_u8(b, 1)
  bytes.append_u8(b, 0)
  let (p1, v1) = bytes.read_bool_at(b, 0)
  assert_eq(p1, 1)
  assert_eq(v1 |> option.unwrap_or(false), true)
  let (p2, v2) = bytes.read_bool_at(b, p1)
  assert_eq(p2, 2)
  assert_eq(v2 |> option.unwrap_or(true), false)
}

test "read_bool_at none at EOF" {
  let b = bytes.new(0)
  let (p, v) = bytes.read_bool_at(b, 0)
  assert_eq(p, 0)
  assert(option.is_none(v), "expected none at empty buf")
}

test "read_f16_le_at advances by 2 and decodes half" {
  // 0x3C00 = 1.0 in IEEE-754 half. LE bytes = 00 3C.
  var b = bytes.new(0)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x3C)
  let (p, v) = bytes.read_f16_le_at(b, 0)
  assert_eq(p, 2)
  assert_eq(v |> option.unwrap_or(0.0), 1.0)
}

test "read_f16_le_at none at partial EOF" {
  let b = bytes.new(1)
  let (p, v) = bytes.read_f16_le_at(b, 0)
  assert_eq(p, 0)
  assert(option.is_none(v), "expected none at partial eof")
}

test "read_string_be_at decodes u32 BE prefix + body" {
  // slen = 3, body = "hey" (0x68 0x65 0x79)
  var b = bytes.new(0)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x03)
  bytes.append_u8(b, 0x68)
  bytes.append_u8(b, 0x65)
  bytes.append_u8(b, 0x79)
  let (p, v) = bytes.read_string_be_at(b, 0)
  assert_eq(p, 7)
  assert_eq(v |> option.unwrap_or(""), "hey")
}

test "read_string_be_at none when prefix runs off" {
  let b = bytes.new(3)
  let (p, v) = bytes.read_string_be_at(b, 0)
  assert_eq(p, 0)
  assert(option.is_none(v), "expected none at short prefix")
}

test "read_string_be_at none when body runs off" {
  // prefix says 10 bytes but only 2 follow
  var b = bytes.new(0)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x00)
  bytes.append_u8(b, 0x0A)
  bytes.append_u8(b, 0x61)
  bytes.append_u8(b, 0x62)
  let (p, v) = bytes.read_string_be_at(b, 0)
  assert_eq(p, 0)
  assert(option.is_none(v), "expected none at short body")
}

