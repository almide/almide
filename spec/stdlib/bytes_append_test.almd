// bytes.append_*_le — symmetric appenders for all integer/float widths.

test "append_u8 builds a single byte" {
  var b = bytes.new(0)
  bytes.append_u8(b, 0x42)
  assert_eq(bytes.len(b), 1)
  assert_eq(bytes.read_u8(b, 0), 0x42)
}

test "append_u16_le writes 2 bytes little-endian" {
  var b = bytes.new(0)
  bytes.append_u16_le(b, 0xABCD)
  assert_eq(bytes.len(b), 2)
  assert_eq(bytes.read_u16_le(b, 0), 0xABCD)
}

test "append_u32_le writes 4 bytes" {
  var b = bytes.new(0)
  bytes.append_u32_le(b, 0xDEADBEEF)
  assert_eq(bytes.len(b), 4)
  assert_eq(bytes.read_u32_le(b, 0), 0xDEADBEEF)
}

test "append_i32_le round-trip" {
  var b = bytes.new(0)
  bytes.append_i32_le(b, -1)
  bytes.append_i32_le(b, 2147483647)
  assert_eq(bytes.len(b), 8)
  assert_eq(bytes.read_i32_le(b, 0), -1)
  assert_eq(bytes.read_i32_le(b, 4), 2147483647)
}

test "append_i64_le round-trip" {
  var b = bytes.new(0)
  bytes.append_i64_le(b, -42)
  assert_eq(bytes.len(b), 8)
  assert_eq(bytes.read_i64_le(b, 0), -42)
}

test "append_f32_le round-trip via f64" {
  var b = bytes.new(0)
  bytes.append_f32_le(b, 1.5)
  bytes.append_f32_le(b, -0.25)
  assert_eq(bytes.len(b), 8)
  assert_eq(bytes.read_f32_le(b, 0), 1.5)
  assert_eq(bytes.read_f32_le(b, 4), -0.25)
}

test "append_f64_le round-trip" {
  var b = bytes.new(0)
  bytes.append_f64_le(b, 3.14159265358979)
  assert_eq(bytes.len(b), 8)
  assert_eq(bytes.read_f64_le(b, 0), 3.14159265358979)
}

test "interleaved appends accumulate length" {
  var b = bytes.new(0)
  bytes.append_u8(b, 1)
  bytes.append_u32_le(b, 2)
  bytes.append_f64_le(b, 3.0)
  assert_eq(bytes.len(b), 1 + 4 + 8)
  assert_eq(bytes.read_u8(b, 0), 1)
  assert_eq(bytes.read_u32_le(b, 1), 2)
  assert_eq(bytes.read_f64_le(b, 5), 3.0)
}
