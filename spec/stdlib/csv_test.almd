// Test aspects derived from: Python csv (PSF), Go encoding/csv (BSD-3),
//   Rust csv crate (MIT), PapaParse (MIT)
// No source code was copied. Tests independently written based on
// observed behavioral patterns across reference implementations.

import csv
import list

fn main() -> Unit = {
  // === parse: basics ===
  let rows = csv.parse("a,b,c\n1,2,3")
  assert_eq(list.len(rows), 2)
  assert_eq(list.get(rows, 0), some(["a", "b", "c"]))
  assert_eq(list.get(rows, 1), some(["1", "2", "3"]))

  // single row
  let single = csv.parse("x,y,z")
  assert_eq(list.len(single), 1)
  assert_eq(list.get(single, 0), some(["x", "y", "z"]))

  // single column
  let col = csv.parse("a\nb\nc")
  assert_eq(list.len(col), 3)
  assert_eq(list.get(col, 0), some(["a"]))

  // single field
  let one = csv.parse("hello")
  assert_eq(list.len(one), 1)
  assert_eq(list.get(one, 0), some(["hello"]))

  // === parse: quoting ===
  // quoted field
  let q1 = csv.parse("\"hello\",world")
  assert_eq(list.get(q1, 0), some(["hello", "world"]))

  // quoted field containing comma
  let q2 = csv.parse("\"hello, world\",b")
  assert_eq(list.get(q2, 0), some(["hello, world", "b"]))

  // quoted field containing newline
  let q3 = csv.parse("\"line1\nline2\",b")
  assert_eq(list.len(q3), 1)
  assert_eq(list.get(q3, 0), some(["line1\nline2", "b"]))

  // escaped quote (doubled)
  let q4 = csv.parse("\"say \"\"hi\"\"\",b")
  assert_eq(list.get(q4, 0), some(["say \"hi\"", "b"]))

  // quoted empty field
  let q5 = csv.parse("\"\",b")
  assert_eq(list.get(q5, 0), some(["", "b"]))

  // === parse: empty / edge cases ===
  // empty input
  let empty = csv.parse("")
  assert_eq(list.len(empty), 0)

  // empty fields
  let ef = csv.parse("a,,b")
  assert_eq(list.get(ef, 0), some(["a", "", "b"]))

  // trailing comma (produces empty final field)
  let tc = csv.parse("a,b,")
  assert_eq(list.get(tc, 0), some(["a", "b", ""]))

  // trailing newline (no phantom row)
  let tn = csv.parse("a,b\n")
  assert_eq(list.len(tn), 1)

  // multiple trailing newlines
  let mtn = csv.parse("a,b\n\n")
  assert_eq(list.len(mtn), 1)

  // only newlines
  let nl = csv.parse("\n\n")
  assert_eq(list.len(nl), 0)

  // CRLF line endings
  let crlf = csv.parse("a,b\r\nc,d")
  assert_eq(list.len(crlf), 2)
  assert_eq(list.get(crlf, 0), some(["a", "b"]))

  // === parse: whitespace ===
  // leading/trailing whitespace preserved
  let ws = csv.parse(" a , b ")
  assert_eq(list.get(ws, 0), some([" a ", " b "]))

  // === parse_with_header ===
  let hdr = csv.parse_with_header("name,age\nAlice,30\nBob,25")
  assert_eq(list.len(hdr), 2)

  // first row fields accessible by header key
  let first = match list.get(hdr, 0) {
    some(row) => row,
    none => map.new(),
  }
  assert_eq(map.get(first, "name"), some("Alice"))
  assert_eq(map.get(first, "age"), some("30"))

  // second row
  let second = match list.get(hdr, 1) {
    some(row) => row,
    none => map.new(),
  }
  assert_eq(map.get(second, "name"), some("Bob"))

  // header only (no data rows)
  let hdr_only = csv.parse_with_header("name,age")
  assert_eq(list.len(hdr_only), 0)

  // === stringify: basics ===
  let s1 = csv.stringify([["a", "b", "c"], ["1", "2", "3"]])
  assert_eq(s1, "a,b,c\n1,2,3\n")

  // single row
  let s2 = csv.stringify([["x", "y"]])
  assert_eq(s2, "x,y\n")

  // empty input
  let s3 = csv.stringify([])
  assert_eq(s3, "")

  // === stringify: quoting ===
  // field containing comma gets quoted
  let sq1 = csv.stringify([["hello, world", "b"]])
  assert_eq(sq1, "\"hello, world\",b\n")

  // field containing newline gets quoted
  let sq2 = csv.stringify([["line1\nline2", "b"]])
  assert_eq(sq2, "\"line1\nline2\",b\n")

  // field containing quote gets quoted and escaped
  let sq3 = csv.stringify([["say \"hi\"", "b"]])
  assert_eq(sq3, "\"say \"\"hi\"\"\",b\n")

  // empty field (not quoted)
  let sq4 = csv.stringify([["", "b"]])
  assert_eq(sq4, ",b\n")

  // === stringify: roundtrip ===
  let original = "name,value\n\"hello, world\",42\n\"line1\nline2\",ok\n"
  let parsed = csv.parse(original)
  let result = csv.stringify(parsed)
  let reparsed = csv.parse(result)
  let expected = csv.parse(original)
  assert_eq(list.len(expected), list.len(reparsed))
  assert_eq(list.get(expected, 0), list.get(reparsed, 0))
  assert_eq(list.get(expected, 1), list.get(reparsed, 1))
  assert_eq(list.get(expected, 2), list.get(reparsed, 2))

  println("csv: all tests passed")
}
