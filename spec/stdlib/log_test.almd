test "log.info outputs message" {
  log.info("test message")
}

test "log.debug outputs message" {
  log.debug("debug info")
}

test "log.warn outputs message" {
  log.warn("warning here")
}

test "log.error outputs message" {
  log.error("error occurred")
}

test "log.info_with outputs fields" {
  log.info_with("user action", [("user", "alice"), ("action", "login")])
}
