// wasm:skip — fs.stat is native-only
import fs

test "fs.stat returns tuple for existing file" {
  // Create a temp file with known content
  let tmp = fs.temp_dir() + "/almide-stat-test.txt"
  fs.write(tmp, "hello")!
  let (size, is_dir, is_file, _modified) = fs.stat(tmp)!
  assert_eq(size, 5)
  assert_eq(is_dir, false)
  assert_eq(is_file, true)
  fs.remove(tmp)!
}

test "fs.stat returns tuple for directory" {
  let tmp = fs.temp_dir()
  let (_size, is_dir, is_file, _modified) = fs.stat(tmp)!
  assert_eq(is_dir, true)
  assert_eq(is_file, false)
}

test "fs.stat on nonexistent path returns err" {
  let r = fs.stat("/nonexistent/path/xyz/12345")
  match r {
    ok(_) => assert(false)
    err(msg) => assert(string.len(msg) > 0)
  }
}
