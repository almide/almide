// Comprehensive list module tests

// ── len ──

test "list.len empty" {
  let xs: List[Int] = []
  assert_eq(list.len(xs), 0)
}

test "list.len many" {
  assert_eq(list.len([1, 2, 3, 4, 5]), 5)
}

// ── get ──

test "list.get first" {
  assert_eq(list.get([10, 20, 30], 0), some(10))
}

test "list.get last" {
  assert_eq(list.get([10, 20, 30], 2), some(30))
}

test "list.get out of bounds" {
  assert_eq(list.get([10, 20], 5), none)
}

test "list.get negative index" {
  assert_eq(list.get([10, 20], -1), none)
}

// ── get_or ──

test "list.get_or present" {
  assert_eq(list.get_or([1, 2, 3], 1, 99), 2)
}

test "list.get_or absent" {
  assert_eq(list.get_or([1, 2, 3], 10, 99), 99)
}

// ── set ──

test "list.set replaces value" {
  assert_eq(list.set([1, 2, 3], 1, 99), [1, 99, 3])
}

test "list.set first element" {
  assert_eq(list.set([10, 20, 30], 0, 0), [0, 20, 30])
}

test "list.set last element" {
  assert_eq(list.set([10, 20, 30], 2, 0), [10, 20, 0])
}

// ── swap ──

test "list.swap basic" {
  assert_eq(list.swap([1, 2, 3], 0, 2), [3, 2, 1])
}

test "list.swap same index" {
  assert_eq(list.swap([1, 2, 3], 1, 1), [1, 2, 3])
}

test "list.swap adjacent" {
  assert_eq(list.swap(["a", "b", "c"], 0, 1), ["b", "a", "c"])
}

// ── sort ──

test "list.sort already sorted" {
  assert_eq(list.sort([1, 2, 3]), [1, 2, 3])
}

test "list.sort reversed" {
  assert_eq(list.sort([3, 2, 1]), [1, 2, 3])
}

test "list.sort with duplicates" {
  assert_eq(list.sort([3, 1, 2, 1, 3]), [1, 1, 2, 3, 3])
}

test "list.sort single" {
  assert_eq(list.sort([42]), [42])
}

test "list.sort strings" {
  assert_eq(list.sort(["banana", "apple", "cherry"]), ["apple", "banana", "cherry"])
}

// ── reverse ──

test "list.reverse empty" {
  let xs: List[Int] = []
  assert_eq(list.reverse(xs), [])
}

test "list.reverse two elements" {
  assert_eq(list.reverse([1, 2]), [2, 1])
}

// ── contains ──

test "list.contains with strings" {
  assert(list.contains(["a", "b", "c"], "b"))
  assert(not list.contains(["a", "b", "c"], "d"))
}

// ── enumerate ──

test "list.enumerate length matches" {
  let xs = [10, 20, 30]
  let en = list.enumerate(xs)
  assert_eq(list.len(en), 3)
}

test "list.enumerate empty" {
  let xs: List[Int] = []
  assert_eq(list.len(list.enumerate(xs)), 0)
}

// ── zip ──

test "list.zip equal lengths" {
  let result = list.zip([1, 2], ["a", "b"])
  assert_eq(list.len(result), 2)
}

test "list.zip empty" {
  let xs: List[Int] = []
  let ys: List[String] = []
  assert_eq(list.len(list.zip(xs, ys)), 0)
}

// ── flatten ──

test "list.flatten nested" {
  assert_eq(list.flatten([[1], [2, 3], [4, 5, 6]]), [1, 2, 3, 4, 5, 6])
}

test "list.flatten single list" {
  assert_eq(list.flatten([[1, 2, 3]]), [1, 2, 3])
}

// ── take / drop ──

test "list.take zero" {
  assert_eq(list.take([1, 2, 3], 0), [])
}

test "list.take exact" {
  assert_eq(list.take([1, 2, 3], 3), [1, 2, 3])
}

test "list.drop zero" {
  assert_eq(list.drop([1, 2, 3], 0), [1, 2, 3])
}

test "list.drop exact" {
  assert_eq(list.drop([1, 2, 3], 3), [])
}

// ── unique ──

test "list.unique all same" {
  assert_eq(list.unique([1, 1, 1, 1]), [1])
}

test "list.unique no duplicates" {
  assert_eq(list.unique([1, 2, 3]), [1, 2, 3])
}

// ── index_of ──

test "list.index_of first" {
  assert_eq(list.index_of([5, 10, 15], 5), some(0))
}

test "list.index_of not found" {
  assert_eq(list.index_of([5, 10, 15], 99), none)
}

test "list.index_of with strings" {
  assert_eq(list.index_of(["x", "y", "z"], "z"), some(2))
}

// ── last ──

test "list.last single" {
  assert_eq(list.last([42]), some(42))
}

test "list.last multiple" {
  assert_eq(list.last([1, 2, 3]), some(3))
}

// ── chunk ──

test "list.chunk evenly" {
  assert_eq(list.chunk([1, 2, 3, 4], 2), [[1, 2], [3, 4]])
}

test "list.chunk single" {
  assert_eq(list.chunk([1, 2, 3], 1), [[1], [2], [3]])
}

test "list.chunk larger than list" {
  assert_eq(list.chunk([1, 2], 5), [[1, 2]])
}

// ── sum / product ──

test "list.sum positive and negative" {
  assert_eq(list.sum([1, -1, 2, -2, 3]), 3)
}

test "list.product with zero" {
  assert_eq(list.product([1, 2, 0, 4]), 0)
}

test "list.product single" {
  assert_eq(list.product([7]), 7)
}

// ── first ──

test "list.first of two" {
  assert_eq(list.first([99, 1]), some(99))
}

// ── is_empty? ──

test "list.is_empty? via UFCS" {
  let xs: List[Int] = []
  assert(xs.is_empty?())
  assert(not [1].is_empty?())
}

// ── min / max ──

test "list.min single element" {
  assert_eq(list.min([42]), some(42))
}

test "list.max single element" {
  assert_eq(list.max([42]), some(42))
}

test "list.min with negatives" {
  assert_eq(list.min([-3, -1, -2]), some(-3))
}

test "list.max with negatives" {
  assert_eq(list.max([-3, -1, -2]), some(-1))
}

// ── join ──

test "list.join with empty separator" {
  assert_eq(list.join(["a", "b", "c"], ""), "abc")
}

test "list.join single" {
  assert_eq(list.join(["hello"], " "), "hello")
}

// ── map ──

test "list.map to strings" {
  assert_eq(list.map([1, 2, 3], (x) => int.to_string(x)), ["1", "2", "3"])
}

test "list.map empty" {
  let xs: List[Int] = []
  assert_eq(list.map(xs, (x) => x * 2), [])
}

// ── filter ──

test "list.filter none pass" {
  assert_eq(list.filter([1, 2, 3], (x) => x > 10), [])
}

test "list.filter all pass" {
  assert_eq(list.filter([1, 2, 3], (x) => x > 0), [1, 2, 3])
}

// ── find ──

test "list.find first match" {
  assert_eq(list.find([1, 2, 3, 4], (x) => x > 2), some(3))
}

test "list.find no match" {
  assert_eq(list.find([1, 2, 3], (x) => x > 10), none)
}

// ── any / all ──

test "list.any empty" {
  let xs: List[Int] = []
  assert(not list.any(xs, (x) => x > 0))
}

test "list.all empty" {
  let xs: List[Int] = []
  assert(list.all(xs, (x) => x > 0))
}

test "list.any single true" {
  assert(list.any([1], (x) => x == 1))
}

test "list.all single false" {
  assert(not list.all([1], (x) => x == 2))
}

// ── sort_by ──

test "list.sort_by numeric key" {
  let result = list.sort_by([3, 1, 2], (x) => x)
  assert_eq(result, [1, 2, 3])
}

test "list.sort_by reverse by negation" {
  let result = list.sort_by([1, 2, 3], (x) => 0 - x)
  assert_eq(result, [3, 2, 1])
}

// ── flat_map ──

test "list.flat_map empty result" {
  let xs: List[Int] = []
  let result = list.flat_map(xs, (x) => [x, x])
  assert_eq(result, [])
}

test "list.flat_map tripling" {
  assert_eq(list.flat_map([1, 2], (x) => [x, x, x]), [1, 1, 1, 2, 2, 2])
}

// ── filter_map ──

test "list.filter_map all none" {
  let xs = [1, 2, 3]
  let result = list.filter_map(xs, (x) => if x > 10 then some(x) else none)
  assert_eq(result, [])
}

test "list.filter_map all some" {
  let xs = [1, 2, 3]
  let result = list.filter_map(xs, (x) => some(x * 10))
  assert_eq(result, [10, 20, 30])
}

// ── take_while / drop_while ──

test "list.take_while all" {
  assert_eq(list.take_while([1, 2, 3], (x) => x < 10), [1, 2, 3])
}

test "list.take_while none" {
  assert_eq(list.take_while([1, 2, 3], (x) => x < 0), [])
}

test "list.drop_while all" {
  assert_eq(list.drop_while([1, 2, 3], (x) => x < 10), [])
}

test "list.drop_while none" {
  assert_eq(list.drop_while([1, 2, 3], (x) => x < 0), [1, 2, 3])
}

// ── count ──

test "list.count none match" {
  assert_eq(list.count([1, 2, 3], (x) => x > 10), 0)
}

test "list.count all match" {
  assert_eq(list.count([1, 2, 3], (x) => x > 0), 3)
}

// ── partition ──

test "list.partition all left" {
  let result = list.partition([2, 4, 6], (x) => x % 2 == 0)
  assert_eq(result.0, [2, 4, 6])
  assert_eq(result.1, [])
}

test "list.partition all right" {
  let result = list.partition([1, 3, 5], (x) => x % 2 == 0)
  assert_eq(result.0, [])
  assert_eq(result.1, [1, 3, 5])
}

// ── reduce ──

test "list.reduce empty" {
  let xs: List[Int] = []
  assert_eq(list.reduce(xs, (a, b) => a + b), none)
}

test "list.reduce single" {
  assert_eq(list.reduce([42], (a, b) => a + b), some(42))
}

test "list.reduce multiply" {
  assert_eq(list.reduce([1, 2, 3, 4], (a, b) => a * b), some(24))
}

// ── group_by ──

test "list.group_by string length" {
  let groups = list.group_by(["a", "bb", "c", "dd", "e"], (s) => string.len(s))
  let ones = map.get_or(groups, 1, [])
  let twos = map.get_or(groups, 2, [])
  assert_eq(ones, ["a", "c", "e"])
  assert_eq(twos, ["bb", "dd"])
}

// ── slice ──

test "list.slice middle" {
  assert_eq(list.slice([10, 20, 30, 40, 50], 1, 4), [20, 30, 40])
}

test "list.slice full" {
  assert_eq(list.slice([1, 2, 3], 0, 3), [1, 2, 3])
}

// ── insert ──

test "list.insert middle" {
  assert_eq(list.insert([1, 3], 1, 2), [1, 2, 3])
}

test "list.insert at end" {
  assert_eq(list.insert([1, 2], 2, 3), [1, 2, 3])
}

// ── remove_at ──

test "list.remove_at first" {
  assert_eq(list.remove_at([1, 2, 3], 0), [2, 3])
}

test "list.remove_at last" {
  assert_eq(list.remove_at([1, 2, 3], 2), [1, 2])
}

// ── find_index ──

test "list.find_index found" {
  assert_eq(list.find_index([10, 20, 30], (x) => x == 20), some(1))
}

test "list.find_index not found" {
  assert_eq(list.find_index([10, 20, 30], (x) => x == 99), none)
}

// ── update ──

test "list.update transform" {
  assert_eq(list.update([1, 2, 3], 1, (x) => x * 10), [1, 20, 3])
}

// ── repeat ──

test "list.repeat strings" {
  assert_eq(list.repeat("hi", 3), ["hi", "hi", "hi"])
}

test "list.repeat zero" {
  assert_eq(list.repeat(1, 0), [])
}

// ── scan ──

test "list.scan running product" {
  assert_eq(list.scan([1, 2, 3, 4], 1, (acc, x) => acc * x), [1, 2, 6, 24])
}

test "list.scan empty" {
  let xs: List[Int] = []
  assert_eq(list.scan(xs, 0, (acc, x) => acc + x), [])
}

// ── intersperse ──

test "list.intersperse strings" {
  assert_eq(list.intersperse(["a", "b", "c"], ","), ["a", ",", "b", ",", "c"])
}

test "list.intersperse two" {
  assert_eq(list.intersperse([1, 2], 0), [1, 0, 2])
}

// ── windows ──

test "list.windows size 3" {
  assert_eq(list.windows([1, 2, 3, 4, 5], 3), [[1, 2, 3], [2, 3, 4], [3, 4, 5]])
}

test "list.windows size 1" {
  assert_eq(list.windows([1, 2, 3], 1), [[1], [2], [3]])
}

// ── dedup ──

test "list.dedup all same" {
  assert_eq(list.dedup([5, 5, 5, 5]), [5])
}

test "list.dedup alternating" {
  assert_eq(list.dedup([1, 2, 1, 2]), [1, 2, 1, 2])
}

// ── zip_with ──

test "list.zip_with multiply" {
  assert_eq(list.zip_with([1, 2, 3], [4, 5, 6], (a, b) => a * b), [4, 10, 18])
}

test "list.zip_with concat strings" {
  assert_eq(list.zip_with(["a", "b"], ["1", "2"], (a, b) => a ++ b), ["a1", "b2"])
}

// ── fold ──

test "list.fold build string" {
  let result = list.fold([1, 2, 3], "", (acc, x) => acc ++ int.to_string(x))
  assert_eq(result, "123")
}

test "list.fold empty" {
  let xs: List[Int] = []
  assert_eq(list.fold(xs, 0, (acc, x) => acc + x), 0)
}

// ── UFCS ──

test "list UFCS map" {
  assert_eq([1, 2, 3].map((x) => x + 1), [2, 3, 4])
}

test "list UFCS filter" {
  assert_eq([1, 2, 3, 4].filter((x) => x > 2), [3, 4])
}

test "list UFCS sort" {
  assert_eq([3, 1, 2].sort(), [1, 2, 3])
}

test "list UFCS reverse" {
  assert_eq([1, 2, 3].reverse(), [3, 2, 1])
}

test "list UFCS contains" {
  assert([1, 2, 3].contains(2))
}

test "list UFCS flatten" {
  assert_eq([[1, 2], [3]].flatten(), [1, 2, 3])
}

test "list UFCS len" {
  assert_eq([1, 2, 3, 4, 5].len(), 5)
}

test "list UFCS last" {
  assert_eq([1, 2, 3].last(), some(3))
}

test "list UFCS sum" {
  assert_eq([1, 2, 3].sum(), 6)
}

test "list UFCS join" {
  assert_eq(["a", "b"].join("-"), "a-b")
}
