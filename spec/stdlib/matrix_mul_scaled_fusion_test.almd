// MatrixFusionPass: `mul(a, scale(b, s))` and `mul(scale(a, s), b)`
// → `mul_scaled(a, s, b)`. Both produce `s * (a @ b)` at the BLAS level,
// so we can verify fusion correctness by comparing against the unfused
// computation path.

fn approx_eq(a: Float, b: Float, tol: Float) -> Bool = {
  let d = if a > b then a - b else b - a
  d < tol
}

test "mul(a, scale(b, s)) == mul_scaled: nested form" {
  let a = matrix.ones(3, 3)
  let b = matrix.ones(3, 3)

  let expected = matrix.mul_scaled(a, 0.5, b)
  let actual = matrix.mul(a, matrix.scale(b, 0.5))

  // Each element of ones(3,3) @ ones(3,3) = 3, scaled by 0.5 → 1.5
  assert(approx_eq(matrix.get(expected, 0, 0), 1.5, 0.00001))
  assert(approx_eq(matrix.get(actual, 0, 0), 1.5, 0.00001))
  assert(approx_eq(matrix.get(actual, 2, 2), 1.5, 0.00001))
}

test "mul(scale(a, s), b) == mul_scaled: lhs-scale nested form" {
  let a = matrix.ones(3, 3)
  let b = matrix.ones(3, 3)
  let actual = matrix.mul(matrix.scale(a, 0.25), b)
  assert(approx_eq(matrix.get(actual, 1, 1), 0.75, 0.00001))
}

test "let-split mul(a, scale(b, s)) fuses" {
  let a = matrix.ones(4, 4)
  let b = matrix.ones(4, 4)
  let b_s = matrix.scale(b, 0.1)
  let c = matrix.mul(a, b_s)
  // 4 * 1 * 0.1 = 0.4
  assert(approx_eq(matrix.get(c, 0, 0), 0.4, 0.00001))
}

test "let-split skipped when scaled input is reused" {
  let a = matrix.ones(3, 3)
  let b = matrix.ones(3, 3)
  let b_s = matrix.scale(b, 0.5)
  let c = matrix.mul(a, b_s)
  // Extra reference prevents fusion — c should still be correct.
  let external = matrix.get(b_s, 0, 0)
  assert_eq(external, 0.5)
  assert(approx_eq(matrix.get(c, 0, 0), 1.5, 0.00001))
}
