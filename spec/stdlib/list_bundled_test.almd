// Regression guard: bundled-Almide stdlib dispatch.
// list.bundled_probe / split_at are defined in stdlib/list.almd with no
// TOML/Rust runtime. If any of these fail, the codegen rt_ bypass is
// broken on Rust or WASM — see docs/roadmap/done/bundled-almide-dispatch.md.

test "list.bundled_probe (bundled-Almide dispatch smoke)" {
  assert_eq(list.bundled_probe(41), 42)
}

test "list.split_at (bundled fn calling TOML fns)" {
  let xs = [1, 2, 3, 4, 5]
  let p = list.split_at(xs, 2)
  let (a, b) = p
  assert_eq(a, [1, 2])
  assert_eq(b, [3, 4, 5])
}

test "list.split_at past end" {
  let xs = [1, 2, 3]
  let p = list.split_at(xs, 10)
  let (a, b) = p
  assert_eq(a, [1, 2, 3])
  assert_eq(b, [])
}

test "list.iterate (pure-Almide recursion)" {
  assert_eq(list.iterate(1, (x) => x * 2, 5), [1, 2, 4, 8, 16])
}

test "list.iterate zero" {
  assert_eq(list.iterate(7, (x) => x + 1, 0), [])
}

test "list.* TOML fns coexist with bundled fns" {
  assert_eq(list.sum([1, 2, 3]), 6)
  assert_eq(list.len([1, 2, 3]), 3)
}
