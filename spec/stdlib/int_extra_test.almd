// int extra tests — deeper coverage of int module

test "int.parse valid positive" {
  assert_eq(int.parse("42"), ok(42))
}

test "int.parse valid negative" {
  assert_eq(int.parse("-100"), ok(-100))
}

test "int.parse invalid string" {
  let r = int.parse("abc")
  let is_err = match r {
    ok(_) => false
    err(_) => true
  }
  assert(is_err)
}

test "int.abs large negative" {
  assert_eq(int.abs(-999999), 999999)
}

test "int.min picks smaller" {
  assert_eq(int.min(3, 7), 3)
  assert_eq(int.min(7, 3), 3)
}

test "int.max picks larger" {
  assert_eq(int.max(3, 7), 7)
  assert_eq(int.max(7, 3), 7)
}

test "int.clamp squeezes into range" {
  assert_eq(int.clamp(-100, 0, 50), 0)
  assert_eq(int.clamp(200, 0, 50), 50)
  assert_eq(int.clamp(25, 0, 50), 25)
}

test "int.to_hex roundtrip" {
  let hex = int.to_hex(255)
  assert_eq(hex, "ff")
  assert_eq(int.from_hex(hex), ok(255))
}

test "int.from_hex mixed case" {
  assert_eq(int.from_hex("Ff"), ok(255))
}

test "int.to_string roundtrip with parse" {
  let s = int.to_string(12345)
  assert_eq(int.parse(s), ok(12345))
}
