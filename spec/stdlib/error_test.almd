
// error_test — Error handling patterns (no error module UFCS due to codegen gaps)
effect fn safe_divide(a: Int, b: Int) -> Result[Int, String] = {
  guard b != 0 else err("division by zero");
  ok(a / b)
}

test "effect fn returns ok" {
  assert_eq(safe_divide(10, 2), ok(5))
}

test "effect fn returns err" {
  assert_eq(safe_divide(10, 0), err("division by zero"))
}

effect fn chain_ops(x: Int) -> Result[String, String] = {
  let n = safe_divide(x, 2);
  ok(int.to_string(n))
}

test "chained effect fn ok" {
  assert_eq(chain_ops(10), ok("5"))
}

test "chained effect fn err propagation" {
  assert_eq(chain_ops(0), ok("0"))
}

test "err string content" {
  let r = safe_divide(1, 0);
  let msg = match r {
    ok(_) => "no error",
    err(e) => e,
  };
  assert_eq(msg, "division by zero")
}

test "guard else err pattern" {
  let r = safe_divide(7, 0);
  let is_err = match r {
    ok(_) => false,
    err(_) => true,
  };
  assert_eq(is_err, true)
}

test "guard else ok pattern" {
  let r = safe_divide(7, 1);
  let is_ok = match r {
    ok(_) => true,
    err(_) => false,
  };
  assert_eq(is_ok, true)
}

effect fn parse_positive(s: String) -> Result[Int, String] = {
  let v = int.parse(s);
  guard v > 0 else err("not positive");
  ok(v)
}

test "nested effect fn ok" {
  assert_eq(parse_positive("42"), ok(42))
}

test "nested effect fn validation err" {
  assert_eq(parse_positive("-5"), err("not positive"))
}
