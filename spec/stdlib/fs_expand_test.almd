import fs
import list

test "fs create_temp_dir" {
  let dir = fs.create_temp_dir("almide_test_")
  assert_eq(fs.is_dir(dir), true)
  fs.remove_all(dir)
}

test "fs create_temp_file" {
  let path = fs.create_temp_file("almide_test_")
  assert_eq(fs.exists(path), true)
  fs.remove(path)
}

test "fs modified_at" {
  let dir = fs.create_temp_dir("almide_mtime_")
  let f = dir ++ "/test.txt"
  fs.write(f, "hello")
  let mtime = fs.modified_at(f)
  assert(mtime > 0)
  fs.remove_all(dir)
}

test "fs is_symlink false for file" {
  let dir = fs.create_temp_dir("almide_sym_")
  let f = dir ++ "/regular.txt"
  fs.write(f, "hello")
  assert_eq(fs.is_symlink(f), false)
  fs.remove_all(dir)
}

test "fs glob matches txt files" {
  let dir = fs.create_temp_dir("almide_glob_")
  fs.write(dir ++ "/a.txt", "hello")
  fs.write(dir ++ "/b.txt", "world")
  fs.write(dir ++ "/c.md", "doc")
  let matches = fs.glob(dir ++ "/*.txt")
  assert_eq(list.len(matches), 2)
  fs.remove_all(dir)
}
