// http response builder tests

test "response creates text response" {
  let resp = http.response(200, "hello")
  assert_eq(http.body(resp), "hello")
}

test "json creates json response" {
  let resp = http.json(200, "{\"ok\":true}")
  assert_eq(http.body(resp), "{\"ok\":true}")
}

test "not_found creates 404 response" {
  let resp = http.not_found("page not found")
  assert_eq(http.body(resp), "page not found")
}

test "redirect creates 302 with Location header" {
  let resp = http.redirect("https://example.com")
  assert_eq(http.get_header(resp, "Location"), some("https://example.com"))
}

test "redirect_permanent creates 301 with Location header" {
  let resp = http.redirect_permanent("https://example.com/new")
  assert_eq(http.get_header(resp, "Location"), some("https://example.com/new"))
}

test "set_header adds header to response" {
  let resp = http.response(200, "ok")
  let resp2 = http.set_header(resp, "X-Custom", "value123")
  assert_eq(http.get_header(resp2, "X-Custom"), some("value123"))
}

test "get_header returns none for missing header" {
  let resp = http.response(200, "ok")
  assert_eq(http.get_header(resp, "X-Missing"), none)
}

test "set_cookie adds Set-Cookie header" {
  let resp = http.response(200, "ok")
  let resp2 = http.set_cookie(resp, "session", "abc123")
  assert_eq(http.get_header(resp2, "Set-Cookie"), some("session=abc123"))
}

test "set_cookie appends multiple cookies" {
  let resp = http.response(200, "ok")
  let resp2 = http.set_cookie(resp, "a", "1")
  let resp3 = http.set_cookie(resp2, "b", "2")
  assert_eq(http.get_header(resp3, "Set-Cookie"), some("a=1, b=2"))
}

test "status changes response status code" {
  let resp = http.response(200, "ok")
  let resp2 = http.status(resp, 201)
  assert_eq(http.body(resp2), "ok")
}
