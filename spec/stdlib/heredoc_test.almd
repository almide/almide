
fn main() -> Unit = {
  // Basic string with newlines
  let sql = "SELECT *\nFROM users\nWHERE id = 1";
  assert_eq(sql, "SELECT *\nFROM users\nWHERE id = 1");
  // String with interpolation
  let name = "Alice";
  let greeting = "Hello, ${name}!\nWelcome.";
  assert_eq(greeting, "Hello, Alice!\nWelcome.");
  // Single-line string
  let single = "hello";
  assert_eq(single, "hello");
  // Empty string
  let empty = "";
  assert_eq(empty, "");
  // Escaped backslashes in strings
  let pattern = "\\d+\\.\\d+";
  assert_eq(pattern, "\\d+\\.\\d+");
  // Single-quote string with double quotes
  let code = 'if x { println("yes") }';
  assert_eq(code, 'if x { println("yes") }');
  println("All string tests passed!")
}
