// float completeness tests — functions not covered elsewhere

test "float.round up" {
  assert_eq(float.round(3.6), 4.0)
}

test "float.round down" {
  assert_eq(float.round(3.4), 3.0)
}

test "float.round half" {
  assert_eq(float.round(2.5), 3.0)
}

test "float.floor basic" {
  assert_eq(float.floor(3.9), 3.0)
}

test "float.floor negative" {
  assert_eq(float.floor(-1.1), -2.0)
}

test "float.floor integer" {
  assert_eq(float.floor(5.0), 5.0)
}

test "float.ceil basic" {
  assert_eq(float.ceil(3.1), 4.0)
}

test "float.ceil negative" {
  assert_eq(float.ceil(-1.9), -1.0)
}

test "float.ceil integer" {
  assert_eq(float.ceil(5.0), 5.0)
}

test "float.abs positive" {
  assert_eq(float.abs(2.5), 2.5)
}

test "float.abs negative" {
  assert_eq(float.abs(-2.5), 2.5)
}

test "float.abs zero" {
  assert_eq(float.abs(0.0), 0.0)
}

test "float.sqrt of 4" {
  assert_eq(float.sqrt(4.0), 2.0)
}

test "float.sqrt of 9" {
  assert_eq(float.sqrt(9.0), 3.0)
}

test "float.sqrt of 1" {
  assert_eq(float.sqrt(1.0), 1.0)
}

test "float.to_int truncates positive" {
  assert_eq(float.to_int(3.9), 3)
}

test "float.to_int truncates negative" {
  assert_eq(float.to_int(-3.9), -3)
}

test "float.to_int zero" {
  assert_eq(float.to_int(0.0), 0)
}

test "float.from_int basic" {
  assert_eq(float.from_int(42), 42.0)
}

test "float.from_int zero" {
  assert_eq(float.from_int(0), 0.0)
}

test "float.from_int negative" {
  assert_eq(float.from_int(-10), -10.0)
}

test "float.min picks smaller" {
  assert_eq(float.min(1.5, 2.5), 1.5)
}

test "float.min equal" {
  assert_eq(float.min(3.0, 3.0), 3.0)
}

test "float.max picks larger" {
  assert_eq(float.max(1.5, 2.5), 2.5)
}

test "float.max equal" {
  assert_eq(float.max(3.0, 3.0), 3.0)
}

test "float.to_fixed two decimals" {
  assert_eq(float.to_fixed(3.14159, 2), "3.14")
}

test "float.to_fixed zero decimals" {
  assert_eq(float.to_fixed(3.7, 0), "4")
}

test "float.to_fixed three decimals" {
  assert_eq(float.to_fixed(1.0, 3), "1.000")
}

test "float.clamp within range" {
  assert_eq(float.clamp(5.0, 0.0, 10.0), 5.0)
}

test "float.clamp below" {
  assert_eq(float.clamp(-5.0, 0.0, 10.0), 0.0)
}

test "float.clamp above" {
  assert_eq(float.clamp(15.0, 0.0, 10.0), 10.0)
}

test "float.sign positive value" {
  assert_eq(float.sign(42.0), 1.0)
}

test "float.sign negative value" {
  assert_eq(float.sign(-42.0), -1.0)
}
