// hex stdlib tests

import hex

test "hex encode lowercase" {
  let b = bytes.from_string("Hi")
  assert_eq(hex.encode(b), "4869")
}

test "hex encode uppercase" {
  let b = bytes.from_string("Hi")
  assert_eq(hex.encode_upper(b), "4869")
}

test "hex decode round-trip" {
  match hex.decode("4869") {
    ok(b) => {
      assert_eq(bytes.len(b), 2)
      assert_eq(bytes.read_u8(b, 0), 0x48)
      assert_eq(bytes.read_u8(b, 1), 0x69)
    }
    err(_) => assert(false)
  }
}

test "hex decode case-insensitive" {
  match hex.decode("DeAdBeEf") {
    ok(b) => {
      assert_eq(bytes.len(b), 4)
      assert_eq(bytes.read_u8(b, 0), 0xDE)
      assert_eq(bytes.read_u8(b, 3), 0xEF)
    }
    err(_) => assert(false)
  }
}

test "hex decode rejects odd length" {
  match hex.decode("4") {
    ok(_) => assert(false)
    err(_) => assert(true)
  }
}

test "hex decode rejects non-hex chars" {
  match hex.decode("4Z") {
    ok(_) => assert(false)
    err(_) => assert(true)
  }
}
