// testing module tests

test "testing.assert_contains passes" {
  testing.assert_contains("hello world", "world")
}

test "testing.assert_approx passes for close values" {
  testing.assert_approx(3.14, 3.14159, 0.01)
}

test "testing.assert_gt passes" {
  testing.assert_gt(10, 5)
}

test "testing.assert_lt passes" {
  testing.assert_lt(3, 7)
}

test "testing.assert_some passes for some" {
  testing.assert_some(some("hello"))
}

test "testing.assert_ok passes for ok" {
  testing.assert_ok(ok("success"))
}
