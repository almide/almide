
module stdlib_e2e

test "string.to_upper" {
  assert_eq(string.to_upper("hello"), "HELLO")
}

test "string.len" {
  assert_eq(string.len("hello"), 5)
}

test "string.contains" {
  assert(string.contains("hello world", "world"))
}

test "list.len" {
  assert_eq(list.len([1, 2, 3]), 3)
}

test "list.map" {
  assert_eq(list.map([1, 2, 3], (x) => x * 2), [2, 4, 6])
}

test "list.filter" {
  assert_eq(list.filter([1, 2, 3, 4], (x) => x > 2), [3, 4])
}

test "list.fold" {
  assert_eq(list.fold([1, 2, 3], 0, (acc, x) => acc + x), 6)
}

test "int.to_string" {
  assert_eq(int.to_string(42), "42")
}

test "UFCS string" {
  assert_eq("hello".to_upper(), "HELLO")
}

test "UFCS list" {
  assert_eq([1, 2, 3].map((x) => x + 10), [11, 12, 13])
}
