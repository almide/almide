
// Comprehensive float module tests
// ── to_string ──
test "float.to_string integer value" {
  let s = float.to_string(3.0);
  assert(string.contains(s, "3"))
}

test "float.to_string decimal" {
  let s = float.to_string(1.5);
  assert(string.contains(s, "1.5"))
}

// ── to_int ──
test "float.to_int truncates down" {
  assert_eq(float.to_int(3.7), 3)
}

test "float.to_int truncates negative" {
  assert_eq(float.to_int(-2.9), -2)
}

test "float.to_int zero" {
  assert_eq(float.to_int(0.0), 0)
}

test "float.to_int exact" {
  assert_eq(float.to_int(5.0), 5)
}

// ── round ──
test "float.round up" {
  assert_eq(float.round(2.7), 3.0)
}

test "float.round down" {
  assert_eq(float.round(2.3), 2.0)
}

test "float.round half" {
  assert_eq(float.round(2.5), 3.0)
}

test "float.round negative" {
  assert_eq(float.round(-1.5), -2.0)
}

// ── floor ──
test "float.floor positive" {
  assert_eq(float.floor(3.9), 3.0)
}

test "float.floor negative" {
  assert_eq(float.floor(-1.1), -2.0)
}

test "float.floor exact" {
  assert_eq(float.floor(5.0), 5.0)
}

// ── ceil ──
test "float.ceil positive" {
  assert_eq(float.ceil(3.1), 4.0)
}

test "float.ceil negative" {
  assert_eq(float.ceil(-1.9), -1.0)
}

test "float.ceil exact" {
  assert_eq(float.ceil(5.0), 5.0)
}

// ── abs ──
test "float.abs positive" {
  assert_eq(float.abs(3.5), 3.5)
}

test "float.abs negative" {
  assert_eq(float.abs(-3.5), 3.5)
}

test "float.abs zero" {
  assert_eq(float.abs(0.0), 0.0)
}

// ── sqrt ──
test "float.sqrt perfect square" {
  assert_eq(float.sqrt(4.0), 2.0)
}

test "float.sqrt one" {
  assert_eq(float.sqrt(1.0), 1.0)
}

test "float.sqrt zero" {
  assert_eq(float.sqrt(0.0), 0.0)
}

test "float.sqrt non-perfect" {
  let s = float.sqrt(2.0);
  assert(s > 1.41 and s < 1.42)
}

// ── from_int ──
test "float.from_int positive" {
  assert_eq(float.from_int(5), 5.0)
}

test "float.from_int zero" {
  assert_eq(float.from_int(0), 0.0)
}

test "float.from_int negative" {
  assert_eq(float.from_int(-10), -10.0)
}

// ── min / max ──
test "float.min basic" {
  assert_eq(float.min(1.0, 2.0), 1.0)
}

test "float.max basic" {
  assert_eq(float.max(1.0, 2.0), 2.0)
}

test "float.min equal" {
  assert_eq(float.min(3.0, 3.0), 3.0)
}

test "float.max equal" {
  assert_eq(float.max(3.0, 3.0), 3.0)
}

test "float.min negative" {
  assert_eq(float.min(-1.0, -2.0), -2.0)
}

test "float.max negative" {
  assert_eq(float.max(-1.0, -2.0), -1.0)
}

// ── to_fixed ──
test "float.to_fixed 0 decimals" {
  assert_eq(float.to_fixed(3.7, 0), "4")
}

test "float.to_fixed 3 decimals" {
  assert_eq(float.to_fixed(1.0, 3), "1.000")
}

test "float.to_fixed pi" {
  assert_eq(float.to_fixed(3.14159, 2), "3.14")
}

// ── clamp ──
test "float.clamp within range" {
  assert_eq(float.clamp(5.0, 0.0, 10.0), 5.0)
}

test "float.clamp below" {
  assert_eq(float.clamp(-1.0, 0.0, 10.0), 0.0)
}

test "float.clamp above" {
  assert_eq(float.clamp(15.0, 0.0, 10.0), 10.0)
}

test "float.clamp at bounds" {
  assert_eq(float.clamp(0.0, 0.0, 1.0), 0.0);
  assert_eq(float.clamp(1.0, 0.0, 1.0), 1.0)
}

// ── UFCS ──
test "float UFCS round" {
  assert_eq(3.7.round(), 4.0)
}

test "float UFCS floor" {
  assert_eq(3.9.floor(), 3.0)
}

test "float UFCS ceil" {
  assert_eq(3.1.ceil(), 4.0)
}

test "float.abs via module call" {
  assert_eq(float.abs(-5.0), 5.0)
}

test "float.sqrt via module call large" {
  assert_eq(float.sqrt(144.0), 12.0)
}

test "float.to_int via module call" {
  assert_eq(float.to_int(7.9), 7)
}
