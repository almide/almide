import url

// ── parse + accessors ──

test "url.parse basic" {
  let u = url.parse("https://example.com/path?q=1#frag")
  assert_eq(url.scheme(u), "https")
  assert_eq(url.host(u), "example.com")
  assert_eq(url.path(u), "/path")
  assert_eq(url.query(u), some("q=1"))
  assert_eq(url.fragment(u), some("frag"))
}

test "url.parse with port" {
  let u = url.parse("http://localhost:8080/api")
  assert_eq(url.scheme(u), "http")
  assert_eq(url.host(u), "localhost")
  assert_eq(url.port(u), some(8080))
  assert_eq(url.path(u), "/api")
}

test "url.parse no path" {
  let u = url.parse("https://example.com")
  assert_eq(url.host(u), "example.com")
  assert_eq(url.path(u), "/")
  assert_eq(url.query(u), none)
  assert_eq(url.fragment(u), none)
}

test "url.parse no port" {
  let u = url.parse("https://example.com/path")
  assert_eq(url.port(u), none)
}

// ── to_string ──

test "url.to_string roundtrip" {
  let u = url.parse("https://example.com/path?q=1#frag")
  assert_eq(url.to_string(u), "https://example.com/path?q=1#frag")
}

test "url.to_string with port" {
  let u = url.parse("http://localhost:3000/api")
  assert_eq(url.to_string(u), "http://localhost:3000/api")
}

// ── query_params ──

test "url.query_params" {
  let u = url.parse("https://example.com?name=alice&age=30")
  let params = url.query_params(u)
  assert_eq(map.get(params, "name"), some("alice"))
  assert_eq(map.get(params, "age"), some("30"))
}

test "url.query_params empty" {
  let u = url.parse("https://example.com/path")
  let params = url.query_params(u)
  assert_eq(map.len(params), 0)
}

// ── set_query_param ──

test "url.set_query_param" {
  let u = url.parse("https://example.com?a=1")
  let u2 = url.set_query_param(u, "b", "2")
  let params = url.query_params(u2)
  assert_eq(map.get(params, "a"), some("1"))
  assert_eq(map.get(params, "b"), some("2"))
}

// ── encode / decode ──

test "url.encode basic" {
  assert_eq(url.encode("hello world"), "hello%20world")
}

test "url.encode preserves unreserved" {
  assert_eq(url.encode("abc-123_test.txt~"), "abc-123_test.txt~")
}

test "url.encode special chars" {
  let encoded = url.encode("a=b&c=d")
  assert(string.contains(encoded, "%3D"))
  assert(string.contains(encoded, "%26"))
}

test "url.decode basic" {
  let decoded = url.decode("hello%20world")
  assert_eq(decoded, "hello world")
}

test "url.decode roundtrip" {
  let original = "hello world!"
  let encoded = url.encode(original)
  let decoded = url.decode(encoded)
  assert_eq(decoded, original)
}
