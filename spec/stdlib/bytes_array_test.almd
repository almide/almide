// bytes.read_*_le_array — bulk readers for typed arrays.

test "read_i32_le_array" {
  var b = bytes.new(0)
  bytes.append_i32_le(b, 1)
  bytes.append_i32_le(b, -2)
  bytes.append_i32_le(b, 3)
  let xs = bytes.read_i32_le_array(b, 0, 3)
  assert_eq(list.len(xs), 3)
  assert_eq(list.get(xs, 0) |> option.unwrap_or(0), 1)
  assert_eq(list.get(xs, 1) |> option.unwrap_or(0), -2)
  assert_eq(list.get(xs, 2) |> option.unwrap_or(0), 3)
}

test "read_u32_le_array zero-extends" {
  var b = bytes.new(0)
  bytes.append_u32_le(b, 0xFFFFFFFF)
  let xs = bytes.read_u32_le_array(b, 0, 1)
  assert_eq(list.get(xs, 0) |> option.unwrap_or(-1), 4294967295)
}

test "read_i64_le_array" {
  var b = bytes.new(0)
  bytes.append_i64_le(b, 100)
  bytes.append_i64_le(b, -200)
  let xs = bytes.read_i64_le_array(b, 0, 2)
  assert_eq(list.len(xs), 2)
  assert_eq(list.get(xs, 0) |> option.unwrap_or(0), 100)
  assert_eq(list.get(xs, 1) |> option.unwrap_or(0), -200)
}

test "read_f64_le_array" {
  var b = bytes.new(0)
  bytes.append_f64_le(b, 1.5)
  bytes.append_f64_le(b, 2.25)
  bytes.append_f64_le(b, -0.125)
  let xs = bytes.read_f64_le_array(b, 0, 3)
  assert_eq(list.len(xs), 3)
  assert_eq(list.get(xs, 0) |> option.unwrap_or(0.0), 1.5)
  assert_eq(list.get(xs, 1) |> option.unwrap_or(0.0), 2.25)
  assert_eq(list.get(xs, 2) |> option.unwrap_or(0.0), -0.125)
}

test "read_f32_le_array" {
  var b = bytes.new(0)
  bytes.append_f32_le(b, 1.5)
  bytes.append_f32_le(b, -0.25)
  let xs = bytes.read_f32_le_array(b, 0, 2)
  assert_eq(list.get(xs, 0) |> option.unwrap_or(0.0), 1.5)
  assert_eq(list.get(xs, 1) |> option.unwrap_or(0.0), -0.25)
}
