// Comprehensive regex module tests
import regex

// ── is_match ──
test "regex.is_match" {
  assert_eq(regex.is_match("[0-9]+", "abc123"), true);
  assert_eq(regex.is_match("hello", "say hello world"), true);
  assert_eq(regex.is_match("[0-9]+", "hello"), false);
  assert_eq(regex.is_match("^hello", "say hello"), false)
}

test "regex.is_match anchored" {
  assert_eq(regex.is_match("^hello", "hello world"), true);
  assert_eq(regex.is_match("world$", "hello world"), true)
}

// ── full_match ──
test "regex.full_match" {
  assert_eq(regex.full_match("[0-9]+", "123"), true);
  assert_eq(regex.full_match("[0-9]+", "abc123"), false);
  assert_eq(regex.full_match("", ""), true)
}

// ── find ──
test "regex.find match" {
  assert_eq(regex.find("[0-9]+", "abc123def456"), some("123"));
  assert_eq(regex.find("[a-z]+", "123abc456"), some("abc"))
}

test "regex.find no match" {
  assert_eq(regex.find("[0-9]+", "hello"), none)
}

// ── find_all ──
test "regex.find_all multiple" {
  assert_eq(regex.find_all("[0-9]+", "a1b2c3"), ["1", "2", "3"])
}

test "regex.find_all no matches" {
  assert_eq(regex.find_all("[0-9]+", "abc"), [])
}

test "regex.find_all words" {
  let words = regex.find_all("[a-z]+", "hello world foo");
  assert_eq(list.len(words), 3);
  assert_eq(list.get_or(words, 0, ""), "hello")
}

// ── replace ──
test "regex.replace all" {
  assert_eq(regex.replace("[0-9]+", "a1b2c3", "X"), "aXbXcX");
  assert_eq(regex.replace("[0-9]+", "hello", "X"), "hello")
}

test "regex.replace with empty string" {
  assert_eq(regex.replace("[0-9]", "a1b2c3", ""), "abc")
}

// ── replace_first ──
test "regex.replace_first" {
  assert_eq(regex.replace_first("[0-9]+", "a1b2c3", "X"), "aXb2c3");
  assert_eq(regex.replace_first("[0-9]+", "hello", "X"), "hello")
}

// ── split ──
test "regex.split by pattern" {
  assert_eq(regex.split("[,;]", "a,b;c"), ["a", "b", "c"]);
  assert_eq(regex.split(",", "hello"), ["hello"])
}

test "regex.split by whitespace" {
  let parts = regex.split("\\s+", "hello   world  foo");
  assert_eq(parts, ["hello", "world", "foo"])
}

// ── captures ──
test "regex.captures with groups" {
  let cap = regex.captures("(\\w+)@(\\w+)", "user@host");
  assert_eq(option.is_some(cap), true);
  assert_eq(regex.captures("(\\d+)-(\\d+)", "hello"), none)
}

test "regex.captures returns some for match" {
  let cap = regex.captures("(\\d+)-(\\d+)", "abc-123-456");
  assert_eq(cap.is_some(), true)
}

// ── capture CONTENTS (previously broken: wasm reused slot 0 by nesting depth) ──
test "regex.captures contents per lexical group" {
  assert_eq(regex.captures("(\\d+)-(\\d+)", "12-34"), some(["12", "34"]));
  assert_eq(regex.captures("(a)(b)(c)", "abc"), some(["a", "b", "c"]));
  assert_eq(regex.captures("(\\w+)@(\\w+)", "user@host"), some(["user", "host"]))
}

test "regex.captures optional-miss is empty string" {
  assert_eq(regex.captures("(x)?(y)", "y"), some(["", "y"]));
  assert_eq(regex.captures("(a)?b", "b"), some([""]))
}

test "regex.captures none when no groups" {
  assert_eq(regex.captures("\\d+", "12"), none)
}

// ── alternation (was entirely unsupported in wasm) ──
test "regex.alternation" {
  assert_eq(regex.is_match("a|b", "zzb"), true);
  assert_eq(regex.is_match("foo|bar|baz", "xbazy"), true);
  assert_eq(regex.find("(a|b)+", "qabbaq"), some("abba"));
  assert_eq(regex.full_match("a|bb|ccc", "ccc"), true);
  assert_eq(regex.find("gr(a|e)y", "grey"), some("grey"))
}

// ── escape atoms (negated + escaped literals) ──
test "regex.escape atoms" {
  assert_eq(regex.is_match("a\\+b", "a+b"), true);
  assert_eq(regex.is_match("a\\+b", "aab"), false);
  assert_eq(regex.find("\\D+", "ab123cd"), some("ab"));
  assert_eq(regex.find("\\S+", "   word "), some("word"))
}

// ── class internal escapes ──
test "regex.class escapes" {
  assert_eq(regex.find("[\\d]+", "xx42yy"), some("42"));
  assert_eq(regex.is_match("[^\\d]", "5"), false);
  assert_eq(regex.is_match("[^\\d]", "a"), true);
  assert_eq(regex.find("[\\w]+", "@@abc@@"), some("abc"))
}

// ── multibyte (scalar-based; '.' matches one scalar, not one byte) ──
test "regex.multibyte" {
  assert_eq(regex.find(".", "日本語"), some("日"));
  assert_eq(regex.find("..", "日本語"), some("日本"));
  assert_eq(regex.is_match("本", "日本語"), true);
  assert_eq(regex.find("[本語]+", "日本語!"), some("本語"))
}

// ── empty alternation arms (an empty arm = empty Seq, matches length-0) ──
// wasm previously dropped TRAILING empty arms.
test "regex.empty alternation arms" {
  assert_eq(regex.is_match("a|", "zzz"), true);    // trailing
  assert_eq(regex.is_match("|a", "zzz"), true);    // leading
  assert_eq(regex.is_match("a||b", "zzz"), true);  // middle
  assert_eq(regex.is_match("a|||", "zzz"), true);  // triple
  assert_eq(regex.find("a|", "bza"), some(""));    // empty match at pos 0
  assert_eq(regex.full_match("a|", ""), true);
  assert_eq(regex.captures("(a|)", "b"), some([""]));
  assert_eq(regex.captures("(|a)", "b"), some([""]))
}

// ── replace / replace_first over EMPTY matches at end-of-string ──
// native used to panic indexing chars[len]; now guarded (and wasm matches).
test "regex.replace over empty matches" {
  assert_eq(regex.replace("x*", "ab", "-"), "-a-b-");
  assert_eq(regex.replace("", "ab", "-"), "-a-b-");
  assert_eq(regex.replace("a*", "aaa", "-"), "--");
  assert_eq(regex.replace("a*", "bbb", "-"), "-b-b-b-");
  assert_eq(regex.replace("b?", "abc", "-"), "-a--c-");
  assert_eq(regex.replace("x*", "", "-"), "-");
  assert_eq(regex.replace("x*", "本a", "-"), "-本-a-");
  assert_eq(regex.replace_first("x*", "ab", "-"), "-ab");
  assert_eq(regex.replace_first("a*", "aaa", "-"), "-")
}
