// Test bundled stdlib: args module
import args

fn main() -> Unit = {
  // args.raw() returns all command-line arguments
  let all = args.raw()
  println("raw args count: " ++ int.to_string(list.len(all)))

  // args.positional() returns non-flag arguments (excluding program name)
  let pos = args.positional()
  println("positional: " ++ int.to_string(list.len(pos)))

  // args.flag? checks for --name or -n
  let verbose = args.flag?("verbose")
  println("verbose: " ++ if verbose then "true" else "false")

  // args.option returns value for --name=val or --name val
  let output = args.option_or("output", "default.txt")
  println("output: " ++ output)

  println("args module works!")
}
