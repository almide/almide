import list
import string

test "crypto.random_bytes returns correct length" {
  let bytes = crypto.random_bytes(16)
  assert_eq(list.len(bytes), 16)
}

test "crypto.random_bytes values in 0-255" {
  let bytes = crypto.random_bytes(32)
  let all_valid = list.all(bytes, fn(b) => b >= 0 and b <= 255)
  assert(all_valid)
}

test "crypto.random_hex returns correct length" {
  let hex = crypto.random_hex(16)
  assert_eq(string.len(hex), 32)
}

test "crypto.hmac_sha256 produces 64 char hex" {
  let sig = crypto.hmac_sha256("secret", "hello")
  assert_eq(string.len(sig), 64)
}

test "crypto.hmac_sha256 is deterministic" {
  let a = crypto.hmac_sha256("key", "data")
  let b = crypto.hmac_sha256("key", "data")
  assert_eq(a, b)
}

test "crypto.hmac_verify true for matching" {
  let sig = crypto.hmac_sha256("mykey", "mydata")
  let valid = crypto.hmac_verify("mykey", "mydata", sig)
  assert_eq(valid, true)
}

test "crypto.hmac_verify false for wrong key" {
  let sig = crypto.hmac_sha256("mykey", "mydata")
  let valid = crypto.hmac_verify("wrongkey", "mydata", sig)
  assert_eq(valid, false)
}
