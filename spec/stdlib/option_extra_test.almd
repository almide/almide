// option extra tests — deeper coverage of option module

test "option.map with string transform" {
  assert_eq(option.map(some("hello"), (s) => string.to_upper(s)), some("HELLO"))
}

test "option.map none stays none" {
  let n: Option[String] = none
  assert_eq(option.map(n, (s) => string.to_upper(s)), none)
}

test "option.flat_map returns none on none input" {
  let n: Option[Int] = none
  assert_eq(option.flat_map(n, (x) => some(x * 2)), none)
}

test "option.flat_map returns none from function" {
  assert_eq(option.flat_map(some(0), (x) => if x > 0 then some(x) else none), none)
}

test "option.flat_map chains successfully" {
  let r = option.flat_map(some(10), (x) => some(x + 5))
  assert_eq(r, some(15))
}

test "option.unwrap_or on some returns value" {
  assert_eq(option.unwrap_or(some("a"), "b"), "a")
}

test "option.unwrap_or on none returns default" {
  let n: Option[String] = none
  assert_eq(option.unwrap_or(n, "default"), "default")
}

test "option.is_some on some" {
  assert_eq(option.is_some(some("x")), true)
}

test "option.is_none on none" {
  let n: Option[Int] = none
  assert_eq(option.is_none(n), true)
}

test "option.filter keeps value when predicate true" {
  assert_eq(option.filter(some(10), (x) => x > 5), some(10))
}

test "option.filter removes value when predicate false" {
  assert_eq(option.filter(some(2), (x) => x > 5), none)
}

test "option.filter on none returns none" {
  let n: Option[Int] = none
  assert_eq(option.filter(n, (x) => x > 0), none)
}

test "option.to_list on some" {
  assert_eq(option.to_list(some(42)), [42])
}

test "option.to_list on none" {
  let n: Option[Int] = none
  assert_eq(option.to_list(n), [])
}

test "option.zip both some returns some tuple" {
  let r = option.zip(some(1), some("a"))
  assert_eq(option.is_some(r), true)
}
