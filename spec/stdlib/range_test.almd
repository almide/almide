effect fn main(args: List[String]) -> Result[Unit, String] = {
  // basic exclusive range
  let xs = 0..5
  assert_eq(list.len(xs), 5)
  assert_eq(list.get_or(xs, 0, -1), 0)
  assert_eq(list.get_or(xs, 4, -1), 4)

  // inclusive range
  let ys = 1..=5
  assert_eq(list.len(ys), 5)
  assert_eq(list.get_or(ys, 0, -1), 1)
  assert_eq(list.get_or(ys, 4, -1), 5)

  // for-in with exclusive range
  var sum = 0
  for i in 0..10 {
    sum = sum + i
  }
  assert_eq(sum, 45)

  // for-in with inclusive range
  var sum2 = 0
  for i in 1..=10 {
    sum2 = sum2 + i
  }
  assert_eq(sum2, 55)

  // range with expressions
  let n = 5
  var sum3 = 0
  for i in 0..n {
    sum3 = sum3 + i
  }
  assert_eq(sum3, 10)

  // range as list - map over it
  let squares = list.map(0..5, (i) => i * i)
  assert_eq(list.len(squares), 5)
  assert_eq(list.get_or(squares, 0, -1), 0)
  assert_eq(list.get_or(squares, 3, -1), 9)
  assert_eq(list.get_or(squares, 4, -1), 16)

  // empty range
  let empty = 5..5
  assert_eq(list.len(empty), 0)

  // inclusive range single element
  let single = 3..=3
  assert_eq(list.len(single), 1)
  assert_eq(list.get_or(single, 0, -1), 3)

  println("All range tests passed!")
  ok(())
}
