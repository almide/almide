// Comprehensive map module tests

// ── new ──

test "map.new creates empty map" {
  let m: Map[String, Int] = map.new()
  assert_eq(map.len(m), 0)
}

// ── set / get ──

test "map.set overwrites existing key" {
  let m = map.set(map.set(map.new(), "x", 1), "x", 2)
  assert_eq(map.get(m, "x"), some(2))
  assert_eq(map.len(m), 1)
}

test "map.get missing key" {
  let m = map.set(map.new(), "a", 1)
  assert_eq(map.get(m, "b"), none)
}

// ── get_or ──

test "map.get_or with int values" {
  let m = map.set(map.new(), "x", 42)
  assert_eq(map.get_or(m, "x", 0), 42)
  assert_eq(map.get_or(m, "y", 0), 0)
}

// ── contains ──

test "map.contains after set and remove" {
  let m = map.set(map.new(), "a", 1)
  assert(map.contains(m, "a"))
  let m2 = map.remove(m, "a")
  assert(not map.contains(m2, "a"))
}

// ── remove ──

test "map.remove non-existent key" {
  let m = map.set(map.new(), "a", 1)
  let m2 = map.remove(m, "b")
  assert_eq(map.len(m2), 1)
}

test "map.remove last key" {
  let m = map.set(map.new(), "a", 1)
  let m2 = map.remove(m, "a")
  assert_eq(map.len(m2), 0)
  assert(map.is_empty?(m2))
}

// ── keys / values ──

test "map.keys returns sorted keys" {
  let m = map.set(map.set(map.set(map.new(), "b", 2), "a", 1), "c", 3)
  assert_eq(map.keys(m), ["a", "b", "c"])
}

test "map.values returns values" {
  let m = map.set(map.set(map.new(), "a", 10), "b", 20)
  let vals = list.sort(map.values(m))
  assert_eq(vals, [10, 20])
}

test "map.keys empty map" {
  let m: Map[String, Int] = map.new()
  assert_eq(map.keys(m), [])
}

test "map.values empty map" {
  let m: Map[String, Int] = map.new()
  assert_eq(map.values(m), [])
}

// ── len ──

test "map.len after operations" {
  let m = map.set(map.set(map.set(map.new(), "a", 1), "b", 2), "c", 3)
  assert_eq(map.len(m), 3)
  let m2 = map.remove(m, "b")
  assert_eq(map.len(m2), 2)
}

// ── entries ──

test "map.entries basic" {
  let m = map.set(map.set(map.new(), "a", 1), "b", 2)
  let entries = map.entries(m)
  assert_eq(list.len(entries), 2)
}

// ── merge ──

test "map.merge non-overlapping" {
  let a = map.set(map.new(), "x", 1)
  let b = map.set(map.new(), "y", 2)
  let merged = map.merge(a, b)
  assert_eq(map.get(merged, "x"), some(1))
  assert_eq(map.get(merged, "y"), some(2))
  assert_eq(map.len(merged), 2)
}

test "map.merge overlapping keys" {
  let a = map.set(map.new(), "x", 1)
  let b = map.set(map.new(), "x", 99)
  let merged = map.merge(a, b)
  assert_eq(map.get(merged, "x"), some(99))
}

test "map.merge empty" {
  let a = map.set(map.new(), "x", 1)
  let empty: Map[String, Int] = map.new()
  let merged = map.merge(a, empty)
  assert_eq(map.len(merged), 1)
}

// ── is_empty? ──

test "map.is_empty? after adding and removing" {
  let m = map.set(map.new(), "k", 1)
  assert(not map.is_empty?(m))
  let m2 = map.remove(m, "k")
  assert(map.is_empty?(m2))
}

// ── from_entries ──

test "map.from_entries multiple" {
  let entries = [("a", 1), ("b", 2), ("c", 3)]
  let m = map.from_entries(entries)
  assert_eq(map.len(m), 3)
  assert_eq(map.get(m, "a"), some(1))
  assert_eq(map.get(m, "b"), some(2))
  assert_eq(map.get(m, "c"), some(3))
}

test "map.from_entries empty" {
  let entries: List[(String, Int)] = []
  let m = map.from_entries(entries)
  assert(map.is_empty?(m))
}

// ── map_values ──

test "map.map_values to string" {
  let m = map.set(map.set(map.new(), "a", 1), "b", 2)
  let result = map.map_values(m, (v) => v + 100)
  assert_eq(map.get_or(result, "a", 0), 101)
  assert_eq(map.get_or(result, "b", 0), 102)
}

test "map.map_values empty" {
  let m: Map[String, Int] = map.new()
  let result = map.map_values(m, (v) => v * 2)
  assert(map.is_empty?(result))
}

// ── filter ──

test "map.filter all pass" {
  let m = map.set(map.set(map.new(), "a", 10), "b", 20)
  let result = map.filter(m, (k, v) => v > 0)
  assert_eq(map.len(result), 2)
}

test "map.filter none pass" {
  let m = map.set(map.set(map.new(), "a", 1), "b", 2)
  let result = map.filter(m, (k, v) => v > 10)
  assert_eq(map.len(result), 0)
}

test "map.filter by key" {
  let m = map.set(map.set(map.set(map.new(), "apple", 1), "banana", 2), "avocado", 3)
  let result = map.filter(m, (k, v) => string.starts_with?(k, "a"))
  assert_eq(map.len(result), 2)
  assert(map.contains(result, "apple"))
  assert(map.contains(result, "avocado"))
}

// ── UFCS ──

test "map UFCS get" {
  let m = map.set(map.new(), "x", 42)
  assert_eq(m.get("x"), some(42))
}

test "map UFCS keys" {
  let m = map.set(map.set(map.new(), "a", 1), "b", 2)
  assert_eq(m.keys(), ["a", "b"])
}

test "map UFCS len" {
  let m = map.set(map.new(), "a", 1)
  assert_eq(m.len(), 1)
}

test "map UFCS contains" {
  let m = map.set(map.new(), "key", "value")
  assert(m.contains("key"))
}
