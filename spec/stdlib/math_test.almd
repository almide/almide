// Comprehensive math module tests
import math

// ── min / max ──

test "math.min basic" {
  assert_eq(math.min(3, 7), 3)
}

test "math.min equal" {
  assert_eq(math.min(5, 5), 5)
}

test "math.min negative" {
  assert_eq(math.min(-10, -20), -20)
}

test "math.max basic" {
  assert_eq(math.max(3, 7), 7)
}

test "math.max equal" {
  assert_eq(math.max(5, 5), 5)
}

test "math.max negative" {
  assert_eq(math.max(-10, -20), -10)
}

// ── abs ──

test "math.abs positive" {
  assert_eq(math.abs(42), 42)
}

test "math.abs negative" {
  assert_eq(math.abs(-42), 42)
}

test "math.abs zero" {
  assert_eq(math.abs(0), 0)
}

// ── pow ──

test "math.pow basic" {
  assert_eq(math.pow(2, 10), 1024)
}

test "math.pow zero exponent" {
  assert_eq(math.pow(5, 0), 1)
}

test "math.pow one exponent" {
  assert_eq(math.pow(7, 1), 7)
}

test "math.pow base zero" {
  assert_eq(math.pow(0, 5), 0)
}

test "math.pow base one" {
  assert_eq(math.pow(1, 100), 1)
}

test "math.pow cubed" {
  assert_eq(math.pow(3, 3), 27)
}

// ── pi / e ──

test "math.pi value" {
  let p = math.pi()
  assert(p > 3.14 and p < 3.15)
}

test "math.e value" {
  let e = math.e()
  assert(e > 2.71 and e < 2.72)
}

// ── sin / cos / tan ──

test "math.sin zero" {
  assert_eq(math.sin(0.0), 0.0)
}

test "math.cos zero" {
  assert_eq(math.cos(0.0), 1.0)
}

test "math.tan zero" {
  assert_eq(math.tan(0.0), 0.0)
}

test "math.sin pi/2" {
  let s = math.sin(math.pi() / 2.0)
  assert(s > 0.999 and s < 1.001)
}

test "math.cos pi" {
  let c = math.cos(math.pi())
  assert(c > -1.001 and c < -0.999)
}

test "math.sin squared plus cos squared equals 1" {
  let x = 1.23
  let s = math.sin(x)
  let c = math.cos(x)
  let sum = s * s + c * c
  assert(sum > 0.999 and sum < 1.001)
}

// ── log / exp ──

test "math.log of 1" {
  assert_eq(math.log(1.0), 0.0)
}

test "math.exp of 0" {
  assert_eq(math.exp(0.0), 1.0)
}

test "math.log of e" {
  let result = math.log(math.e())
  assert(result > 0.999 and result < 1.001)
}

test "math.exp of 1 equals e" {
  let result = math.exp(1.0)
  let e = math.e()
  assert(result > e - 0.001 and result < e + 0.001)
}

test "math.log and exp are inverses" {
  let x = 5.0
  let result = math.log(math.exp(x))
  assert(result > 4.999 and result < 5.001)
}

// ── sqrt ──

test "math.sqrt perfect" {
  assert_eq(math.sqrt(25.0), 5.0)
}

test "math.sqrt one" {
  assert_eq(math.sqrt(1.0), 1.0)
}

test "math.sqrt zero" {
  assert_eq(math.sqrt(0.0), 0.0)
}

test "math.sqrt 100" {
  assert_eq(math.sqrt(100.0), 10.0)
}

test "math.sqrt non-perfect" {
  let s = math.sqrt(3.0)
  assert(s > 1.73 and s < 1.74)
}
