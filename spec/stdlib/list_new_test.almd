test "list.range" {
  let xs = list.range(0, 5)
  assert_eq(xs, [0, 1, 2, 3, 4])
  assert_eq(list.range(3, 3), [])
  assert_eq(list.range(1, 4), [1, 2, 3])
}

test "list.slice" {
  let xs = [10, 20, 30, 40, 50]
  assert_eq(list.slice(xs, 1, 3), [20, 30])
  assert_eq(list.slice(xs, 0, 5), [10, 20, 30, 40, 50])
  assert_eq(list.slice(xs, 2, 2), [])
  assert_eq(list.slice(xs, 0, 0), [])
}

test "list.insert" {
  let xs = [1, 2, 3]
  assert_eq(list.insert(xs, 0, 0), [0, 1, 2, 3])
  assert_eq(list.insert(xs, 1, 99), [1, 99, 2, 3])
  assert_eq(list.insert(xs, 3, 4), [1, 2, 3, 4])
}

test "list.remove_at" {
  let xs = [10, 20, 30, 40]
  assert_eq(list.remove_at(xs, 0), [20, 30, 40])
  assert_eq(list.remove_at(xs, 2), [10, 20, 40])
  assert_eq(list.remove_at(xs, 3), [10, 20, 30])
}

test "list.find_index" {
  let xs = [10, 20, 30, 40]
  assert_eq(list.find_index(xs, (x) => x == 30), some(2))
  assert_eq(list.find_index(xs, (x) => x > 25), some(2))
  assert_eq(list.find_index(xs, (x) => x > 100), none)
}

test "UFCS forms" {
  let xs = [1, 2, 3, 4, 5]
  assert_eq(xs.slice(1, 3), [2, 3])
  assert_eq(xs.insert(0, 0), [0, 1, 2, 3, 4, 5])
  assert_eq(xs.remove_at(2), [1, 2, 4, 5])
  assert_eq(xs.find_index((x) => x == 4), some(3))
}
