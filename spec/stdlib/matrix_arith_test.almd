// matrix.{sub, div, neg, pow} — arithmetic completeness tests.

test "sub element-wise" {
  let a = matrix.from_lists([[5.0, 7.0], [9.0, 11.0]])
  let b = matrix.from_lists([[1.0, 2.0], [3.0, 4.0]])
  let c = matrix.sub(a, b)
  assert_eq(matrix.get(c, 0, 0), 4.0)
  assert_eq(matrix.get(c, 0, 1), 5.0)
  assert_eq(matrix.get(c, 1, 0), 6.0)
  assert_eq(matrix.get(c, 1, 1), 7.0)
}

test "div element-wise" {
  let a = matrix.from_lists([[10.0, 20.0], [30.0, 40.0]])
  let b = matrix.from_lists([[2.0, 4.0], [5.0, 8.0]])
  let c = matrix.div(a, b)
  assert_eq(matrix.get(c, 0, 0), 5.0)
  assert_eq(matrix.get(c, 0, 1), 5.0)
  assert_eq(matrix.get(c, 1, 0), 6.0)
  assert_eq(matrix.get(c, 1, 1), 5.0)
}

test "neg flips signs" {
  let a = matrix.from_lists([[1.0, -2.0], [3.0, 0.0]])
  let n = matrix.neg(a)
  assert_eq(matrix.get(n, 0, 0), -1.0)
  assert_eq(matrix.get(n, 0, 1), 2.0)
  assert_eq(matrix.get(n, 1, 0), -3.0)
  assert_eq(matrix.get(n, 1, 1), 0.0)
}

test "pow squares each element" {
  let a = matrix.from_lists([[2.0, 3.0], [4.0, 5.0]])
  let s = matrix.pow(a, 2.0)
  assert_eq(matrix.get(s, 0, 0), 4.0)
  assert_eq(matrix.get(s, 0, 1), 9.0)
  assert_eq(matrix.get(s, 1, 0), 16.0)
  assert_eq(matrix.get(s, 1, 1), 25.0)
}

test "pow with cube" {
  let a = matrix.from_lists([[2.0, 3.0]])
  let s = matrix.pow(a, 3.0)
  assert_eq(matrix.get(s, 0, 0), 8.0)
  assert_eq(matrix.get(s, 0, 1), 27.0)
}

test "pow with 0.5 = sqrt" {
  let a = matrix.from_lists([[4.0, 9.0], [16.0, 25.0]])
  let s = matrix.pow(a, 0.5)
  assert(float.abs(matrix.get(s, 0, 0) - 2.0) < 0.001, "got " + float.to_string(matrix.get(s, 0, 0)))
  assert(float.abs(matrix.get(s, 0, 1) - 3.0) < 0.001, "got " + float.to_string(matrix.get(s, 0, 1)))
  assert(float.abs(matrix.get(s, 1, 0) - 4.0) < 0.001, "got " + float.to_string(matrix.get(s, 1, 0)))
  assert(float.abs(matrix.get(s, 1, 1) - 5.0) < 0.001, "got " + float.to_string(matrix.get(s, 1, 1)))
}
