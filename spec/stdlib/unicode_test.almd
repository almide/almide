// Unicode string function tests

test "is_upper all uppercase" {
  assert_eq(string.is_upper("ABC"), true)
}

test "is_upper mixed case" {
  assert_eq(string.is_upper("AbC"), false)
}

test "is_upper with numbers" {
  assert_eq(string.is_upper("ABC123"), true)
}

test "is_lower all lowercase" {
  assert_eq(string.is_lower("abc"), true)
}

test "is_lower mixed case" {
  assert_eq(string.is_lower("aBc"), false)
}

test "is_lower with numbers" {
  assert_eq(string.is_lower("abc123"), true)
}

test "codepoint ASCII" {
  assert_eq(string.codepoint("A"), some(65))
  assert_eq(string.codepoint("a"), some(97))
  assert_eq(string.codepoint("0"), some(48))
}

test "codepoint empty string" {
  assert_eq(string.codepoint(""), none)
}

test "from_codepoint ASCII" {
  assert_eq(string.from_codepoint(65), "A")
  assert_eq(string.from_codepoint(97), "a")
}

test "char_count ASCII" {
  assert_eq(string.len("hello"), 5)
  assert_eq(string.len(""), 0)
}

test "is_upper via UFCS" {
  assert_eq("HELLO".is_upper(), true)
  assert_eq("Hello".is_upper(), false)
}

test "is_lower via UFCS" {
  assert_eq("hello".is_lower(), true)
  assert_eq("Hello".is_lower(), false)
}

test "codepoint via UFCS" {
  assert_eq("Z".codepoint(), some(90))
}

test "char_count via UFCS" {
  assert_eq("hello".char_count(), 5)
}
