import term

fn main() -> Unit = {
  // Test that color wrapping produces correct ANSI codes
  let red_text = term.red("hello")
  assert(string.contains(red_text, "hello"), "red contains text")
  assert(string.contains(red_text, "[31m"), "red has color code")
  assert(string.contains(red_text, "[0m"), "red has reset")

  let bold_text = term.bold("test")
  assert(string.contains(bold_text, "[1m"), "bold has code")

  // Test strip removes ANSI codes
  let stripped = term.strip(term.red("hello"))
  assert(stripped == "hello", "strip removes ANSI")

  // Test 256-color
  let colored = term.color("hi", 42)
  assert(string.contains(colored, "[38;5;42m"), "256-color code")

  println("All term tests passed!")
}
