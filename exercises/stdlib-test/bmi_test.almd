fn bmi(weight: Float, height: Float) -> Float = {
  weight / (height * height)
}

fn category(bmi_val: Float) -> String = {
  if bmi_val < 18.5 then "Underweight"
  else if bmi_val < 25.0 then "Normal"
  else if bmi_val < 30.0 then "Overweight"
  else "Obese"
}

test "BMI normal weight" {
  let result = bmi(70.0, 1.75)
  assert(result > 22.0)
  assert(result < 23.0)
  assert_eq(category(result), "Normal")
}

test "BMI underweight" {
  let result = bmi(50.0, 1.75)
  assert_eq(category(result), "Underweight")
}

test "BMI overweight" {
  let result = bmi(85.0, 1.75)
  assert_eq(category(result), "Overweight")
}

test "BMI obese" {
  let result = bmi(110.0, 1.75)
  assert_eq(category(result), "Obese")
}

effect fn main(args: List[String]) -> Unit = {
  let w = float.from_int(110)
  let h = float.from_int(178) / 100.0
  let result = bmi(w, h)
  println("Weight: 110 kg, Height: 178 cm")
  println("BMI: ${float.to_string(result)}")
  println("Category: ${category(result)}")
}
