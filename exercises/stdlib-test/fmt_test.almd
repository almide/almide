
// fmt_test: Tests that code round-trips through `almide fmt` correctly.
// This file covers all major syntax constructs to catch formatter regressions.
type Color = | Red | Green | Blue

type Shape = | Circle(Float) | Rect(Float, Float)

type AppError = | NotFound(String) | Io(IoError) deriving From

fn area(s: Shape) -> Float = match s {
  Circle(r) => 3.14159 * r * r,
  Rect(w, h) => w * h,
}

fn greet(n: String) -> String = "Hello, ${n}!"

fn classify(n: Int) -> String = if n > 0 then "positive"
else if n < 0 then "negative" else "zero"

fn sum_list(xs: List[Int]) -> Int = list.fold(xs, 0, fn(acc, x) => acc + x)

fn process(items: List[String]) -> List[String] = items |> list.filter(fn(s) => string.len(s) > 0) |> list.map(fn(s) => string.to_upper(s))

fn float_literals() -> Unit = {
  let a = 1.0;
  let b = 25.0;
  let c = 3.14;
  let d = 0.5;
  assert_eq(a + b, 26.0);
  assert_eq(c > d, true)
}

fn string_tests() -> Unit = {
  let s = "hello\nworld";
  let t = "tab\there";
  let u = "quote\"inside";
  let v = "backslash\\";
  assert_eq(string.len(s), 11);
  assert_eq(string.len(t), 8);
  assert_eq(string.len(u), 12);
  assert_eq(string.len(v), 10)
}

fn interpolation_tests() -> Unit = {
  let x = "world";
  let msg = "hello ${x}!";
  assert_eq(msg, "hello world!");
  let multi = "line1\nline2\nline3";
  assert_eq(string.len(multi), 17)
}

fn heredoc_tests() -> Unit = {
  let sql = "SELECT *\nFROM users";
  assert_eq(sql, "SELECT *\nFROM users");
  let code = "if x {\n  return y\n}";
  assert_eq(code, "if x {\n  return y\n}");
  let empty = "";
  assert_eq(empty, "")
}

fn collection_tests() -> Unit = {
  let xs = [1, 2, 3, 4, 5];
  assert_eq(list.len(xs), 5);
  assert_eq(list.get(xs, 0), some(1));
  assert_eq(list.get(xs, 10), none);
  let m = map.new();
  let m = map.set(m, "a", 1);
  let m = map.set(m, "b", 2);
  assert_eq(map.len(m), 2);
  assert_eq(map.get(m, "a"), some(1))
}

fn pattern_tests() -> Unit = {
  let opt: Option[Int] = some(42);
  let val = match opt {
    some(n) => n,
    none => 0,
  };
  assert_eq(val, 42)
}

fn range_test() -> Unit = {
  let xs = list.map(1..5, fn(x) => x * 2);
  assert_eq(xs, [2, 4, 6, 8]);
  let ys = list.map(1..=3, fn(x) => x);
  assert_eq(ys, [1, 2, 3])
}

fn for_loop_test() -> Unit = {
  var total = 0;
  for x in [10, 20, 30] {
    total = total + x;
  };
  assert_eq(total, 60);
  var pairs: List[String] = [];
  for (i, v) in list.enumerate(["a", "b"]) {
    pairs = pairs ++ [int.to_string(i) ++ ":" ++ v];
  };
  assert_eq(pairs, ["0:a", "1:b"])
}

fn unary_test() -> Unit = {
  assert_eq(-5, 0 - 5);
  assert_eq(not true, false)
}

fn pipe_test() -> Unit = {
  let result = [1, 2, 3] |> list.map(fn(x) => x * 2) |> list.filter(fn(x) => x > 2) |> list.len();
  assert_eq(result, 2)
}

fn main() -> Unit = {
  float_literals();
  string_tests();
  interpolation_tests();
  heredoc_tests();
  collection_tests();
  pattern_tests();
  range_test();
  for_loop_test();
  unary_test();
  pipe_test();
  assert_eq(area(Circle(1.0)), 3.14159);
  assert_eq(area(Rect(3.0, 4.0)), 12.0);
  assert_eq(greet("Almide"), "Hello, Almide!");
  assert_eq(classify(5), "positive");
  assert_eq(classify(-3), "negative");
  assert_eq(classify(0), "zero");
  assert_eq(sum_list([1, 2, 3, 4, 5]), 15);
  assert_eq(process(["hello", "", "world"]), ["HELLO", "WORLD"]);
  println("All fmt tests passed!")
}

test "area circle" {
  assert_eq(area(Circle(1.0)), 3.14159)
}

test "area rect" {
  assert_eq(area(Rect(2.0, 5.0)), 10.0)
}

test "classify" {
  assert_eq(classify(1), "positive");
  assert_eq(classify(-1), "negative");
  assert_eq(classify(0), "zero")
}
