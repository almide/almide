module math_random_time_test

import math
import random
import time
import list

// ============================================================
// math module
// ============================================================

test "math.min and math.max" {
  assert_eq(math.min(3, 5), 3)
  assert_eq(math.min(-1, 1), -1)
  assert_eq(math.max(3, 5), 5)
  assert_eq(math.max(-1, 1), 1)
}

test "math.abs" {
  assert_eq(math.abs(-5), 5)
  assert_eq(math.abs(5), 5)
  assert_eq(math.abs(0), 0)
}

test "math.pow" {
  assert_eq(math.pow(2, 10), 1024)
  assert_eq(math.pow(3, 0), 1)
  assert_eq(math.pow(5, 1), 5)
}

test "math.pi and math.e" {
  assert(math.pi() > 3.14)
  assert(math.pi() < 3.15)
  assert(math.e() > 2.71)
  assert(math.e() < 2.72)
}

test "math.sin and math.cos" {
  assert(math.sin(0.0) < 0.001)
  assert(math.cos(0.0) > 0.999)
}

test "math.sqrt" {
  assert(math.sqrt(4.0) > 1.999)
  assert(math.sqrt(4.0) < 2.001)
}

test "math.log and math.exp" {
  assert(math.log(1.0) < 0.001)
  assert(math.exp(0.0) > 0.999)
  assert(math.exp(0.0) < 1.001)
}

// ============================================================
// random module
// ============================================================

test "random.int in range" {
  let n = random.int(1, 10)
  assert(n >= 1)
  assert(n <= 10)
}

test "random.float in range" {
  let f = random.float()
  assert(f >= 0.0)
  assert(f <= 1.0)
}

test "random.choice returns element" {
  let xs = ["a", "b", "c"]
  let result = random.choice(xs)
  match result {
    some(v) => assert(list.contains(xs, v)),
    none => assert(false)
  }
}

test "random.shuffle preserves elements" {
  let xs = [1, 2, 3, 4, 5]
  let shuffled = random.shuffle(xs)
  assert_eq(list.len(shuffled), 5)
  assert(list.contains(shuffled, 1))
  assert(list.contains(shuffled, 5))
}

// ============================================================
// time module
// ============================================================

test "time.now returns positive" {
  let t = time.now()
  assert(t > 0)
}

test "time.millis returns positive" {
  let t = time.millis()
  assert(t > 0)
}

test "time decomposition - known timestamp" {
  // 2024-01-15 10:30:45 UTC = 1705314645
  let ts = 1705314645
  assert_eq(time.year(ts), 2024)
  assert_eq(time.month(ts), 1)
  assert_eq(time.day(ts), 15)
  assert_eq(time.hour(ts), 10)
  assert_eq(time.minute(ts), 30)
  assert_eq(time.second(ts), 45)
}

test "time.weekday" {
  // 2024-01-15 is Monday = 0
  let ts = 1705314645
  assert_eq(time.weekday(ts), 0)
}

test "time.to_iso" {
  let ts = 1705314645
  assert_eq(time.to_iso(ts), "2024-01-15T10:30:45Z")
}

test "time.from_parts roundtrip" {
  let ts = time.from_parts(2024, 1, 15, 10, 30, 45)
  assert_eq(ts, 1705314645)
}

test "time.from_parts and decomposition roundtrip" {
  let ts = time.from_parts(2000, 6, 15, 12, 0, 0)
  assert_eq(time.year(ts), 2000)
  assert_eq(time.month(ts), 6)
  assert_eq(time.day(ts), 15)
  assert_eq(time.hour(ts), 12)
  assert_eq(time.minute(ts), 0)
  assert_eq(time.second(ts), 0)
}
