// Test fix 1: PartialOrd — comparison on type vars
fn max_of[T](a: T, b: T) -> T = if a > b then a else b

// Test fix 2: Generic variant type
type Maybe[T] =
  | Just(T)
  | Nothing

fn from_option[T](opt: Option[T]) -> Maybe[T] =
  match opt {
    some(v) => Just(v)
    none => Nothing
  }

fn maybe_map[A, B](m: Maybe[A], f: fn(A) -> B) -> Maybe[B] =
  match m {
    Just(v) => Just(f(v))
    Nothing => Nothing
  }

test "comparison on generic type" {
  assert_eq(max_of(3, 7), 7)
  assert_eq(max_of(10, 2), 10)
  assert_eq(max_of("banana", "apple"), "banana")
}

test "generic variant Just" {
  let m = Just(42)
  match m {
    Just(v) => assert_eq(v, 42)
    Nothing => assert(false, "should be Just")
  }
}

test "generic variant Nothing" {
  let m = Nothing[Int]()
  match m {
    Just(_v) => assert(false, "should be Nothing")
    Nothing => assert(true)
  }
}

test "from_option converts some" {
  let m = from_option(some(10))
  match m {
    Just(v) => assert_eq(v, 10)
    Nothing => assert(false)
  }
}

test "from_option converts none" {
  let m = from_option[Int](none)
  match m {
    Just(_v) => assert(false)
    Nothing => assert(true)
  }
}

test "maybe_map applies function" {
  let m = Just(5)
  let doubled = maybe_map(m, fn(x: Int) => x * 2)
  match doubled {
    Just(v) => assert_eq(v, 10)
    Nothing => assert(false)
  }
}
