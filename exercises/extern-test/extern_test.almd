// @extern test: Pattern 2 — body is fallback for targets without @extern
// Since we compile to Rust, @extern(rs, ...) takes priority over the body.
// The body is used as fallback for targets that don't have an @extern.

// Pattern 1: Pure Almide (no extern, both targets use body)
fn add(a: Int, b: Int) -> Int = a + b

// Pattern 2: @extern for rs, body is fallback for ts
@extern(rs, "std::cmp", "min")
fn my_min(a: Int, b: Int) -> Int = if a < b then a else b

// Pattern 3: Both targets extern (no body needed)
@extern(rs, "std::cmp", "max")
@extern(ts, "Math", "max")
fn my_max(a: Int, b: Int) -> Int

fn main() -> Unit = {
  // Pattern 1: pure Almide
  assert_eq(add(2, 3), 5, "pure Almide fn")

  // Pattern 2: @extern(rs) delegates to std::cmp::min
  assert_eq(my_min(10, 20), 10, "@extern(rs) min")
  assert_eq(my_min(5, 3), 3, "@extern(rs) min reversed")

  // Pattern 3: @extern(rs) delegates to std::cmp::max
  assert_eq(my_max(10, 20), 20, "@extern(rs) max")
  assert_eq(my_max(5, 3), 5, "@extern(rs) max reversed")

  println("All @extern tests passed!")
}
