// random — bundled-Almide stdlib module (Stdlib Declarative Unification Stage 4b).
//
// Migrated mechanically from `stdlib/defs/random.toml` (4 fns). All
// are `effect` (non-deterministic); the runtime impls stay in
// `runtime/rs/src/random.rs`.

@inline_rust("almide_rt_random_int({min}, {max})")
effect fn int(min: Int, max: Int) -> Int = _

@inline_rust("almide_rt_random_float()")
effect fn float() -> Float = _

@inline_rust("almide_rt_random_choice(&{xs})")
effect fn choice[T](xs: List[T]) -> Option[T] = _

@inline_rust("almide_rt_random_shuffle(({xs}).to_vec())")
effect fn shuffle[T](xs: List[T]) -> List[T] = _
