// Stdlib Phase 5 — fs and process integration tests

effect fn main() -> Result[Unit, String] = {
  // ── fs.is_file? / fs.is_dir? ──

  let tmp_dir = env.temp_dir() ++ "/almide_fs_test"
  fs.mkdir_p(tmp_dir)
  let tmp_file = tmp_dir ++ "/hello.txt"
  fs.write(tmp_file, "hello")

  assert(fs.is_file?(tmp_file), "expected is_file? true for " ++ tmp_file)
  assert(fs.is_dir?(tmp_dir), "expected is_dir? true for " ++ tmp_dir)
  assert(not fs.is_dir?(tmp_file), "file should not be is_dir?")
  assert(not fs.is_file?(tmp_dir), "dir should not be is_file?")
  assert(not fs.is_file?(tmp_dir ++ "/nonexistent"), "nonexistent should not be is_file?")
  println("fs.is_file? / fs.is_dir?: ok")

  // ── fs.copy ──

  let copy_dst = tmp_dir ++ "/hello_copy.txt"
  fs.copy(tmp_file, copy_dst)
  let copied = fs.read_text(copy_dst)
  assert_eq(copied, "hello", "copied file contents should match")
  println("fs.copy: ok")

  // ── fs.rename ──

  let rename_dst = tmp_dir ++ "/hello_renamed.txt"
  fs.rename(copy_dst, rename_dst)
  assert(fs.is_file?(rename_dst), "renamed file should exist")
  assert(not fs.is_file?(copy_dst), "original should not exist after rename")
  let renamed = fs.read_text(rename_dst)
  assert_eq(renamed, "hello", "renamed file contents should match")
  println("fs.rename: ok")

  // ── process.exec_status ──

  let { code, stdout, stderr } = process.exec_status("echo", ["hello world"])
  assert_eq(code, 0, "echo should exit with 0")
  assert_eq(string.trim(stdout), "hello world", "echo stdout")
  println("process.exec_status success: ok (stderr=" ++ stderr ++ ")")

  let result2 = process.exec_status("false", [])
  let { code, stdout, stderr } = result2
  assert(code != 0, "false should exit non-zero, got " ++ int.to_string(code))
  println("process.exec_status non-zero: ok")

  // ── cleanup ──
  fs.remove(tmp_file)
  fs.remove(rename_dst)

  println("All fs/process tests passed!")
}
