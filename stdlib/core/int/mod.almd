// int — integer operations
// Core module (auto-import, platform-independent)

@extern
fn to_string(n: Int) -> String

@extern
fn from_string(s: String) -> Result[Int, String]

fn abs(n: Int) -> Int =
  if n < 0 then 0 - n else n

fn clamp(n: Int, min: Int, max: Int) -> Int =
  if n < min then min
  else if n > max then max
  else n

fn min(a: Int, b: Int) -> Int = if a < b then a else b
fn max(a: Int, b: Int) -> Int = if a > b then a else b
