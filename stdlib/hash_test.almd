import hash

fn main() -> Unit = {
  // SHA-256 test vectors
  let empty_sha256 = hash.sha256("")
  assert(empty_sha256 == "e3b0c44298fc1c149afbf4c8996fb92427ae41e4649b934ca495991b7852b855", "sha256 empty")

  let hello_sha256 = hash.sha256("hello")
  assert(hello_sha256 == "2cf24dba5fb0a30e26e83b2ac5b9e29e1b161e5c1fa7425e73043362938b9824", "sha256 hello")

  // SHA-1 test vectors
  let empty_sha1 = hash.sha1("")
  assert(empty_sha1 == "da39a3ee5e6b4b0d3255bfef95601890afd80709", "sha1 empty")

  let hello_sha1 = hash.sha1("hello")
  assert(hello_sha1 == "aaf4c61ddcc5e8a2dabede0f3b482cd9aea9434d", "sha1 hello")

  // MD5 test vectors
  let empty_md5 = hash.md5("")
  assert(empty_md5 == "d41d8cd98f00b204e9800998ecf8427e", "md5 empty")

  let hello_md5 = hash.md5("hello")
  assert(hello_md5 == "5d41402abc4b2a76b9719d911017c592", "md5 hello")

  println("All hash tests passed!")
}
