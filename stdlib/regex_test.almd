import regex

// ============================================================
// regex.match? — partial match
// ============================================================

test "regex.match? finds digits" {
  assert(regex.match?(r"\d+", "abc123"))
  assert(regex.match?(r"\d+", "42"))
  assert(not regex.match?(r"\d+", "hello"))
}

test "regex.match? with character classes" {
  assert(regex.match?("[a-z]+", "hello"))
  assert(not regex.match?("[a-z]+", "123"))
  assert(regex.match?("[^0-9]+", "abc"))
}

test "regex.match? with dot and quantifiers" {
  assert(regex.match?("a.c", "abc"))
  assert(regex.match?("a.*c", "aXXXc"))
  assert(regex.match?("ab?c", "ac"))
  assert(regex.match?("ab?c", "abc"))
}

// ============================================================
// regex.full_match? — entire string match
// ============================================================

test "regex.full_match? requires full string" {
  assert(regex.full_match?(r"\d+", "123"))
  assert(not regex.full_match?(r"\d+", "abc123"))
  assert(regex.full_match?("[a-zA-Z_][a-zA-Z0-9_]*", "my_var_1"))
  assert(not regex.full_match?("[a-zA-Z_][a-zA-Z0-9_]*", "1bad"))
}

test "regex.full_match? integer validation" {
  assert(regex.full_match?(r"-?\d+", "42"))
  assert(regex.full_match?(r"-?\d+", "-7"))
  assert(not regex.full_match?(r"-?\d+", "abc"))
}

// ============================================================
// regex.find — first match
// ============================================================

test "regex.find returns first match" {
  assert_eq(regex.find(r"\d+", "abc123def456"), some("123"))
  assert_eq(regex.find(r"\d+", "hello"), none)
  assert_eq(regex.find("[a-z]+", "123abc456"), some("abc"))
}

// ============================================================
// regex.find_all — all matches
// ============================================================

test "regex.find_all returns all matches" {
  assert_eq(regex.find_all(r"\d+", "a1b22c333"), ["1", "22", "333"])
  assert_eq(regex.find_all("[a-z]+", "1a2bb3ccc"), ["a", "bb", "ccc"])
  assert_eq(regex.find_all(r"\d+", "hello"), [])
}

// ============================================================
// regex.replace — replace all
// ============================================================

test "regex.replace replaces all" {
  assert_eq(regex.replace(r"\d+", "a1b2c3", "X"), "aXbXcX")
  assert_eq(regex.replace(r"\s+", "hello  world", " "), "hello world")
}

// ============================================================
// regex.replace_first — replace first only
// ============================================================

test "regex.replace_first replaces only first" {
  assert_eq(regex.replace_first(r"\d+", "a1b2c3", "X"), "aXb2c3")
}

// ============================================================
// regex.split — split by pattern
// ============================================================

test "regex.split by pattern" {
  assert_eq(regex.split("[,;]", "a,b;c"), ["a", "b", "c"])
  assert_eq(regex.split(r"\s+", "hello  world foo"), ["hello", "world", "foo"])
}

// ============================================================
// regex.captures — capture groups
// ============================================================

test "regex.captures extracts groups" {
  assert_eq(regex.captures(r"(\w+)=(\w+)", "key=val"), some(["key", "val"]))
  assert_eq(regex.captures(r"(\d+)-(\d+)", "2024-01"), some(["2024", "01"]))
  assert_eq(regex.captures(r"(\w+)=(\w+)", "!!!"), none)
}

// ============================================================
// regex with alternation
// ============================================================

test "regex.match? with alternation" {
  assert(regex.match?("cat|dog", "I have a cat"))
  assert(regex.match?("cat|dog", "I have a dog"))
  assert(not regex.match?("cat|dog", "I have a fish"))
}

// ============================================================
// regex.match? with shorthand classes
// ============================================================

test "regex shorthand classes" {
  assert(regex.match?(r"\w+", "hello"))
  assert(regex.match?(r"\s", " "))
  assert(not regex.match?(r"\S", " "))
  assert(regex.match?(r"\D+", "abc"))
}

// ============================================================
// raw string literals
// ============================================================

test "raw strings preserve backslashes" {
  assert_eq(r"\d+", "\\d+")
  assert_eq(r"\n\t", "\\n\\t")
  assert_eq(r"hello", "hello")
}

// ============================================================
// practical: section header validation (miniconf use case)
// ============================================================

test "regex validates section headers" {
  assert(regex.full_match?(r"\[([a-zA-Z_][a-zA-Z0-9_]*)\]", "[server]"))
  assert(regex.full_match?(r"\[([a-zA-Z_][a-zA-Z0-9_]*)\]", "[my_section_2]"))
  assert(not regex.full_match?(r"\[([a-zA-Z_][a-zA-Z0-9_]*)\]", "[2bad]"))
  assert(not regex.full_match?(r"\[([a-zA-Z_][a-zA-Z0-9_]*)\]", "server"))
}

// ============================================================
// regex.match? — additional edge cases
// ============================================================

test "regex.match? empty string" {
  assert(not regex.match?(r"\d+", ""))
}

test "regex.match? anchored start" {
  assert(regex.match?("^hello", "hello world"))
  assert(not regex.match?("^hello", "say hello"))
}

test "regex.match? anchored end" {
  assert(regex.match?("world$", "hello world"))
  assert(not regex.match?("world$", "world hello"))
}

test "regex.match? with plus quantifier" {
  assert(regex.match?("a+", "aaa"))
  assert(not regex.match?("a+", "bbb"))
}

// ============================================================
// regex.full_match? — additional patterns
// ============================================================

test "regex.full_match? email-like pattern" {
  assert(regex.full_match?(r"[a-zA-Z0-9.]+@[a-zA-Z0-9]+\.[a-zA-Z]+", "test@example.com"))
  assert(not regex.full_match?(r"[a-zA-Z0-9.]+@[a-zA-Z0-9]+\.[a-zA-Z]+", "not-an-email"))
}

test "regex.full_match? ip-like pattern" {
  assert(regex.full_match?(r"\d+\.\d+\.\d+\.\d+", "192.168.1.1"))
  assert(not regex.full_match?(r"\d+\.\d+\.\d+\.\d+", "192.168.1"))
}

// ============================================================
// regex.find — edge cases
// ============================================================

test "regex.find empty pattern" {
  assert_eq(regex.find("", "hello"), some(""))
}

test "regex.find first word" {
  assert_eq(regex.find("[a-z]+", "hello world"), some("hello"))
}

// ============================================================
// regex.find_all — edge cases
// ============================================================

test "regex.find_all single match" {
  assert_eq(regex.find_all(r"\d+", "abc42def"), ["42"])
}

test "regex.find_all word extraction" {
  assert_eq(regex.find_all("[A-Z][a-z]+", "Hello World Foo"), ["Hello", "World", "Foo"])
}

// ============================================================
// regex.replace — additional cases
// ============================================================

test "regex.replace no match" {
  assert_eq(regex.replace(r"\d+", "hello world", "X"), "hello world")
}

test "regex.replace all characters" {
  assert_eq(regex.replace(".", "abc", "X"), "XXX")
}

// ============================================================
// regex.replace_first — edge cases
// ============================================================

test "regex.replace_first no match" {
  assert_eq(regex.replace_first(r"\d+", "hello", "X"), "hello")
}

test "regex.replace_first single occurrence" {
  assert_eq(regex.replace_first(r"\d+", "abc42", "X"), "abcX")
}

// ============================================================
// regex.split — edge cases
// ============================================================

test "regex.split no match" {
  assert_eq(regex.split(r"\d+", "hello"), ["hello"])
}

test "regex.split at start and end" {
  let result = regex.split(r"\d+", "1abc2def3")
  assert_eq(list.len(result), 4)
}

// ============================================================
// regex.captures — additional patterns
// ============================================================

test "regex.captures single group" {
  assert_eq(regex.captures(r"hello (\w+)", "hello world"), some(["world"]))
}

test "regex.captures three groups" {
  assert_eq(regex.captures(r"(\d+)-(\d+)-(\d+)", "2024-01-15"), some(["2024", "01", "15"]))
}

test "regex.captures no groups returns none" {
  assert_eq(regex.captures(r"\d+", "42"), none)
}
