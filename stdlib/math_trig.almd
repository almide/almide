// math_trig — SELF-HOSTED math.sin / math.cos / math.tan, a FAITHFUL transcription of
// runtime/rs/src/libm.rs (vendored libm 0.2.16 = FreeBSD msun / fdlibm). v0 uses the SAME
// libm for native + wasm, so a transcription with identical f64 ops in identical order is
// bit-identical across the WHOLE input range, including the Payne-Hanek large-argument path.
//
// Float constants are materialized via prim.ffrombits(<exact i64 bits>) — decimal literals
// drift ~1 ULP. Float arithmetic uses Almide operators (a*b+c) which lower to the prim float
// floor; op order / associativity is PRESERVED from the Rust source. Integer/bit math uses the
// prim bit floor (fbits/ffrombits/band/bor/bxor/bshl/bshr/bshr_u, f2i/i2f).
//
// The reduction result (n, y0, y1) is written into a caller-provided 3-slot scratch List[Int]
// (Almide self-host fns return a single value): slot0 = n, slot1 = bits(y0), slot2 = bits(y1).
// rem_pio2_large uses a few small scratch List[Int]/List[Float] arrays (q/iq/f/fq + the IPIO2
// 2/pi table prefix), each bounded and freed — pure scalar Float, the cert is untouched.

// ───────────────────────── kernel sin / cos / tan ─────────────────────────

// k_sin on ~[-pi/4, pi/4]. iy != 0 means y (the tail) is used.
fn __k_sin(x: Float, y: Float, iy: Int) -> Float = {
  let s1 = prim.ffrombits(0 - 4628199217061079735)
  let s2 = prim.ffrombits(4575957461383575718)
  let s3 = prim.ffrombits(0 - 4671919876304969259)
  let s4 = prim.ffrombits(4523617212983017085)
  let s5 = prim.ffrombits(0 - 4730215680275931925)
  let s6 = prim.ffrombits(4460209850635244924)
  let z = x * x
  let w = z * z
  let r = s2 + z * (s3 + z * s4) + z * w * (s5 + z * s6)
  let v = z * x
  if iy == 0 then x + v * (s1 + z * r)
  else x - ((z * (0.5 * y - v * r) - y) - v * s1)
}

// k_cos on [-pi/4, pi/4]. y is the tail of x.
fn __k_cos(x: Float, y: Float) -> Float = {
  let c1 = prim.ffrombits(4586165620538955084)
  let c2 = prim.ffrombits(0 - 4659324094485802633)
  let c3 = prim.ffrombits(4537941361668330896)
  let c4 = prim.ffrombits(0 - 4714566979978243411)
  let c5 = prim.ffrombits(4477121870137962948)
  let c6 = prim.ffrombits(0 - 4780295122622859052)
  let z = x * x
  let w = z * z
  let r = z * (c1 + z * (c2 + z * c3)) + w * w * (c4 + z * (c5 + z * c6))
  let hz = 0.5 * z
  let w2 = 1.0 - hz
  w2 + (((1.0 - w2) - hz) + (z * r - x * y))
}

fn __zero_low_word(x: Float) -> Float = {
  let mask = prim.bshl(0 - 1, 32)
  prim.ffrombits(prim.band(prim.fbits(x), mask))
}

// k_tan on ~[-pi/4, pi/4]. odd != 0 returns -1/tan, else tan.
fn __k_tan(x0: Float, y0: Float, odd: Int) -> Float = {
  let t0 = prim.ffrombits(4599676419421066595)
  let t1 = prim.ffrombits(4593971859893059194)
  let t2 = prim.ffrombits(4587938466107703806)
  let t3 = prim.ffrombits(4581960672245896759)
  let t4 = prim.ffrombits(4576262931677611155)
  let t5 = prim.ffrombits(4570429193025094440)
  let t6 = prim.ffrombits(4564358403679355669)
  let t7 = prim.ffrombits(4558562946408670465)
  let t8 = prim.ffrombits(4553182066015801448)
  let t9 = prim.ffrombits(4545397049192321702)
  let t10 = prim.ffrombits(4544897349388904425)
  let t11 = prim.ffrombits(0 - 4687273268743220365)
  let t12 = prim.ffrombits(4538267711989316308)
  let pio4 = prim.ffrombits(4605249457297304856)
  let pio4_lo = prim.ffrombits(4359948597267291143)

  let hx = prim.band(prim.bshr_u(prim.fbits(x0), 32), 4294967295)
  let big = prim.band(hx, 2147483647) >= 1072010280    // 0x3FE59428
  let sign = prim.bshr_u(hx, 31)
  // big branch: fold x into pi/4 - x. negate first when sign set.
  let xn = if big then (if sign == 0 then x0 else 0.0 - x0) else x0
  let yn = if big then (if sign == 0 then y0 else 0.0 - y0) else y0
  let x = if big then (pio4 - xn) + (pio4_lo - yn) else xn
  let y = if big then 0.0 else yn

  let z = x * x
  let w = z * z
  let r0 = t1 + w * (t3 + w * (t5 + w * (t7 + w * (t9 + w * t11))))
  let v0 = z * (t2 + w * (t4 + w * (t6 + w * (t8 + w * (t10 + w * t12)))))
  let s = z * x
  // r = y + z*(s*(r+v)+y) + s*T[0] — bind each step so no contraction (FMA-free, like v0).
  let rv = r0 + v0
  let srv = s * rv
  let inr = srv + y
  let zinr = z * inr
  let st0 = s * t0
  let r = y + zinr + st0
  let w3 = x + r
  if big then {
    let sg = prim.i2f(1 - 2 * odd)
    let v = sg - 2.0 * (x + (r - w3 * w3 / (w3 + sg)))
    if sign == 0 then v else 0.0 - v
  }
  else if odd == 0 then w3
  else {
    let w0 = __zero_low_word(w3)
    let v = r - (w0 - x)
    let a = (0.0 - 1.0) / w3
    let a0 = __zero_low_word(a)
    // a0 + a * (1.0 + a0*w0 + a0*v) — bind each product so no float op contracts (FMA-free, like v0).
    let p1 = a0 * w0
    let p2 = a0 * v
    let inner = 1.0 + p1 + p2
    let prod = a * inner
    a0 + prod
  }
}

// ───────────────────────── rem_pio2_large (Payne-Hanek) ─────────────────────────
// Faithful port of k_rem_pio2.c. x is a scratch List[Float] of `nx` 24-bit terms; ty is a
// 3-slot scratch List[Float] receiving y0,y1; prec is fixed at 1 here (the trig caller).
// Returns n & 7. Uses small scratch arrays f/q/fq (Float) and iq (Int), each `alloc`-bounded.

// Read IPIO2[i] from the table built once per large-path call (handle `tabh`).
fn __ipio2(tabh: Int, i: Int) -> Int = prim.load64(tabh + 12 + i * 8)

// The 2/pi integer table prefix — the first 101 24-bit groups, ample to cover the full f64
// range (max needed index over all finite f64 is ~50). Built once per large-path call.
fn __ipio2_table() -> List[Int] = {
  let t = prim.alloc_list(101)
  let h = prim.handle(t)
  prim.store64(h + 12 + 0 * 8, 10680707)
  prim.store64(h + 12 + 1 * 8, 7228996)
  prim.store64(h + 12 + 2 * 8, 1387004)
  prim.store64(h + 12 + 3 * 8, 2578385)
  prim.store64(h + 12 + 4 * 8, 16069853)
  prim.store64(h + 12 + 5 * 8, 12639074)
  prim.store64(h + 12 + 6 * 8, 9804092)
  prim.store64(h + 12 + 7 * 8, 4427841)
  prim.store64(h + 12 + 8 * 8, 16666979)
  prim.store64(h + 12 + 9 * 8, 11263675)
  prim.store64(h + 12 + 10 * 8, 12935607)
  prim.store64(h + 12 + 11 * 8, 2387514)
  prim.store64(h + 12 + 12 * 8, 4345298)
  prim.store64(h + 12 + 13 * 8, 14681673)
  prim.store64(h + 12 + 14 * 8, 3074569)
  prim.store64(h + 12 + 15 * 8, 13734428)
  prim.store64(h + 12 + 16 * 8, 16653803)
  prim.store64(h + 12 + 17 * 8, 1880361)
  prim.store64(h + 12 + 18 * 8, 10960616)
  prim.store64(h + 12 + 19 * 8, 8533493)
  prim.store64(h + 12 + 20 * 8, 3062596)
  prim.store64(h + 12 + 21 * 8, 8710556)
  prim.store64(h + 12 + 22 * 8, 7349940)
  prim.store64(h + 12 + 23 * 8, 6258241)
  prim.store64(h + 12 + 24 * 8, 3772886)
  prim.store64(h + 12 + 25 * 8, 3769171)
  prim.store64(h + 12 + 26 * 8, 3798172)
  prim.store64(h + 12 + 27 * 8, 8675211)
  prim.store64(h + 12 + 28 * 8, 12450088)
  prim.store64(h + 12 + 29 * 8, 3874808)
  prim.store64(h + 12 + 30 * 8, 9961438)
  prim.store64(h + 12 + 31 * 8, 366607)
  prim.store64(h + 12 + 32 * 8, 15675153)
  prim.store64(h + 12 + 33 * 8, 9132554)
  prim.store64(h + 12 + 34 * 8, 7151469)
  prim.store64(h + 12 + 35 * 8, 3571407)
  prim.store64(h + 12 + 36 * 8, 2607881)
  prim.store64(h + 12 + 37 * 8, 12013382)
  prim.store64(h + 12 + 38 * 8, 4155038)
  prim.store64(h + 12 + 39 * 8, 6285869)
  prim.store64(h + 12 + 40 * 8, 7677882)
  prim.store64(h + 12 + 41 * 8, 13102053)
  prim.store64(h + 12 + 42 * 8, 15825725)
  prim.store64(h + 12 + 43 * 8, 473591)
  prim.store64(h + 12 + 44 * 8, 9065106)
  prim.store64(h + 12 + 45 * 8, 15363067)
  prim.store64(h + 12 + 46 * 8, 6271263)
  prim.store64(h + 12 + 47 * 8, 9264392)
  prim.store64(h + 12 + 48 * 8, 5636912)
  prim.store64(h + 12 + 49 * 8, 4652155)
  prim.store64(h + 12 + 50 * 8, 7056368)
  prim.store64(h + 12 + 51 * 8, 13614112)
  prim.store64(h + 12 + 52 * 8, 10155062)
  prim.store64(h + 12 + 53 * 8, 1944035)
  prim.store64(h + 12 + 54 * 8, 9527646)
  prim.store64(h + 12 + 55 * 8, 15080200)
  prim.store64(h + 12 + 56 * 8, 6658437)
  prim.store64(h + 12 + 57 * 8, 6231200)
  prim.store64(h + 12 + 58 * 8, 6832269)
  prim.store64(h + 12 + 59 * 8, 16767104)
  prim.store64(h + 12 + 60 * 8, 5075751)
  prim.store64(h + 12 + 61 * 8, 3212806)
  prim.store64(h + 12 + 62 * 8, 1398474)
  prim.store64(h + 12 + 63 * 8, 7579849)
  prim.store64(h + 12 + 64 * 8, 6349435)
  prim.store64(h + 12 + 65 * 8, 12618859)
  prim.store64(h + 12 + 66 * 8, 4703257)
  prim.store64(h + 12 + 67 * 8, 12806093)
  prim.store64(h + 12 + 68 * 8, 14477321)
