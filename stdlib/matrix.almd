@inline_rust("almide_rt_matrix_from_bytes_f32_le(&{data}, {offset}, {rows}, {cols})")
fn from_bytes_f32_le(data: Bytes, offset: Int, rows: Int, cols: Int) -> Matrix = _

@inline_rust("almide_rt_matrix_to_bytes_f64_le(&{m})")
