// matrix — bundled-Almide stdlib module (Stdlib Declarative Unification Stage 4e).
//
// Migrated mechanically from `stdlib/defs/matrix.toml` (48 fns). All
// runtime fns take `&AlmideMatrix` / `&Vec<...>` borrows with owned
// scalars (f64 / i64) — templates use `&{m}` / `&{bias}` / `&{data}`
// matching each runtime signature. The `map` closure arg rides the
// standard `prepare_lambda` lambda-prep and renders as an ordinary
// Rust closure.
//
// `MatrixFusionPass` runs *before* `StdlibLoweringPass` (see
// `crates/almide-codegen/src/target.rs`), so `matrix.add(matrix.scale(
// a, ka), matrix.scale(b, kb))` already collapses to `matrix.fma(a,
// ka, b, kb)` by the time the InlineRust dispatch fires. No
// fusion-preserving reorder is needed — the fused form is still a
// plain `CallTarget::Module { module: "matrix", func: "fma" }`, which
// the bundled `@inline_rust` path dispatches directly.

// ── construction + metadata ──

@inline_rust("almide_rt_matrix_zeros({rows}, {cols})")
fn zeros(rows: Int, cols: Int) -> Matrix = _

@inline_rust("almide_rt_matrix_ones({rows}, {cols})")
fn ones(rows: Int, cols: Int) -> Matrix = _

@inline_rust("almide_rt_matrix_shape(&{m})")
fn shape(m: Matrix) -> (Int, Int) = _

@inline_rust("almide_rt_matrix_transpose(&{m})")
fn transpose(m: Matrix) -> Matrix = _

@inline_rust("almide_rt_matrix_from_lists(&{rows})")
fn from_lists(rows: List[List[Float]]) -> Matrix = _

@inline_rust("almide_rt_matrix_to_lists(&{m})")
fn to_lists(m: Matrix) -> List[List[Float]] = _

@inline_rust("almide_rt_matrix_get(&{m}, {row}, {col})")
fn get(m: Matrix, row: Int, col: Int) -> Float = _

@inline_rust("almide_rt_matrix_rows(&{m})")
fn rows(m: Matrix) -> Int = _

@inline_rust("almide_rt_matrix_cols(&{m})")
fn cols(m: Matrix) -> Int = _

// ── elementwise arithmetic ──

@inline_rust("almide_rt_matrix_add(&{a}, &{b})")
fn add(a: Matrix, b: Matrix) -> Matrix = _

@inline_rust("almide_rt_matrix_mul(&{a}, &{b})")
fn mul(a: Matrix, b: Matrix) -> Matrix = _

@inline_rust("almide_rt_matrix_scale(&{m}, {s})")
fn scale(m: Matrix, s: Float) -> Matrix = _

@inline_rust("almide_rt_matrix_fma(&{a}, {ka}, &{b}, {kb})")
fn fma(a: Matrix, ka: Float, b: Matrix, kb: Float) -> Matrix = _

@inline_rust("almide_rt_matrix_fma3(&{a}, {ka}, &{b}, {kb}, &{c}, {kc})")
fn fma3(a: Matrix, ka: Float, b: Matrix, kb: Float, c: Matrix, kc: Float) -> Matrix = _

@inline_rust("almide_rt_matrix_sub(&{a}, &{b})")
fn sub(a: Matrix, b: Matrix) -> Matrix = _

@inline_rust("almide_rt_matrix_div(&{a}, &{b})")
fn div(a: Matrix, b: Matrix) -> Matrix = _

@inline_rust("almide_rt_matrix_neg(&{m})")
fn neg(m: Matrix) -> Matrix = _

@inline_rust("almide_rt_matrix_pow(&{m}, {exp})")
fn pow(m: Matrix, exp: Float) -> Matrix = _

@inline_rust("almide_rt_matrix_map(&{m}, {f})")
fn map(m: Matrix, f: (Float) -> Float) -> Matrix = _

