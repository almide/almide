// bytes_cursor — SELF-HOSTED cursor reads (`bytes.read_*_at` / `bytes.take_at`),
// byte-matching native runtime/rs/src/bytes.rs's cursor macros: each returns
// `(next_pos, Option[T])`; on EOF (or a negative pos/len — native's `as usize` wrap
// lands past the end) the POSITION IS UNCHANGED and the value is `none`, so a caller
// detects the end without losing track. In-range values delegate to the PROVEN
// registered width primitives (`bytes.read_u16_le` …), so the byte decoding is shared,
// not duplicated. `take_at` copies the sub-range into a fresh Bytes (native's
// `to_vec`); `read_string_be_at` is the u32-BE-length-prefixed String read.

fn __bc_n(b: Bytes) -> Int = prim.load32(prim.handle(b) + 4)

fn bytes_read_u8_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 1 > __bc_n(b) then (pos, none)
  else (pos + 1, some(bytes.read_u8(b, pos)))

fn bytes_read_bool_at(b: Bytes, pos: Int) -> (Int, Option[Bool]) =
  if pos < 0 or pos >= __bc_n(b) then (pos, none)
  else (pos + 1, some(prim.load8(prim.handle(b) + 12 + pos) != 0))

fn bytes_read_u16_le_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 2 > __bc_n(b) then (pos, none)
  else (pos + 2, some(bytes.read_u16_le(b, pos)))

fn bytes_read_u16_be_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 2 > __bc_n(b) then (pos, none)
  else (pos + 2, some(bytes.read_u16_be(b, pos)))

fn bytes_read_i16_le_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 2 > __bc_n(b) then (pos, none)
  else (pos + 2, some(bytes.read_i16_le(b, pos)))

fn bytes_read_i16_be_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 2 > __bc_n(b) then (pos, none)
  else (pos + 2, some(bytes.read_i16_be(b, pos)))

fn bytes_read_u32_le_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else (pos + 4, some(bytes.read_u32_le(b, pos)))

fn bytes_read_u32_be_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else (pos + 4, some(bytes.read_u32_be(b, pos)))

fn bytes_read_i32_le_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else (pos + 4, some(bytes.read_i32_le(b, pos)))

fn bytes_read_i32_be_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else (pos + 4, some(bytes.read_i32_be(b, pos)))

fn bytes_read_i64_le_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 8 > __bc_n(b) then (pos, none)
  else (pos + 8, some(bytes.read_i64_le(b, pos)))

fn bytes_read_i64_be_at(b: Bytes, pos: Int) -> (Int, Option[Int]) =
  if pos < 0 or pos + 8 > __bc_n(b) then (pos, none)
  else (pos + 8, some(bytes.read_i64_be(b, pos)))

fn bytes_read_f16_le_at(b: Bytes, pos: Int) -> (Int, Option[Float]) =
  if pos < 0 or pos + 2 > __bc_n(b) then (pos, none)
  else (pos + 2, some(bytes.read_f16_le(b, pos)))

fn bytes_read_f32_le_at(b: Bytes, pos: Int) -> (Int, Option[Float]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else (pos + 4, some(bytes.read_f32_le(b, pos)))

fn bytes_read_f32_be_at(b: Bytes, pos: Int) -> (Int, Option[Float]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else (pos + 4, some(bytes.read_f32_be(b, pos)))

fn bytes_read_f64_le_at(b: Bytes, pos: Int) -> (Int, Option[Float]) =
  if pos < 0 or pos + 8 > __bc_n(b) then (pos, none)
  else (pos + 8, some(bytes.read_f64_le(b, pos)))

fn bytes_read_f64_be_at(b: Bytes, pos: Int) -> (Int, Option[Float]) =
  if pos < 0 or pos + 8 > __bc_n(b) then (pos, none)
  else (pos + 8, some(bytes.read_f64_be(b, pos)))

fn __bc_copy(dst: Int, src: Int, n: Int, i: Int) -> Int =
  if i >= n then 0
  else { prim.store8(dst + i, prim.load8(src + i)); __bc_copy(dst, src, n, i + 1) }

fn bytes_take_at(b: Bytes, pos: Int, len: Int) -> (Int, Option[Bytes]) =
  if pos < 0 or len < 0 or pos + len > __bc_n(b) then (pos, none)
  else {
    let out = prim.alloc_bytes(len)
    let _c = __bc_copy(prim.handle(out) + 12, prim.handle(b) + 12 + pos, len, 0)
    (pos + len, some(out))
  }

fn bytes_read_string_be_at(b: Bytes, pos: Int) -> (Int, Option[String]) =
  if pos < 0 or pos + 4 > __bc_n(b) then (pos, none)
  else {
    let slen = bytes.read_u32_be(b, pos)
    if pos + 4 + slen > __bc_n(b) then (pos, none)
    else (pos + 4 + slen, some(bytes.read_string_at(b, pos + 4, slen)))
  }
