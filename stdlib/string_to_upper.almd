// to_upper — SELF-HOSTED `string.to_upper(s)` for v1: FULL Unicode case mapping,
// NORMATIVE SPEC: ALS-T5 (docs/specs/als/text-and-numbers.md §T5) — conformance is judged against that section's
// rules and its pinned fixture, NOT against any other implementation (F1: no oracle circularity).
// byte-identical to v0's `str::to_uppercase()`. The mapping table is GENERATED
// FROM RUST ITSELF (scratch casedump: every codepoint where to_uppercase != identity,
// 1580 entries incl. 1:N SpecialCasing like ß→SS) so the two implementations
// cannot drift — regenerate with scripts/gen-case-tables.py when the Rust
// toolchain's Unicode version changes. Encoding: a sorted fixed-width hex
// string, 12 hex chars per entry = [cp:6][target:6]; target >= 0xF00000 is an
// index into the 18-hex-wide specials table [c1:6][c2:6][c3:6] (zero-padded).
// Lookup = binary search over the literal (static data, no per-call parse);
// ASCII takes the arithmetic fast path and never reaches the table.

fn __to_upper_h1(b: Int) -> Int =
  if b <= 57 then b - 48 else b - 55

fn __to_upper_rd6(a: Int) -> Int =
  __to_upper_h1(prim.load8(a)) * 1048576 + __to_upper_h1(prim.load8(a + 1)) * 65536
    + __to_upper_h1(prim.load8(a + 2)) * 4096 + __to_upper_h1(prim.load8(a + 3)) * 256
    + __to_upper_h1(prim.load8(a + 4)) * 16 + __to_upper_h1(prim.load8(a + 5))

fn __to_upper_find(th: Int, lo: Int, hi: Int, cp: Int) -> Int =
  if lo >= hi then 0 - 1
  else {
    let mid = (lo + hi) / 2
    let e = __to_upper_rd6(th + mid * 12)
    if e == cp then mid
    else if e < cp then __to_upper_find(th, mid + 1, hi, cp)
    else __to_upper_find(th, lo, mid, cp)
  }

fn __to_upper_cp(addr: Int) -> (Int, Int) = {
  let b0 = prim.load8(addr)
  if b0 < 128 then (b0, 1)
  else if b0 < 224 then ((b0 - 192) * 64 + (prim.load8(addr + 1) - 128), 2)
  else if b0 < 240 then ((b0 - 224) * 4096 + (prim.load8(addr + 1) - 128) * 64 + (prim.load8(addr + 2) - 128), 3)
  else ((b0 - 240) * 262144 + (prim.load8(addr + 1) - 128) * 4096 + (prim.load8(addr + 2) - 128) * 64 + (prim.load8(addr + 3) - 128), 4)
}

fn __to_upper_w(dh: Int, o: Int, cp: Int) -> Int =
  if cp < 128 then {
    prim.store8(dh + o, cp)
    1
  }
  else if cp < 2048 then {
    prim.store8(dh + o, 192 + cp / 64)
    prim.store8(dh + o + 1, 128 + cp % 64)
    2
  }
  else if cp < 65536 then {
    prim.store8(dh + o, 224 + cp / 4096)
    prim.store8(dh + o + 1, 128 + (cp / 64) % 64)
    prim.store8(dh + o + 2, 128 + cp % 64)
    3
  }
  else {
    prim.store8(dh + o, 240 + cp / 262144)
    prim.store8(dh + o + 1, 128 + (cp / 4096) % 64)
    prim.store8(dh + o + 2, 128 + (cp / 64) % 64)
    prim.store8(dh + o + 3, 128 + cp % 64)
    4
  }

fn __to_upper_walk(p: Int, end: Int, th: Int, nent: Int, sh: Int, dh: Int, o: Int) -> Int =
  if p >= end then o
  else {
    let b0 = prim.load8(p)
    if b0 < 128 then {
      prim.store8(dh + o, (if b0 >= 97 and b0 <= 122 then b0 - 32 else b0))
      __to_upper_walk(p + 1, end, th, nent, sh, dh, o + 1)
    }
    else {
      let (cp, l) = __to_upper_cp(p)
      let idx = __to_upper_find(th, 0, nent, cp)
      if idx < 0 then {
        let w = __to_upper_w(dh, o, cp)
        __to_upper_walk(p + l, end, th, nent, sh, dh, o + w)
      }
      else {
        let v = __to_upper_rd6(th + idx * 12 + 6)
        if v < 15728640 then {
          let w = __to_upper_w(dh, o, v)
          __to_upper_walk(p + l, end, th, nent, sh, dh, o + w)
        }
        else {
          let sa = sh + (v - 15728640) * 18
          let c1 = __to_upper_rd6(sa)
          let c2 = __to_upper_rd6(sa + 6)
          let c3 = __to_upper_rd6(sa + 12)
          let w1 = __to_upper_w(dh, o, c1)
          let w2 = if c2 != 0 then __to_upper_w(dh, o + w1, c2) else 0
          let w3 = if c3 != 0 then __to_upper_w(dh, o + w1 + w2, c3) else 0
          __to_upper_walk(p + l, end, th, nent, sh, dh, o + w1 + w2 + w3)
        }
      }
    }
  }

fn string_to_upper(s: String) -> String = {
  let tbl = ""
  let sp = ""
  let h = prim.handle(s)
  let blen = prim.load32(h + 4)
  let buf = prim.alloc_str(blen * 3 + 8)
  let outn = __to_upper_walk(h + 12, h + 12 + blen, prim.handle(tbl) + 12, 1580, prim.handle(sp) + 12, prim.handle(buf) + 12, 0)
  prim.store32(prim.handle(buf) + 4, outn)
  buf
}
