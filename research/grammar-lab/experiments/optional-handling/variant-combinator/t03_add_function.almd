type Product = { name: String, price: Int, category: String }

fn find_price(products: List[Product], target: String) -> Int =
  list.find(products, (p) => p.name == target)
    |> option.map((p) => p.price)
    |> option.unwrap_or(0)

fn product_names(products: List[Product]) -> List[String] =
  products |> list.map((p) => p.name)
