// Grammar Lab — A/B test runner for Almide syntax variants
// Usage: almide run src/mod.almd -- <experiment-dir> [--model <name>] [--trials <n>]

import json
import fs
import process
import http
import env


// ── Config ──

effect fn resolve_bin(env_var: String, name: String, fallback: String) -> String = {
  // 1. Environment variable
  match env.get(env_var) {
    some(p) => p,
    none => {
      // 2. Try `which` to find in PATH
      let r = process.exec_status("which", [name])
      if r.code == 0 then {
        string.trim(r.stdout)
      } else {
        // 3. Fallback (relative path)
        fallback
      }
    },
  }
}

effect fn get_almide_bin() -> String =
  resolve_bin("ALMIDE_BIN", "almide", "../../target/release/almide")

// ── Helpers ──

effect fn println(s: String) -> Unit = io.print(s ++ "\n")

// ── Entry Point ──

effect fn main() -> Result[Unit, String] = {
  match run_experiment() {
    ok(_) => ok(()),
    err(e) => {
      println("Error: ${e}")
      process.exit(1)
      ok(())
    },
  }
}

effect fn run_experiment() -> Result[Unit, String] = {
  let raw_args = env.args()
  // Skip argv[0] (binary path)
  let args_list = list.drop(raw_args, 1)
  guard list.len(args_list) >= 1 else err("Usage: grammar-lab <experiment-dir> [--model <name>] [--trials <n>]")

  let experiment_dir = match list.get(args_list, 0) {
    some(d) => d,
    none => "",
  }

  // Load experiment config
  let config_path = "${experiment_dir}/experiment.json"
  let config_text = fs.read_text(config_path)
  let config = json.parse(config_text)

  let experiment_name = json.get_string(config, "name").unwrap_or("unknown")
  let trials = json.get_int(config, "trials").unwrap_or(5)

  // trials is from experiment.json (CLI override removed for now)

  // Load models
  let models = json.get_array(config, "models").unwrap_or([])

  // Filter model from CLI
  let model_filter = parse_cli_string(args_list, "--model", "")

  // Load task names
  let task_names = json.get_array(config, "tasks").unwrap_or([])

  // Load variants
  let variants = json.get_array(config, "variants").unwrap_or([])

  // Load prompt layers
  let layer1 = fs.read_text("prompts/layer1_rules.md")

  println("=== Grammar Lab ===")
  println("Experiment: ${experiment_name}")
  println("Trials: ${int.to_string(trials)}")
  println("")

  // Results accumulator
  var all_results: List[Value] = []

  for model_json in models {
    let model_name = json.get_string(model_json, "name").unwrap_or("")
    let provider = json.get_string(model_json, "provider").unwrap_or("")
    let model_id = json.get_string(model_json, "model_id").unwrap_or("")

    // Skip if model filter is set and doesn't match
    if model_filter != "" and model_filter != model_name then {
      continue
    } else {
      ()
    }

    println("Model: ${model_name}")

    for variant_json in variants {
      let variant_name = json.get_string(variant_json, "name").unwrap_or("")
      let variant_dir = json.get_string(variant_json, "dir").unwrap_or("")
      let transpile_mode = json.get_string(variant_json, "transpile_regex").unwrap_or("")

      // Load layer2 for this variant
      let layer2_path = "prompts/layer2_${variant_name}.md"
      let layer2 = if fs.exists(layer2_path) then {
        let t = fs.read_text(layer2_path)
        t
      } else {
        ""
      }

      println("  Variant: ${variant_name}")

      for task_name_json in task_names {
        let task_name = json.as_string(task_name_json).unwrap_or("")

        // Load task config
        let task_config_text = fs.read_text("${experiment_dir}/tasks/${task_name}.json")
        let task_config = json.parse(task_config_text)
        let instruction = json.get_string(task_config, "instruction").unwrap_or("")
        let layer3 = json.get_string(task_config, "layer3_hint").unwrap_or("")
        let test_file_name = json.get_string(task_config, "test_file").unwrap_or("")

        // Load source code for this variant
        let source_code = fs.read_text("${experiment_dir}/${variant_dir}/${task_name}.almd")

        // Load test code
        let test_code = fs.read_text("${experiment_dir}/tasks/${test_file_name}")

        for trial_num in 1..=trials {
          println("    Task: ${task_name} trial ${int.to_string(trial_num)}/${int.to_string(trials)}")

          // Build prompt
          let system_prompt = build_system_prompt(layer1, layer2, layer3)
          let user_prompt = build_user_prompt(source_code, test_code, instruction)

          // Call LLM
          let llm_response = call_llm(provider, model_id, system_prompt, user_prompt)

          // Extract code from response, strip any test blocks LLM may have included
          let modified_code = strip_test_blocks(extract_code(llm_response))

          // Save raw LLM output for debugging/analysis
          let output_dir = "outputs/${experiment_name}/${model_name}/${variant_name}"
          fs.mkdir_p(output_dir)
          fs.write("${output_dir}/${task_name}_${int.to_string(trial_num)}_raw.almd", modified_code)

          // Transpile if needed (convert experimental syntax to current syntax for compilation)
          let compilable_code = transpile(modified_code, transpile_mode)
          fs.write("${output_dir}/${task_name}_${int.to_string(trial_num)}_compiled.almd", compilable_code)

          // Evaluate: write to temp file, compile, test
          let eval_result = evaluate(compilable_code, test_code, task_name)

          let result = make_result_json(experiment_name, variant_name, model_name, task_name, trial_num, eval_result)

          all_results = all_results ++ [result]

          let status = if eval_result.tests_passed then "PASS"
            else if eval_result.compiled then "FAIL (test)"
            else "FAIL (compile)"
          println("      ${status}")
        }
      }
    }
  }

  // Write results
  let results_text = json.stringify_pretty(json.array(all_results))
  let timestamp = int.to_string(env.unix_timestamp())
  let results_path = "results/${experiment_name}_${timestamp}.json"
  fs.mkdir_p("results")
  fs.write(results_path, results_text)
  println("")
  println("Results written to ${results_path}")

  // Re-read results for summary (avoids move issue)
  let summary_text = fs.read_text(results_path)
  let summary_results = json.parse(summary_text)
  let summary_list = json.as_array(summary_results).unwrap_or([])
  print_summary(summary_list)

  ok(())
}

// ── Prompt Building ──

fn build_system_prompt(layer1: String, layer2: String, layer3: String) -> String =
  "You are modifying code written in Almide (.almd files). Return ONLY the modified code, no explanation.\n\n${layer1}\n\n${layer2}\n\n${layer3}"

fn build_user_prompt(source: String, tests: String, instruction: String) -> String =
  "## Current Code\n\n```almide\n${source}\n```\n\n## Tests (must pass after modification)\n\n```almide\n${tests}\n```\n\n## Task\n\n${instruction}\n\nReturn ONLY the modified source code (the Current Code section above, with your changes applied). Do NOT include the test blocks — tests will be appended automatically. Wrap your code in ```almide ... ```."

// ── LLM API ──

effect fn call_llm(provider: String, model_id: String, system: String, user: String) -> Result[String, String] =
  call_claude_code(model_id, system, user)

effect fn call_claude_code(model_id: String, system: String, user: String) -> Result[String, String] = {
  let claude_bin = resolve_bin("CLAUDE_BIN", "claude", "claude")
  let r = process.exec_status(
    claude_bin,
    ["-p", "--model", model_id, "--append-system-prompt", system, "--output-format", "text", "--max-turns", "1", user]
  )
  if r.code != 0 then {
    err("claude-code failed: ${r.stderr}")
  } else {
    ok(r.stdout)
  }
}

effect fn call_anthropic(model_id: String, system: String, user: String) -> Result[String, String] =
  err("anthropic provider not implemented — use claude-code")

effect fn call_openai(model_id: String, system: String, user: String) -> Result[String, String] =
  err("openai provider not implemented — use claude-code")

// ── Strip Test Blocks ──

fn strip_test_blocks(code: String) -> String = {
  // Remove test "..." { ... } blocks from LLM output
  // Tests are appended by the runner, so duplicates cause compile errors
  let lines = string.split(code, "\n")
  var result: List[String] = []
  var in_test = false
  var brace_depth = 0
  for line in lines {
    if not in_test and string.starts_with(string.trim(line), "test ") then {
      in_test = true
      brace_depth = 0
      // Count opening braces on this line
      for c in string.chars(line) {
        if c == "{" then { brace_depth = brace_depth + 1 } else { () }
        if c == "}" then { brace_depth = brace_depth - 1 } else { () }
      }
      if brace_depth <= 0 then { in_test = false } else { () }
    } else if in_test then {
      for c in string.chars(line) {
        if c == "{" then { brace_depth = brace_depth + 1 } else { () }
        if c == "}" then { brace_depth = brace_depth - 1 } else { () }
      }
      if brace_depth <= 0 then { in_test = false } else { () }
    } else {
      result = result ++ [line]
    }
  }
  string.join(result, "\n")
}

// ── Transpile ──

fn transpile(code: String, mode: String) -> String =
  if mode == "" then {
    code
  } else if mode == "paren-to-fn-lambda" then {
    // Transform (params) => to (params) =>
    // Strategy: find ") =>" and look backwards for matching "("
    // If not preceded by "fn", insert "fn"
    let lines = string.split(code, "\n")
    let converted = list.map(lines, (line) => transpile_line_paren_to_(line))
    string.join(converted, "\n")
  } else if mode == "combinator-to-match" then {
    // Transform option.map/flat_map/unwrap_or to match expressions
    let lines = string.split(code, "\n")
    let converted = list.map(lines, (line) => transpile_line_combinator(line))
    string.join(converted, "\n")
  } else {
    code
  }

fn transpile_line_paren_to_(line: String) -> String = {
  // Generic approach: find ") =>" and look backwards for matching "("
  // If "(" is not preceded by "fn" or a keyword, insert "fn"
  // Handles any parameter names without enumeration

  if not string.contains(line, ") =>") then {
    line
  } else {
    // Find all ") =>" positions
    var positions: List[Int] = []
    var si = 0
    let line_len = string.len(line)
    while si + 4 <= line_len {
      if string.slice(line, si, si + 4) == ") =>" then {
        positions = positions ++ [si]
        si = si + 4
      } else {
        si = si + 1
      }
    }

    if list.len(positions) == 0 then {
      line
    } else {
      // For each ") =>" find matching "(" by scanning backwards
      var insert_positions: List[Int] = []
      for close_pos in positions {
        var depth = 1
        var j = close_pos - 1
        var open_pos = -1
        while j >= 0 and depth > 0 {
          let ch = string.slice(line, j, j + 1)
          if ch == ")" then { depth = depth + 1 }
          else if ch == "(" then {
            depth = depth - 1
            if depth == 0 then { open_pos = j } else { () }
          } else { () }
          j = j - 1
        }

        if open_pos >= 0 then {
          // Check character before "(" — if alpha/underscore, it's part of a word (some, fn, etc.)
          let skip = if open_pos >= 1 then {
            let prev = string.slice(line, open_pos - 1, open_pos)
            string.contains("abcdefghijklmnopqrstuvwxyz_", prev)
          } else {
            false
          }
          if not skip then {
            insert_positions = insert_positions ++ [open_pos]
          } else { () }
        } else { () }
      }

      // Insert "fn" at positions (reverse order to preserve indices)
      if list.len(insert_positions) == 0 then {
        line
      } else {
        let sorted = insert_positions |> list.sort() |> list.reverse()
        var result = line
        for pos in sorted {
          let before = string.slice(result, 0, pos)
          let after = string.slice(result, pos, string.len(result))
          result = before ++ "fn" ++ after
        }
        result
      }
    }
  }
}

// ── Combinator-to-match transpile ──

fn find_pos(s: String, sub: String) -> Int = {
  let s_len = string.len(s)
  let sub_len = string.len(sub)
  var i = 0
  var result = -1
  while i + sub_len <= s_len and result < 0 {
    if string.slice(s, i, i + sub_len) == sub then {
      result = i
    } else {
      i = i + 1
    }
  }
  result
}

fn replace_all_str(s: String, old: String, replacement: String) -> String =
  if not string.contains(s, old) then {
    s
  } else {
    let parts = string.split(s, old)
    string.join(parts, replacement)
  }

fn transpile_line_combinator(line: String) -> String = {
  // Step 1: Replace "option.unwrap_or(" with "unwrap_or("
  let line = replace_all_str(line, "option.unwrap_or(", "unwrap_or(")
  // Step 2: Handle |> option.map(fn(...) => ...)
  let line = transpile_pipe_option(line, "option.map", true)
  // Step 3: Handle |> option.flat_map(fn(...) => ...)
  let line = transpile_pipe_option(line, "option.flat_map", false)
  line
}

fn transpile_pipe_option(line: String, call_name: String, wrap_some: Bool) -> String = {
  let marker = "|> ${call_name}(fn("
  if not string.contains(line, marker) then {
    line
  } else {
    let marker_pos = find_pos(line, marker)
    if marker_pos < 0 then { line }
    else {
      let pipe_pos = marker_pos
      // Position of opening "(" after call_name: "|> " + call_name + "("
      let open_paren_pos = marker_pos + string.len("|> ") + string.len(call_name)

      // Find matching ")" using bracket matching
      var depth = 1
      var i = open_paren_pos + 1
      let line_len = string.len(line)
      var close_pos = -1
      while i < line_len and depth > 0 {
        let ch = string.slice(line, i, i + 1)
        if ch == "(" then { depth = depth + 1 }
        else if ch == ")" then {
          depth = depth - 1
          if depth == 0 then { close_pos = i } else { () }
        } else { () }
        i = i + 1
      }

      if close_pos < 0 then { line }
      else {
        // Content between parens is "fn(PARAM) => BODY"
        let content = string.slice(line, open_paren_pos + 1, close_pos)
        let fn_prefix = "fn("
        if not string.starts_with(content, fn_prefix) then { line }
        else {
          let after_fn = string.slice(content, string.len(fn_prefix), string.len(content))
          // Find ") => " to separate param from body
          let arrow_pos = find_pos(after_fn, ") => ")
          if arrow_pos < 0 then { line }
          else {
            let param = string.slice(after_fn, 0, arrow_pos)
            let body = string.slice(after_fn, arrow_pos + 5, string.len(after_fn))
            let match_expr = if wrap_some then {
              "|> match { some(${param}) => some(${body}), none => none }"
            } else {
              "|> match { some(${param}) => ${body}, none => none }"
            }
            let before = string.slice(line, 0, pipe_pos)
            let after = string.slice(line, close_pos + 1, line_len)
            before ++ match_expr ++ after
          }
        }
      }
    }
  }
}

// ── Code Extraction ──

fn extract_code(response: String) -> String = {
  // Find ```almide ... ``` block
  let lines = string.split(response, "\n")
  var in_block = false
  var code_lines: List[String] = []
  for line in lines {
    if string.starts_with(line, "```almide") then {
      in_block = true
    } else if in_block and string.starts_with(line, "```") then {
      in_block = false
    } else if in_block then {
      code_lines = code_lines ++ [line]
    } else {
      ()
    }
  }
  // If no code block found, assume entire response is code
  if list.len(code_lines) == 0 then {
    response
  } else {
    string.join(code_lines, "\n")
  }
}

// ── Evaluation ──

type EvalResult = { compiled: Bool, tests_passed: Bool, error: String }

effect fn evaluate(code: String, test_code: String, task_name: String) -> EvalResult = {
  // Write modified code to temp file
  let tmp_dir = "/tmp/grammar-lab"
  let code_path = "${tmp_dir}/${task_name}.almd"
  let combined = "${code}\n\n${test_code}"

  fs.mkdir_p(tmp_dir)
  fs.write(code_path, combined)

  // Run almide check
  let check_r = process.exec_status(get_almide_bin(), ["check", code_path])
  if check_r.code != 0 then {
    EvalResult { compiled: false, tests_passed: false, error: check_r.stderr }
  } else {
    // Run almide test
    let test_r = process.exec_status(get_almide_bin(), ["test", code_path])
    if test_r.code != 0 then {
      EvalResult { compiled: true, tests_passed: false, error: test_r.stderr }
    } else {
      EvalResult { compiled: true, tests_passed: true, error: "" }
    }
  }
}

// ── Summary ──

fn count_passed(results: List[Value], model_name: String, variant_name: String) -> (Int, Int) = {
  let matching = results
    |> list.filter((r) => {
      let m = json.get_string(r, "model").unwrap_or("")
      let v = json.get_string(r, "variant").unwrap_or("")
      m == model_name and v == variant_name
    })
  let total = list.len(matching)
  let passed = matching
    |> list.filter((r) => json.get_bool(r, "tests_passed").unwrap_or(false))
    |> list.len()
  (passed, total)
}

fn format_cell(passed: Int, total: Int) -> String = {
  let pct = if total > 0 then int.to_string(passed * 100 / total) else "0"
  "${pct}% (${int.to_string(passed)}/${int.to_string(total)})"
}

fn build_row(results: List[Value], model_name: String, variants: List[String]) -> String = {
  // Build cells first to avoid ownership issues with model_name
  let cells = list.map(variants, (v) => {
    let (passed, total) = count_passed(results, model_name, v)
    string.pad_end(format_cell(passed, total), 20, " ")
  })
  let row = string.pad_end(model_name, 20, " ")
  row ++ string.join(cells, "")
}

fn count_passed_task(results: List[Value], model_name: String, variant_name: String, task_name: String) -> (Int, Int) = {
  let matching = results
    |> list.filter((r) => {
      let m = json.get_string(r, "model").unwrap_or("")
      let v = json.get_string(r, "variant").unwrap_or("")
      let t = json.get_string(r, "task").unwrap_or("")
      m == model_name and v == variant_name and t == task_name
    })
  let total = list.len(matching)
  let passed = matching
    |> list.filter((r) => json.get_bool(r, "tests_passed").unwrap_or(false))
    |> list.len()
  (passed, total)
}

fn build_task_row(results: List[Value], model_name: String, task_name: String, variants: List[String]) -> String = {
  let cells = list.map(variants, (v) => {
    let (passed, total) = count_passed_task(results, model_name, v, task_name)
    string.pad_end(format_cell(passed, total), 20, " ")
  })
  let row = string.pad_end("  " ++ task_name, 24, " ")
  row ++ string.join(cells, "")
}

effect fn print_summary(results: List[Value]) -> Unit = {
  println("=== Summary ===")
  println("")

  let models = results
    |> list.map((r) => json.get_string(r, "model").unwrap_or(""))
    |> list.unique()

  let variants = results
    |> list.map((r) => json.get_string(r, "variant").unwrap_or(""))
    |> list.unique()

  let tasks = results
    |> list.map((r) => json.get_string(r, "task").unwrap_or(""))
    |> list.unique()

  let variant_names = variants
  let task_names = tasks

  for model_name in models {
    // Model header
    println("Model: ${model_name}")

    // Variant header
    var header = string.pad_end("", 24, " ")
    for v in variant_names {
      header = header ++ string.pad_end(v, 20, " ")
    }
    println(header)

    // Total row
    let total_cells = list.map(variant_names, (v) => {
      let (passed, total) = count_passed(results, model_name, v)
      string.pad_end(format_cell(passed, total), 20, " ")
    })
    println(string.pad_end("  TOTAL", 24, " ") ++ string.join(total_cells, ""))

    // Per-task rows
    for task_name in task_names {
      println(build_task_row(results, model_name, task_name, variant_names))
    }

    // Fisher's exact test (if exactly 2 variants)
    if list.len(variant_names) == 2 then {
      let v1 = match list.get(variant_names, 0) { some(v) => v, none => "" }
      let v2 = match list.get(variant_names, 1) { some(v) => v, none => "" }
      let (p1, t1) = count_passed(results, model_name, v1)
      let (p2, t2) = count_passed(results, model_name, v2)
      let a = p1       // variant 1 pass
      let b = t1 - p1  // variant 1 fail
      let c = p2       // variant 2 pass
      let d = t2 - p2  // variant 2 fail
      let p = fishers_exact_p(a, b, c, d)
      let p_str = float.to_fixed(p, 4)
      let sig = if p < 0.05 then " *" else if p < 0.10 then " ." else ""
      println("  Fisher's exact test: p = ${p_str}${sig}")
    } else {
      ()
    }
    println("")
  }
}

// ── Fisher's Exact Test ──

fn log_choose(n: Int, k: Int) -> Float = {
  // log(C(n, k)) = log_gamma(n+1) - log_gamma(k+1) - log_gamma(n-k+1)
  math.log_gamma(int.to_float(n + 1))
    - math.log_gamma(int.to_float(k + 1))
    - math.log_gamma(int.to_float(n - k + 1))
}

fn hypergeometric_log_pmf(a: Int, b: Int, c: Int, d: Int) -> Float = {
  // P(X=a) for 2x2 table [[a,b],[c,d]]
  let n = a + b + c + d
  log_choose(a + b, a) + log_choose(c + d, c) - log_choose(n, a + c)
}

fn fishers_exact_p(a: Int, b: Int, c: Int, d: Int) -> Float = {
  // Two-tailed Fisher's exact test
  // Sum probabilities of all tables as or more extreme than observed
  let n = a + b + c + d
  let r1 = a + b   // row 1 total
  let c1 = a + c   // col 1 total
  let observed_log_p = hypergeometric_log_pmf(a, b, c, d)
  let observed_p = math.exp(observed_log_p)

  // Enumerate all possible values of a (0..min(r1, c1))
  let max_a = math.min(r1, c1)
  var p_value = 0.0
  for i in 0..=max_a {
    let bi = r1 - i
    let ci = c1 - i
    let di = n - r1 - ci
    if bi >= 0 and ci >= 0 and di >= 0 then {
      let log_pi = hypergeometric_log_pmf(i, bi, ci, di)
      let pi = math.exp(log_pi)
      // Include if probability <= observed (two-tailed)
      if pi <= observed_p + 0.0000001 then {
        p_value = p_value + pi
      } else {
        ()
      }
    } else {
      ()
    }
  }
  // Clamp to [0, 1]
  math.fmin(1.0, p_value)
}

// ── Result JSON Builder ──

fn make_result_json(experiment: String, variant: String, model: String, task: String, trial: Int, eval: EvalResult) -> Value =
  json.object([
    ("experiment", json.from_string(experiment)),
    ("variant", json.from_string(variant)),
    ("model", json.from_string(model)),
    ("task", json.from_string(task)),
    ("trial", json.from_int(trial)),
    ("compiled", json.from_bool(eval.compiled)),
    ("tests_passed", json.from_bool(eval.tests_passed)),
    ("error", json.from_string(eval.error)),
  ])

// ── CLI Helpers ──

fn parse_cli_string(args: List[String], flag: String, fb: String) -> String =
  fb

