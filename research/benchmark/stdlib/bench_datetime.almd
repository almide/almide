import datetime
fn bench(name: String, f: () -> Unit) -> Unit = { let s = datetime.monotonic_ns(); f(); let ms = (datetime.monotonic_ns() - s) / 1000000; let st = if ms <= 1 then "OK" else if ms <= 50 then "ok" else "SLOW"; println("  [${st}] ${name}: ${int.to_string(ms)}ms") }
fn main() -> Unit = {
  println("== Datetime ==")
  bench("datetime.now 100k", () => { var i = 0; while i < 100000 { let _r = datetime.now(); i = i + 1 } })
  bench("datetime.format 10k", () => { let ts = datetime.now(); var i = 0; while i < 10000 { let _r = datetime.format(ts, "YYYY-MM-DD"); i = i + 1 } })
  bench("datetime.parse_iso 10k", () => { var i = 0; while i < 10000 { let _r = datetime.parse_iso("2026-05-23T12:00:00Z"); i = i + 1 } })
}
