import datetime
import random
fn bench_effect(name: String, f: () -> Unit) -> Unit = { let s = datetime.monotonic_ns(); f(); let ms = (datetime.monotonic_ns() - s) / 1000000; let st = if ms <= 1 then "OK" else if ms <= 50 then "ok" else "SLOW"; println("  [${st}] ${name}: ${int.to_string(ms)}ms") }
effect fn main() -> Unit = {
  println("== Random ==")
  bench_effect("random.int 100k", () => { var i = 0; while i < 100000 { let _r = random.int(0, 1000); i = i + 1 } })
  bench_effect("random.float 100k", () => { var i = 0; while i < 100000 { let _r = random.float(); i = i + 1 } })
}
