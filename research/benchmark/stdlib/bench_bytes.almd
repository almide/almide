import datetime
import bytes
fn bench(name: String, f: () -> Unit) -> Unit = { let s = datetime.monotonic_ns(); f(); let ms = (datetime.monotonic_ns() - s) / 1000000; let st = if ms <= 1 then "OK" else if ms <= 50 then "ok" else "SLOW"; println("  [${st}] ${name}: ${int.to_string(ms)}ms") }
fn main() -> Unit = {
  println("== Bytes ==")
  bench("bytes.push 100k", () => { var buf: Bytes = bytes.new(0); var i = 0; while i < 100000 { bytes.push(buf, i % 256); i = i + 1 } })
  bench("bytes.index r/w 100k", () => { var buf: Bytes = bytes.new(100000); var i = 0; while i < 100000 { buf[i] = i % 256; i = i + 1 }; var s = 0; var j = 0; while j < 100000 { s = s + buf[j]; j = j + 1 } })
  bench("bytes.slice 10k", () => { let buf = bytes.new(100000); var i = 0; while i < 10000 { let _r = buf[i..i+100]; i = i + 1 } })
}
