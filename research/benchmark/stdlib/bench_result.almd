import datetime
fn bench(name: String, f: () -> Unit) -> Unit = { let s = datetime.monotonic_ns(); f(); let ms = (datetime.monotonic_ns() - s) / 1000000; let st = if ms <= 1 then "OK" else if ms <= 50 then "ok" else "SLOW"; println("  [${st}] ${name}: ${int.to_string(ms)}ms") }
fn main() -> Unit = {
  println("== Option + Result ==")
  bench("option unwrap_or 100k", () => { var i = 0; var acc = 0; while i < 100000 { let v: Option[Int] = some(i); acc = acc + (v ?? 0); i = i + 1 } })
  bench("result unwrap_or 100k", () => { var i = 0; var acc = 0; while i < 100000 { let v: Result[Int, String] = ok(i); acc = acc + (v ?? 0); i = i + 1 } })
}
